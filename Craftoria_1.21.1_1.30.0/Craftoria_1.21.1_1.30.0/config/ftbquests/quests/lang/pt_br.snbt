	quest.495EEAA73357FA60.quest_subtitle: "Надпотужний"
	quest.495EEAA73357FA60.title: "Інструменти та зброя зі Сплаву Затемнення"
	quest.497660DB9611C67C.quest_desc: ["Як звичайний &bЖолоб&r, але з &6фільтрацією&r та &6контролем швидкості&r."]
	quest.4980C231ECDB0BF2.quest_desc: ["  &bСталевий Бур&r дає вам решту &6найпоширеніших руд&r, які знадобляться для подальшого прогресу в автоматизації, а також у вашій подорожі світом. Перевірте EMI для всіх можливих результатів."]
	quest.4980C231ECDB0BF2.title: "Сталевий Бур"
	quest.49910F2EFEA1CDF2.quest_desc: [
		"  &bПростий&r:"
		"    • &bРідини&r &6збираються&r"
		"    • Контроль &eшвидкості&r та &eорієнтації&r"
