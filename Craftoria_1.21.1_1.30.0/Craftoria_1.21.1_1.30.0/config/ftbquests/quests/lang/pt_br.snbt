	quest.4BF483174CC0A0F1.title: "Інструменти та зброя з Целестигеми"
	quest.4C23B5A6A57A13C0.quest_desc: ["&bСтіл безпеки&r — це центральна система безпеки для керування всіма вашими машинами."]
	quest.4C23B5A6A57A13C0.title: "Стіл безпеки"
	quest.4C357D8CF72B8F25.quest_subtitle: "З'являється в рідкісних структурах у Незері."
	quest.4C357D8CF72B8F25.title: "&4Рукавиця Незеру"
	quest.4CA2A53F4C298E2B.quest_desc: [
		"&bПортативна панель OIQ&r дозволить вам отримати доступ до вашої &dСистеми зберігання OIQ&r з будь-якого місця у світі."
