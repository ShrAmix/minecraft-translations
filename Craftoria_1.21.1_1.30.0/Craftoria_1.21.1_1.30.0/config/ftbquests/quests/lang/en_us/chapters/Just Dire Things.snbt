{
	quest.030E566682A89105.quest_desc: [
		"   &bfuel canister&r (паливна каністра) вміщує велику кількість палива."
		""
		"   Її можна помістити в будь-який слот, що зазвичай приймає паливо."
		""
		"   Найкраща частина... &oвона припиняє споживати свій внутрішній запас&r, коли немає нічого, що потрібно &6переплавити&r, &6закоптити&r, &6спалити&r або для чого &6генерувати енергію&r."
		""
		"  Це допомагає вашим запасам палива витрачатися повільніше."
		""
		"{image:justdirethings:item/fuel_canister_full width:100 height:100 align:center fit:true}"
	]
	quest.030E566682A89105.quest_subtitle: "Економіст палива"
	quest.03271CEB2EBD0979.quest_desc: [
		"  &6Передає&r &cенергію&r від підключеного &bджерела&r до будь-якого &bспоживача&r енергії в межах зміщеної зони дії (AOE)."
		""
		"{image:ftblibrary:icons/up width:32 height:32 align:center}"
		"{image:ftbquests:tasks/fe_full width:64 height:64 align:center}"
	]
	quest.03271CEB2EBD0979.quest_subtitle: "Зарядний пристрій AOE"
	quest.03F624101CDF5291.quest_desc: [
