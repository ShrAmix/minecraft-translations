	quest.3189264EB89A2A5A.quest_subtitle: "&oХитрощі ремесла"
	quest.3189264EB89A2A5A.title: "&aКорисні поради \\& хитрощі"
	quest.320C2F44DD138054.quest_desc: [
		"Цього боса не можна вбивати."
		""
		"Виконайте його &6завдання&r, давши йому &bВовну&r всіх кольорів."
