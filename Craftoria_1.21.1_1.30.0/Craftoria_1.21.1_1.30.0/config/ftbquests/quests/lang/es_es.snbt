	quest.2E97456B0ED0AB1A.title: "Електричний насос"
	quest.2F53567C34E86536.quest_desc: ["Найпростіша книга заклинань, може містити лише п'ять заклинань"]
	quest.2F66F85A601AC908.quest_desc: [
		"{image:modern_industrialization:block/machines/macerator/overlay_top_active width:32 height:32 align:center}"
		"  Тепер ви можете &6подрібнювати руди вчетверо&r з 50% шансом на додатковий пил. Також переробляти &bЦілісну руду&r на багато &bСирої руди&r."
		""
		"  Переробляйте металеві предмети на пил."
	]
	quest.2F66F85A601AC908.title: "Бронзовий подрібнювач"
	quest.2F6C16939D136BF0.quest_desc: ["&bПлощина анігіляції&f &6руйнує блоки&f та &6збирає&b предмети&f перед собою."]
	quest.2F6C16939D136BF0.title: "ME-площини"
	quest.2F7A213261682E1B.quest_desc: [
		"&bКазан зрідження&r &6занурює&r ресурси в &dрозчинник&r для виробництва &bСірки&r. Потребує &6тепла&r."
		""
		"Деякі ресурси, як-от руди, &aвиробляють більше сірки&r."
	]
	quest.2F9560A5281DCDFD.quest_desc: [
		"Потрібно захистити свої речі від &cтролів&r? &6Заявіть на них права!&r"
		""
		"Створіть &9Команду&r або заявте права на &aчанки&r самостійно."
		""
		"Відкрийте свій &bінвентар&r і знайдіть кнопку &6\"Керування правами\"&r."
		""
		"Кожен &aчанк&r має розмір &b16x16 блоків&r."
		""
		"У вас є ліміт, не перевищуйте його."
		""
		"Щоб створити &9Команду&r, використовуйте \"&a/ftbteams party invite&r\"."
	]
	quest.2F9560A5281DCDFD.quest_subtitle: "&oМоя земля НЕ твоя земля."
	quest.2F9560A5281DCDFD.title: "&3Клани &7та &2Заявки на територію"
	quest.2F993B0F106DB883.quest_desc: ["Використовується для виготовлення предметів за допомогою різних &bДрукарських форм&f."]
	quest.2F993B0F106DB883.title: "Друкарський верстат"
	quest.2FA7A5966FEF6701.quest_desc: ["&bНайкраща механічна труба&r має місткість &9128,000mb&r та потік &932,000mb/t&r на видобуток."]
	quest.2FA7A5966FEF6701.title: "Найкраща механічна труба"
	quest.2FB2FE782B1103D6.quest_desc: [
		"  Ваш другий мультиблок: &bПокращена парова піч&r! Схожа, але вища і з &bВогнетривкою цеглою&r."
		""
		"  Використовуйте &bКлюч&r, щоб побачити структуру, вам потрібні лише &6люки&r."
		""
		"  Тут ви виготовите свою першу &bСталь&r!"
	]
	quest.2FB2FE782B1103D6.title: "Покращена парова піч"
	quest.2FC0A2D07CC2DFC7.quest_desc: [
		"Примітка:"
		""
		"  EMI показує калькулятор будівництва для Термічних випарних установок."
