	quest.2E0837E85AD433EC.quest_subtitle: "Булочки з корицею кращі"
	quest.2E1EB12F3D9B315E.quest_desc: [
		"Деякі помітні &bритуали&r:"
		""
		"- &bТабличка створення острова: Пустеля&r"
