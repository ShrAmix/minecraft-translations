	quest.2E1EB12F3D9B315E.quest_subtitle: "Для колекціонерів"
	quest.2E1EB12F3D9B315E.title: "Червоні таблички"
	quest.2E50F969D8AE49B2.quest_desc: ["Кожна &bЕлітна індукційна комірка&r додає &e204.8 GFE&r до сховища енергії."]
	quest.2E50F969D8AE49B2.title: "Елітна індукційна комірка"
	quest.2E5D9CB5D821E96A.quest_desc: [
		"Найбільш &8міцний&r тип &bНапірної труби&r. "
		""
		"Можуть &2маскуватися&r та приймати &bМодулі&r для &eдодаткової функціональності&r."
	]
	quest.2E7A46639993CCDE.quest_desc: [
		"Кожен світ має секрети, &6приховані&r під поверхнею або в інших &6вимірах&r."
		""
		"Ніколи не ігноруйте те, що виглядає &6не на своєму місці&r."
		""
		"Будьте &6споряджені&r та &6у безпеці&r."
	]
	quest.2E7A46639993CCDE.quest_subtitle: "Навколо гори йде!"
	quest.2E7A46639993CCDE.title: "&bДослідження!"
	quest.2E883FCCA2FB281B.quest_desc: ["Налаштуйте два &bКвантові кільця&f за допомогою &bЗаплутаних сингулярностей&f, щоб підключити вашу &bME-систему&f до будь-якого місця."]
