	quest.2FC0A2D07CC2DFC7.title: "Термічна випарна установка"
	quest.3009C3939976FBD2.quest_desc: ["&bТермінал створення&f — це покращена версія, яка дозволяє крафтити, маючи доступ до всіх ваших предметів."]
	quest.3009C3939976FBD2.title: "Термінал створення"
	quest.300F6868FC217C55.quest_subtitle: "Завершіть свій світ!"
	quest.300F6868FC217C55.title: "&6Колекціонер"
	quest.302BE63E3488B94D.quest_desc: [
		"Просто ще один предмет для крафту. "
		"Перевірте &bEMI/JEI&r для рецепта."
	]
	quest.305C258D68DA8E96.quest_desc: ["&bІндукційний корпус&r вміщує комірки для зберігання &eвеличезної кількості&r енергії."]
	quest.305C258D68DA8E96.title: "Індукційний корпус"
	quest.308640ACCC096431.quest_desc: [
		"&bME-контролер&r — це ядро вашої системи. Потребує мало &6енергії&r."
		""
		"Забезпечує до 32 каналів з кожного боку (використовуйте &bЩільні кабелі&r)."
