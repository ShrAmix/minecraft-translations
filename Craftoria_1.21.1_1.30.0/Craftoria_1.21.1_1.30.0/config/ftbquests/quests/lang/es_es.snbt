	quest.4D7F6656A6A38EE0.quest_desc: ["Використовується для видобутку &4енергії&f з &5Мережі"]
	quest.4DAFFFDC31A78665.quest_desc: ["Виготовляється з &bЗалізного блоку &fу &bЗарядному пристрої&f для створення &bЕнергетичного процесора&f."]
	quest.4DBDCEA0761F1D3B.quest_desc: [
		"&bСувої телепортації&r служать для переміщення або створення &5постійних порталів&r."
		"&8+ Телепортація: використайте сувій у &6основній руці"
		"&8+ Телепортація моба: накладіть заклинання за допомогою &5Гліфа спалаху &8та сувою в &6другій руці"
		""
		"- &bСувій телепортації&r: переносить вас у збережене місце."
		"&8Використання: 1 раз"
		"&8Між вимірами: НІ"
		""
		"- &bСтабілізований сувій телепортації&r: створює &5тимчасовий портал&r, який скоро зникне."
		"&8Використання: необмежене"
		"&8Між вимірами: ТАК"
		""
		""
		"&8Порада 1: щоб &6зберегти&r місце, натисніть праву кнопку миші (тільки на &bпорожніх&8 сувоях)."
		"&8Порада 2: щоб &6скинути&r місце, перекрафтіть сувій без форми (можна використати сітку 2x2 у вашому інвентарі :P )"
		""
		""
		"&4ПРИМІТКА&r: для &5постійних&r порталів перегляньте &bнаступне завдання&r."
	]
	quest.4DBDCEA0761F1D3B.title: "Сувої телепортації"
