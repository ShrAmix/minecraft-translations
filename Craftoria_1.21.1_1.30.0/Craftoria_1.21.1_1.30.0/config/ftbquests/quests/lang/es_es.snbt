	quest.308640ACCC096431.title: "Центр зберігання"
	quest.30BD7370506EBC6C.title: "Кисень"
	quest.30D584EAD9243548.quest_desc: [
		"&bРідинний розподільник&r &6заповнює&r простір &7рідинами&r."
		""
		"Ви можете створювати цілі озера."
	]
	quest.30D584EAD9243548.title: "Рідинний розподільник"
	quest.30ED8D5374012D92.quest_desc: ["Пляшка блискавки отримується натисканням правою кнопкою миші на зарядженого кріпера з пляшкою."]
	quest.30FB66E92909D4B9.quest_subtitle: "Всі нітри"
	quest.30FB66E92909D4B9.title: "&bАлхімічний нітр"
	quest.31203D3E004E1DAB.title: "Хлор"
	quest.3143EA7DF096CE61.quest_desc: [
		"  Нова сталева машина!"
		""
		"  &bПакувальник&r виконує прості крафти, такі як подвійні злитки, труби та цегла."
	]
	quest.3143EA7DF096CE61.title: "Сталевий пакувальник"
	quest.314F299A677D92A6.quest_desc: [
		"Зберігає до &9100 однакових зілль&r."
		"&8(Також для &bДифузора\\&Змішувача зілль&r)"
		""
		"- Використовуйте з &5Віксі&r для автоматизації зілль."
		""
		""
		"&4ПРИМІТКА&r: &6присісти + права кнопка миші&r з &bЖезлом домінування&r для блокування."
	]
	quest.3189264EB89A2A5A.quest_desc: [
		"Я допоможу вам з деякими поширеними &6проблемами&r:"
