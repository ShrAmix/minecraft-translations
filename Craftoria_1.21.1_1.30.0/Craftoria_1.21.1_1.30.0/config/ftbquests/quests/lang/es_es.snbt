	quest.33AC5F9CFB679483.quest_desc: ["&bШолом MekaSuit&r захищає ваші очі та може надати &5Нічний зір&r."]
	quest.33AC5F9CFB679483.title: "Шолом MekaSuit"
	quest.33CD5343AFBF853C.quest_desc: [
		"Транспортує &5джерело&r з точки А в точку Б."
