	quest.0FDA602713778AF0.title: "Рівень 3, 1:3"
	quest.0FE33633653DE3D8.title: "milestones/unlock_pastel_node_coloring"
	quest.0FE6DFF73BE7AA10.quest_desc: ["&aЛаймова&r крейда потрібна для виклику духів, сильніших за Фоліота. Вона підтверджує ваше володіння основами окультизму."]
