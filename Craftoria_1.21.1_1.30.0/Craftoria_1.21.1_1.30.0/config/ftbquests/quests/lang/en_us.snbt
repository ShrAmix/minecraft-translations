	quest.79288A7251986136.quest_desc: [
		""
		"[ підказка: навіть для механізмів, які не призначені для пересування рейками, &bЗбирачі вагонеток&r корисні для розміщення механізмів у світі або перетворення їх назад у форму механізму — а потім підбирання їх у вигляді предмета за допомогою &bГайкового ключа&r. Привіт, кишеньковий вимір! ]"
	]
