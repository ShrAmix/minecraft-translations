	quest.670CE9B293296FEB.quest_desc: [
		"Жартую!"
		"""Для цього вам знадобиться створити &b256M Energy Storage Component&r."
		""
		"Може зберігати &aнескінченну&r кількість FE."
	]
	quest.6711E72048BBDB08.quest_desc: ["&6Вміщує&r до восьми різних речей, можна фарбувати, а до всіх найближчих &bящиків для інструментів (Toolboxes)&r можна &6отримати доступ&r за допомогою однієї клавіші — зручно, щоб не відволікатися від роботи."]
	quest.6716C1CE7B7FFA94.quest_desc: ["&bКарта місткості (Capacity Card)&f збільшує кількість слотів фільтра в &bшинах (Buses)&f."]
	quest.6716C1CE7B7FFA94.title: "Базові покращення"
	quest.671DF2CC261DDEC5.title: "unlocks/blocks/mob_heads"
	quest.67216A8FD1A22C99.title: "milestones/unlock_ink_use"
	quest.672633733F521B54.title: "unlocks/enchantments/inexorable"
	quest.67284079A941EF4B.quest_desc: [
		"&bАкваланг (Scuba Tank)&r вбирає &7кисень&r і дозволяє &6дихати під водою&r протягом тривалого часу."
		""
		"Використовуйте його, щоб досліджувати глибини &9океану&r або &6побудувати&r собі підводну базу."
	]
	quest.67284079A941EF4B.title: "Спорядження для дайвінгу"
	quest.673F362E1C0A4FF5.title: "hidden/status_effects/fatal_slumber"
	quest.6750F4584257BA75.quest_desc: ["&bРозширені шини (Extended Buses)&f мають &aзбільшену&r кількість слотів для покращень і працюють у 8 разів &aшвидше&f."]
	quest.6750F4584257BA75.title: "Розширені шини"
	quest.6762C357EEDE8D10.quest_desc: [
		"Вдосконалений компресор, який використовує &eсонячне світло&r для &7стиснення повітря&r."
		""
		"Його &aефективність&r зростає, коли стає &cгарячіше&r, але надмірне накопичення &4тепла&r призведе до &8вимкнення&r компресора, що потребуватиме &6ручного ремонту&r."
	]
	quest.67785FD77E880DDB.quest_subtitle: "З'являється в рідкісних печерах на самому дні світу. Лілії порожнечі вкажуть шлях."
	quest.67785FD77E880DDB.title: "&dКвітка порожнечі (Void Blossom)"
	quest.6778B32FDC46C2DC.title: "unlocks/blocks/lava_sponge"
	quest.67792A4DE6EDBC37.quest_desc: ["Елдрітський манускрипт створюється з восьми фрагментів знань та одного уламка відлуння. Обидва можна знайти під час пограбування стародавніх міст. Після використання він дасть вам силу одного Елдрітського сувою на ваш вибір. Ви можете розблокувати більше, але для кожного сувою потрібен новий манускрипт."]
	quest.678A65A6A3461CFC.quest_subtitle: "Завершіть розділ квестів."
	quest.678A65A6A3461CFC.title: "&6Риболовля"
	quest.678B4F34673DD733.title: "unlocks/reagents/bone_ash"
	quest.6793FC359952E287.title: "unlocks/gemstone_lights/onyx"
	quest.6794A40DE2A79575.quest_desc: [
		"У цьому моді є &2селянин&r."
		"&8(В AE2 теж є, якщо ви не знали)"
		""
		"- Блок: &bМагічне ядро (Arcane Core)&r."
		""
		"Випадкова &bТабличка&r на рівні &6Підмайстер&r."
		"Випадковий &bЖетон&r на рівні &6Експерт&r."
		"Випадкова &bМузична платівка мода&r на рівні &6Майстер&r."
		""
		""
		"&8Перегляньте &bСторінку 2 &8для інформації про торгівлю."
		""
		"{@pagebreak}"
		"- Сайт: &bars.guide&r має мати інформацію."
		"- Вихідний код: EventHandler.java "
		"&8public static void registerTrades(VillagerTradesEvent event)"
	]
	quest.6794A40DE2A79575.quest_subtitle: "Підозрілий чарівник"
	quest.6794A40DE2A79575.title: "Селянин"
	quest.67A41E4D6BCA5F2B.quest_desc: ["Це серце системи квантової оркестрації предметів (QIO). Тут ви будете зберігати свої QIO-диски. Бережіть його як зіницю ока."]
	quest.67A41E4D6BCA5F2B.title: "Масив QIO-дисків"
	quest.67A88AB41C766EF7.title: "milestones/unlock_overenchanting_with_enchanter"
	quest.67ACD099BDB606FA.quest_desc: [
		"З цими &bОкулярами&r на очах ви будете бачити так, ніби у вас є &bТретє око&r."
		""
		"Однак ви все одно не зможете збирати блоки без спеціалізованого інструменту..."
	]
	quest.67ACD099BDB606FA.quest_subtitle: "Потойбічне"
	quest.67B17617F57B247F.quest_desc: [
		"&bЛіфт&r використовує &7тиск&r для переміщення вас вгору та вниз між поверхами за допомогою &bКонтролера&r. Розмістивши один &bЛіфт&r, ви можете піднятися на &eзагалом&r шість блоків. Якщо ви ставите &bОснови ліфта&r одна на одну вище &cмаксимальної висоти&r, це &aзбільшуватиме&r її на шість блоків за кожну встановлену основу."
		""
		"Ви також можете &aзбільшити&r ширину та глибину &bЛіфта&r, додавши таку ж кількість &bОснов ліфта&r, як і при початковому розміщенні."
		""
		"&bКонтролер&r розміщується на &eрівні очей&r, на один блок від землі, ліворуч або праворуч, але впритул до &bЛіфта&r, торкаючись &bШахти ліфта&r. Його потрібно ставити на кожному блоці, щоб &bЛіфт&r міг рухатися вгору, оскільки він їде по &bрейках&r."
		""
		"Якщо ви хочете, щоб &bЛіфт&r піднімався на &330 блоків&r з &aтрьома поверхами&r, вам знадобиться:"
		""
		"&96&r &bОснов ліфта&r x ширина та глибина."
		""
		"&930 &bШахт ліфта&r x ширина та глибина."
		""
		"&91&r &bКонтролер&r для кожного поверху, тобто три."
		""
		"&7Тиск&r, необхідний для &bЛіфта&r, досягає максимуму на &c5.0&r і не збільшується залежно від кількості &bОснов ліфта&r."
	]
	quest.67B17617F57B247F.title: "Ліфт"
	quest.67D26D75BF3DCF22.title: "unlocks/reagents/aether_vestiges"
	quest.67D5ED5703F35A2D.quest_desc: [
		"&bСонячний нейтронний активатор&r спрямовує &cнейтронне випромінювання&r від &6сонця&r у внутрішній резервуар для створення певних &9ізотопів&r."
		""
		"Ви можете використовувати цю машину, щоб &6переробляти&r &2ядерні відходи&r на &3корисні радіоактивні ізотопи&r."
	]
	quest.67D5ED5703F35A2D.title: "Сонячний нейтронний активатор"
	quest.67E949C75CEFA446.quest_desc: [
		"Трохи кращий видобуток, ніж той, що ліворуч."
		"&8використовуйте це, коли у вас немає &5гліфів 3-го рівня&r."
		""
		"- Потрібне &6зачарування Пробивання (Piercing)&r для пробивання &5снарядів&r."
		"&8(не знаю, чому розробник ігнорує кожен &5гліф Пробивання&r &8перед &5гліфом Ефекту&r&8)."
		""
		"- Інструмент: &bАрбалет зачаровувача&r."
		"- Стріла: &bСтріла посилення: Розщеплення&r."
		"- Зачарування Пробивання: якомога вище. (кожен рівень додає <рівень> + 1 раз)"
		"- Радіус: 3x3x4 для звичайної стріли без зачарувань."
		"&8Близько до 9x3x4x(?+1) з &6рівнем Пробивання ?&r &8\\& &bСтрілою розщеплення&r"
		""
		"- Видалення предметів: &bГлечик порожнечі&r (повертає джерело) або &bПокращення порожнечі&r для рюкзака."
		""
		"- Заклинання: не потрібен &5гліф Форми&r, оскільки &bАрбалет&r додасть його автоматично."
		"&8Злам -> AoE -> AoE -> Пробивання -> Пробивання -> Пробивання -> Видобуток -> Підбір -> AoE -> AoE"
	]
	quest.67E949C75CEFA446.quest_subtitle: "Приклад заклинання"
	quest.67E949C75CEFA446.title: "Арбалет зачаровувача (T2)"
	quest.67F060243167F8BF.quest_desc: [
		"&bЗлиток небесної сталі&f можна використовувати для створення комірок &bMEGA Item Storage&f. Він створюється шляхом &6скидання&r &bЗарядженого кварцу Сертус, заліза та небесного каменю&f у воду."
		""
		"&bЗлиток небесного осмію&f можна використовувати для створення комірок &bMEGA Chemical Storage&f. Він створюється шляхом &6скидання&r &bЗарядженого кварцу Сертус, осмію та небесного каменю&f у воду."
		""
		"&bЗлиток небесної бронзи&f можна використовувати для створення комірок &bMEGA Fluid Storage&f. Він створюється шляхом &6скидання&r &bЗарядженого кварцу Сертус, міді та небесного каменю&f у воду."
	]
	quest.67F2212453B81446.quest_desc: [
		"  Змішаний злиток, що містить злиток &bІридію&r, затиснутий між двома злитками &bВибухостійкого сплаву&r, готовий до створення надзвичайно міцної &bІридієвої пластини&r."
		""
		"  До речі про сендвічі, він виглядає досить &bапетитно&r, чи не так?"
	]
	quest.67F2212453B81446.title: "Змішаний іридієвий злиток"
	quest.67F9EF1D0C743BD9.title: "unlocks/weather/clear"
	quest.6817F9FF3248F3CD.title: "hidden/status_effects/projectile_rebound"
	quest.681A718388A97FFC.quest_desc: [
		"&bПокращення глушника&r практично заглушає машину, на яку воно встановлене."
		""
		"Добре використовувати, коли ви хочете тиші."
	]
	quest.681A718388A97FFC.title: "Покращення глушника"
	quest.682D1178AF51998C.quest_desc: ["Створіть будь-яку руну, яка найкраще підходить до магічної броні або сфери покращення, яку ви хочете."]
	quest.68493CE96FD68EBA.title: "Кріомант"
	quest.6849F9CC71D2D96D.title: "unlocks/blocks/compacting_chest"
	quest.6866DE035D9767A0.title: "hidden/build_any_complex_structure"
	quest.68721F148E2805FB.quest_desc: [
		"Ваша перша &bКнига заклинань&r дозволить вам почати &6збирати&r та використовувати &bзаклинання&r."
		""
		"Ця книга заклинань може використовувати лише &5гліфи 1-го рівня&r."
		""
		""
		"&4ПРИМІТКА&r: також можна використовувати Книгу заклинань для доступу до &bкниги-посібника&r мода."
		"&4ПРИМІТКА 2&r: перегляньте &bрозділ Збройової&r для броні, інструментів та дрібничок."
	]
	quest.68721F148E2805FB.title: "Книга заклинань новачка (T1)"
	quest.687325679D9EDA10.title: "milestones/unlock_pastel_node_upgrading"
	quest.68734DDE2C2763D3.title: "unlocks/trinkets/heartsingers_reward"
	quest.687A9332533A26E8.quest_desc: ["Олень &6покращує&r вашу здатність &bстрибати&r."]
	quest.687A9332533A26E8.quest_subtitle: "Високо в небі"
	quest.688DAD3A7390A738.title: "unlocks/items/enchantment_canvas"
	quest.688DEE1D1C4F9BDA.quest_desc: [
		"Цей &9модуль&r випромінює &4сигнал редстоуну&r, сила якого пропорційна &7тиску&r всередині &bтруб&r."
		""
		"Коли &6обладнано&r &bКартою розширення модуля&r, ви можете точно &6налаштувати&r поріг через &3графічний інтерфейс&r."
	]
	quest.6892D502FD8AB61B.title: "triggers/hints/azurite_page1"
	quest.68A8995F4A13381A.quest_desc: [
		"  Приймає покращення найвищого рівня:"
		""
		"• &bШолом&r:"
		"    &cЗняття дебафів&r,"
		"    &cМентальна дезінтеграція&r"
		"• &bНагрудник&r:"
		"    &cПоліт&r, (так, політ у &oстилі творчого режиму&r!)"
		"    &cЗахист від смерті&r,"
		"    &cІмунітет до лави&r"
