	quest.7E3BD249213C7036.title: "unlocks/trinkets/azure_dike_belt"
	quest.7E49DB806DD04701.quest_desc: [""]
	quest.7EAA0A13EF60E267.title: "hidden/visit_dd_biomes/deep_barrens"
	quest.7EBDCA060A3CC055.title: "unlocks/blocks/shimmerstone_lights"
	quest.7ED9955750255A69.quest_subtitle: "Завершіть розділ квестів."
	quest.7ED9955750255A69.title: "&dArs Nouveau"
	quest.7EDF633DDB5DA2A1.quest_desc: ["Заморожені кістки випадають зі Здихлих (Strays) і використовуються для створення Крижаних сувоїв"]
	quest.7EF829BFBBB4009B.quest_desc: [
		"Розмістивши енергетичні стрижні навколо Енергетичної сфери, а потім подавши на них живлення, ви можете заряджати різні матеріали всередині сфери. Це може бути як один предмет, так і комбінація предметів."
		""
		"Якщо ви хочете робити це швидше, ви можете заряджати їх масово! &bЗарядку&r можна прискорити, якщо у вас достатньо &bенергії&r. Якщо у вас є &bблоки&r, а не &bзлитки&r, ви можете зробити &bзаряджений блок у 9 разів швидше&r."
	]
	quest.7F10CB765C7796E1.title: "unlocks/blocks/blood_orchid"
	quest.7F24E9392D118D31.title: "unlocks/colored_lamps/pink_lamp"
	quest.7F3A28754CD6AD41.quest_desc: [
		"  &6Перетворює&b:"
		""
		"• Блоки &bНезериту&r на &b&nсиру руду сплаву затемнення&r"
		""
		"• Блоки &bАлмазів&r на &b&oсиру руду целестігему&r"
		""
		"• Блоки &bЗолота&r на &b&oсиру руду палаючого золота&r"
		""
		"• Блоки &bЗаліза&r на &b&oсиру руду ферікору&r"
		""
		"Працює швидше, ніж &bслиз мерехтіння порожнечі&r."
		""
		"{image:justdirethings:block/gooblock_tier4 width:100 height:100 align:center fit:true}"
	]
	quest.7F3F046CC34EC9CB.title: "unlocks/reagents/raw_bloodstone"
	quest.7F4BD83F2D567FF0.quest_desc: [
		"Поїзд наближається!"
		""
		"Поїзд наближається!"
		""
		"Ви любите поїзди?"
		""
		"О так, ви обрали правильний мод."
		""
		"Вам знадобляться міцні листи, щоб потрапити до галереї &c\"Поїздів\"&r."
		""
		"Поїзди з &oCreate&r — це просто вибух, на мою думку."
		""
		"Насолоджуйтесь!"
	]
	quest.7F4BD83F2D567FF0.quest_subtitle: "Чух-чух, містере Фарнсворт!"
	quest.7F4BFF2C6E887FCC.quest_desc: [
		"   Блоки &bслизу примогелю&r також &6перетворять&r &bблоки вугілля&r на &bсире первісне вугілля&r "
		""
		"   3-4 &bПервісних вугілля&r &6випадуть&r з цього &bсирого первісного вугілля&r."
		""
		"   Має достатньо енергії, щоб &6спалити&r у 3 рази більше предметів, ніж звичайне &bвугілля&r."
		""
		"{image:justdirethings:block/coalblock_t1 width:100 height:100 align:center fit:true}"
	]
	quest.7F4BFF2C6E887FCC.quest_subtitle: "Краще вугілля"
	quest.7F4DE16B3EA6232F.title: "unlocks/upgrades/upgrade_speed2"
	quest.7F57BFB41865173A.title: "unlocks/glowblocks/any_glowblock"
	quest.7F5C7E623935E63B.title: "hidden/status_effects/divinity"
	quest.7F7AB9192CD7FC70.quest_desc: ["&bЕлітна лісопильна фабрика&r може обробляти до &a7&r процесів розпилювання одночасно, маючи ту саму функцію \"&eАвто-сортування&r\"."]
	quest.7F7AB9192CD7FC70.title: "Елітна лісопильна фабрика"
	quest.7F7BA1F878A2219B.title: "unlocks/blocks/block_flooder"
	quest.7FA5112E27A0D70C.quest_desc: ["Ця кирка може бути кориснішою для створення &bдухів шахтарів&r, ніж для вас, але вона набагато краща за свого крихкого попередника."]
	quest.7FA5112E27A0D70C.quest_subtitle: "Духовна кирка"
	quest.7FBC6EFE948A0CD2.quest_desc: ["Дракон &6підсилює&r ваше &bотримання досвіду&r."]
	quest.7FBC6EFE948A0CD2.quest_subtitle: "Цей накопичує знання, а не золото"
	quest.7FC6AE9DB7C1DA52.quest_desc: [
		"&bБіогенератор&r використовує &2біопаливо&r для генерації &eенергії&r. "
		""
		"Ви можете зробити &2біопаливо&r, &6подрібнивши&r майже будь-який &bорганічний матеріал&r."
	]
	quest.7FC6AE9DB7C1DA52.title: "Біогенератор"
	quest.7FCA9352AF05C235.quest_desc: [
		"Ці труби &6автоматизують&r деякі процеси:"
		""
		"Передача &6Енергії&r: "
		"- Вони працюють як будь-яка інша &bЕнергетична труба&r."
		""
		"Передача &dМатерії&r: "
		"- Від &bДезінтегратора&r до &bРезервуарів матерії&r "
		""
		"- Від &d&lРезервуарів матерії&r до інших &bмашин&r, які її потребують."
	]
	quest.7FCA9352AF05C235.quest_subtitle: "Труби матерії дозволять вам підключати машини &aРеплікації&r."
	quest.7FD0A63CDC267251.quest_desc: ["Кількість сутностей, що з'являються одночасно."]
	quest.7FD0A63CDC267251.quest_subtitle: "+1 до кількості спавну"
	quest.7FD2368444636E93.quest_desc: [
		"Коваль може &6покращувати&r інших &bокультних фамільярів&r."
		""
		"Він також може &6ремонтувати&r ваше &bспорядження&r, поки ви видобуваєте камінь."
	]
	quest.7FD2368444636E93.quest_subtitle: "Покращення"
	quest.7FD5FCEFE3697A7C.quest_desc: [
		"Всього за &oмізерні&r &e8EU/t&r, &bПаровий фермер&r може виконувати наступне:"
		"- &6Орання&r: Коли активовано, блоки землі перетворюються на сільськогосподарські угіддя. Не працюватиме без води."
		"- &6Зволоження&r: При подачі води зорана земля буде зволожуватися."
		"- &6Збір врожаю&r: Коли є достатньо місця для виходу, він збирає повністю дозрілі культури та дерева."
		"- &6Посадка&r: При подачі насіння або саджанців, він висаджує їх на відповідний ґрунт. Використання різних режимів посадки дозволяє висаджувати їх у різних схемах."
	]
	quest.7FD5FCEFE3697A7C.quest_subtitle: "Що сказала дитина-&eкукурудза&r мамі-&eкукурудзі&r?"
	quest.7FEBDFAE021B3C56.quest_desc: ["Корисно для &oдуже&r великих крафтів."]
