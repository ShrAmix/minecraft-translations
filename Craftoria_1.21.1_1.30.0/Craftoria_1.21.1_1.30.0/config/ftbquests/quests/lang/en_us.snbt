	quest.36D6EB562AA17DA0.title: "unlocks/redstone/redstone_calculator"
	quest.36F22AA68C1841F6.quest_desc: [""]
	quest.36F22AA68C1841F6.quest_subtitle: "Ви круті, броньовані та захищені від лави!"
	quest.36F58A00DD9498EC.title: "unlocks/reagents/fermented_spider_eye"
	quest.37001338052E8335.quest_desc: ["&bФабрика остаточного дроблення&r може обробляти до &a9&r процесів дроблення одночасно, містячи ту саму функцію \"&eАвто-сортування&r\"."]
	quest.37001338052E8335.title: "Фабрика остаточного дроблення"
	quest.3723D86B327384DB.quest_desc: [
		"Два слова: &oлавовий поїзд&r."
