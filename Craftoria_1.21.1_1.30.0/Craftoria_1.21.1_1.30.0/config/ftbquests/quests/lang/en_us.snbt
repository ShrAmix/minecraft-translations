	quest.0F3307EDD8196CF0.title: "unlocks/blocks/dragonrot_bucket"
	quest.0F3C82E58178EEC3.title: "hidden/status_effects/life_drain"
	quest.0F401FE59ECEDA02.title: "mod_integration/the_bumblezone/red_raging"
	quest.0F45A838DF9DD2AA.title: "unlocks/enchantments/vanilla_curses"
	quest.0F495341BFA6EB28.title: "unlocks/enchantments/sniping"
	quest.0F5DAF9E14EB08E3.title: "unlocks/reagents/midnight_chip"
	quest.0F6DCB6955AC4B54.title: "unlocks/enchantments/voiding_usage"
	quest.0F7AEC02C0AC86A2.quest_desc: [
		"Коли їхній &7тиск&r стає &eнижчим&r за певну позначку, вони шукатимуть &bзарядну станцію&r, оснащену &bпокращенням дозатора&r у межах визначеної зони. Якщо таку буде знайдено, вони автоматично &6перезарядяться&r перед поверненням до свого завдання."
		"""Хоча всі &bДрони&r можна &6покращити&r за допомогою апгрейдів на швидкість, місткість, броню, режим очікування, безпеку та термін служби предметів, додаткові &bапгрейди&r можна &6встановити&r залежно від типу дрона:"
		""
		"&aВсі:&r            "
		"- Швидкість x 10, Місткість x 25, Броня x 15, Режим очікування x 1, Безпека x 3, Термін служби предметів x 10"
		""
		"&eЗбирач:&r    "
		"- Магніт x 6, Радіус x 16, Інвентар x 35"
		""
		"&2Збирач врожаю:&r   "
		"- <н/д>"
		""
		"&cОхоронець:&r      "
		"- Мініган x 1, Радіус x 16, Глушник x 4"
		""
		"&9Логіст:&r    "
		"- Інвентар x 35"
	]
	quest.0F9C5537FE9B18AE.title: "triggers/hints/failing_page1"
	quest.0FA3C7049E71EA4A.quest_desc: ["Плануєш найближчим часом обзавестися &bКар'єром&f?"]
	quest.0FA3C7049E71EA4A.title: "Компонент зберігання 64k"
