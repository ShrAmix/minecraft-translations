	quest.5667D6AA8C518110.title: "unlocks/blocks/ethereal_platform"
	quest.566D039774A4DB9D.quest_desc: ["Створюйте &bПлутонієві пелети&r, переробляючи &2ядерні відходи&r і поєднуючи їх із &9флюоритовим пилом&r."]
