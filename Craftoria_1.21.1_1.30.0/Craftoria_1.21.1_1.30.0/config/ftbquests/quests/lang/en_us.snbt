	quest.1FD1C62AFB6E02F1.title: "hidden/status_effects/effect_prolonging"
	quest.1FD59C1147BCE34F.quest_desc: ["Спавнер ігнорує умови спавну."]
	quest.1FD59C1147BCE34F.quest_subtitle: "+ Ігнорує умови"quest.1FDE63D5EA5DA3CB.quest_desc: ["Якщо інтернет-протокол має порти, то &bPackage Frogports&r має бути частиною CCP: Chain Conveyor Protocol."]
	quest.1FDE63D5EA5DA3CB.quest_subtitle: "Це не те місце, де жаби приземляються і злітають."
	quest.1FF9C1E9ECCBB353.title: "unlocks/reagents/prickly_bayleaf"
	quest.1FF9FB01DBE735FC.quest_desc: [
		"Природу &bСірки&r можна &6змінити&r. Це основа трансмутації."
		""
		"Цей &bЧан&r, якщо додати правильні інгредієнти, здатний &6перетворити&r сірку на набагато більш податливий стан — &bАлхімічну селітру&r."
	]
	quest.1FF9FB01DBE735FC.quest_subtitle: "Еквівалентний обмін?"
	quest.202149DADCC786EE.quest_desc: [
		"  Вітаємо!"
		""
