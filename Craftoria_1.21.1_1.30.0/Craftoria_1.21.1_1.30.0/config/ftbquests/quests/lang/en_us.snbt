	quest.32B4C48622EEE090.title: "unlocks/trinkets/radiance_pin"
	quest.32DC17E21BF26228.quest_desc: ["Використовуйте це, щоб &6завантажити&r збережені &bКреслення&r у нове &bКреслення&r, готове до використання у &bКресленнєвій гарматі.&r"]
