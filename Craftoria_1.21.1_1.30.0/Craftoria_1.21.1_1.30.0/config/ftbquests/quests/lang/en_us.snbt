	quest.57A8D67858693F4A.quest_desc: ["&bБазова фабрика ін'єкцій&r дозволяє обробляти &a3&r рецепти ін'єкцій одночасно."]
	quest.57A8D67858693F4A.title: "Базова фабрика ін'єкцій"
	quest.57BD29386888988A.title: "unlocks/reagents/shimmerstone_gem"
	quest.57D104FF04B35463.title: "Водяна пара"
	quest.57D9E9C4AEA9DF63.quest_desc: [
		"- &bСтіл писаря&r використовується для створення &5Гліфів&r, які можна помістити у вашу &bКнигу заклинань&r."
		"- Це також місце, куди ви кладете свої &bІнструменти зачарування&r (меч/лук/сокиру тощо), щоб накласти на них заклинання."
		""
		""
		"&8Підказка 1: перегляньте квест &bГліфи 1 рівня&8, там вказано, де знайти більшість із них без крафту :)"
		"{ \"text\": \"НАТИСНИ МЕНЕ\", \"underlined\": true, \"clickEvent\": { \"action\": \"change_page\", \"value\": \"511C07DFE796F377\" } }"
		""
		"&8Підказка 2: він може &6забирати &8предмети зі &bсховищ &8поруч (вимкніть за допомогою &bЖезла домінування&r&8)"
		"&6shift + права кнопка миші"
	]
	quest.581A65CFEEA0C2E4.title: "unlocks/glowblocks/light_blue_glowblock"
	quest.5820987E7948B631.title: "hidden/collect_jadeite"
