	quest.66AE27B8C8DADDA5.title: "Змішувач пігментів"
	quest.66E3EDC6B58A1E87.title: "hidden/collect_pigment/green"
	quest.66F756E370750359.quest_desc: [
		"Гарні штани!"
		""
		"&bШтани MekaSuit&r захистять ваші ноги від майже будь-якої &4атаки&r, як тільки ви повністю їх &6покращите&r."
	]
	quest.66F756E370750359.title: "Штани MekaSuit"
