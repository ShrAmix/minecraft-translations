	quest.5E8396CEEB2F2395.title: "hidden/status_effects/calming"
	quest.5E8FBBB9378BD7E0.title: "unlocks/ampoules/raw_malachite_ampoule"
	quest.5E9F30ADD242C764.quest_desc: [
		"&4Купуйте 2 за тією ж ціною, якщо зателефонуєте прямо зараз!!!"
		"&bНітро-кристали&f — це матеріали, необхідні для найвищого рівня техніки, а саме &bНітро&f. Вони виготовляються з &bЗірок Нетеру, Редстоуну&f та дрібки &bкристалів іфриту&f."
	]
	quest.5E9F30ADD242C764.quest_subtitle: "Тепер лише за $19.99!"
	quest.5E9F30ADD242C764.title: "&4Нітро-кристал"
	quest.5EC2714894E2CB13.quest_desc: [
		"Додайте підтримку рецептів модів для &5Crush, Cut, Flatten Glyphs&r."
		""
		"- &bCrush&r: "
		"&8+ Actually Additions: Crusher"
		"&8+ Integrated Dynamics: Squeer"
		"&8+ Mekanism: Crusher, Sawmill"
		"&8+ Modern Industrialization: Macerator"
		"&8+ Occultism: crushing spirits (найнижчий рівень)"
		""
		"- &bCut&r:"
		"&8+ Farmers Delight: Cutting Board"
		"&8+ Cutting Machine з Modern Industrialization вимкнено"
		""
		"- &bFlatten&r:"
		"&8+ Modern Industrialization: Compressor"
		""
		""
		"&4ПРИМІТКА&r: список модів вище з версії збірки 1.12.0."
		"&4ПРИМІТКА 2&r: для автоматизації використовуйте &bРуни&r та/або &bТурелі&r."
	]"&4ПРИМІТКА 3&r: у разі однакових рецептів у різних модах, вищий пріоритет замінить нижчий."
		"&8(перевірте конфігурацію для значення пріоритету)"
	]
	quest.5EC2714894E2CB13.quest_subtitle: "Дробити, різати, сплющувати"
	quest.5EC2714894E2CB13.title: "Аддон Ars Unification"
	quest.5ECC7F4F5D2591D9.quest_desc: ["&bПросунута карта&f — це крафтовий компонент, що використовується для створення &bПокращень&f."]
	quest.5ECC7F4F5D2591D9.title: "Просунуті покращення"
	quest.5ED90DDC4B3189F6.title: "triggers/hints/stratine_page1"
	quest.5EE080DD8BCBD8C9.title: "unlocks/gemstone_chimes/onyx_chime"
	quest.5EEF6110DDBEB146.quest_desc: [
		"Попередньо запрограмований &bДрон&r, який захищає зону &e31x31x31&r, центровану відносно позиції, з якої він був розгорнутий."
		""
		"Цей &bДрон&r має два базові &3режими&r залежно від того, як він розгорнутий:"
		""
		"- Розгортання на землі накаже &bДрону&r &cатакувати&r будь-яких &2мобів&r, що входять у його зону, використовуючи все, що вже є на борту."
		""
		"- Розгортання поверх &9інвентарю&r, що містить &cЗброю&r або &7Набої для мінігана&r (якщо дрон має покращення мінігана), накаже &bДрону&r озброїтися, використовуючи &bпредмети&r всередині &9інвентарю&r перед тим, як &eзахищати&r свою зону."
	]
	quest.5F223917E991B6BA.title: "unlocks/food/nectardew_titration"
	quest.5F24478B2BD1C3FE.title: "hidden/unlock_explard_hint"
	quest.5F2801445E518E49.quest_desc: ["Флакони з кров'ю можна отримати, стоячи в Алхімічному казані або в звичайному казані з вогнем під ним. Коли він наповниться кров'ю, ви можете натиснути правою кнопкою миші з порожньою пляшкою, щоб зібрати кров."]
	quest.5F2D0753FBBC2E32.title: "unlocks/items/enchantment_canvas"
	quest.5F2E816EE9311DB5.title: "unlocks/items/bottle_of_failing"
	quest.5F3A1C06DEA743F7.title: "unlocks/enchantments/treasure_hunter"
	quest.5F46E1D3938F5F2A.quest_desc: [
		"- &bІнструменти зачарування&r: застосовують заклинання на &bСтолі писаря&r."
		""
		"- &5Комплект броні&r: потребує &6Реактивного зачарування&r для активації заклинання."
		"&8застосуйте заклинання, використовуючи Пергамент заклинань у &bАпараті зачарування&r&8."
	]
