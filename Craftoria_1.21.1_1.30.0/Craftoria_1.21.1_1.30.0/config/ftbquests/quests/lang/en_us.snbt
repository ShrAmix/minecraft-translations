	quest.2D12653352AAD2E2.title: "unlocks/equipment/dragonrending_pickaxe"
	quest.2D15A536403974E2.title: "hidden/interact_with_dragonrot"
	quest.2D2A4E52CF79C196.title: "unlocks/equipment/knotted_sword"
	quest.2D4170B5AD28DCBF.quest_desc: [
		"  Найкращий одноблоковий &bDiesel Generator&r (Дизельний генератор), який ви можете створити. &6Він видаватиме до 1024 eu/t&r з будь-якої з різних рідин, перелічених у вашому EMI."
		"""  Тепер, це не найкращий генератор, який працює на рідкому паливі. Існує така річ, як &bВеликий дизельний генератор&r, який потребуватиме &bВисокотехнологічні корпуси машин&r; хоча це того варте, коли почуєш, що &6він генерує до 16 384 eu/t&r!"
	]
	quest.2D4170B5AD28DCBF.title: "Дизельний генератор високої напруги (HV)"
	quest.2D4564F6C18AE96B.quest_desc: ["&bВдосконалений логістичний транспортер&r може забирати &a32 предмети на секунду&r у транспортну мережу та передавати їх зі швидкістю &a2,0 метри на секунду&r."]
	quest.2D4564F6C18AE96B.title: "Вдосконалений логістичний транспортер"
