	quest.49C508DCB4AAC3CB.quest_desc: ["&bУльтимативна лісопильна фабрика&r може обробляти до &a9&r процесів розпилювання одночасно, містить ту саму функцію \"&eАвто-сортування&r\"."]
	quest.49C508DCB4AAC3CB.title: "Ультимативна лісопильна фабрика"
	quest.49C5862DCDDE0F53.title: "unlocks/trinkets/fanciful_pendant"
	quest.49D4F55F8A20DB22.quest_desc: ["Буває в кількох кольорах, щоб підійти до будь-якого декору."]
	quest.49D4F55F8A20DB22.quest_subtitle: "Розслабся. Присядь."
	quest.49E73DF03C8D28C7.quest_desc: ["&4Червона&r крейда приваблює та зв'язує Афритів, дозволяючи їм виконувати ваші накази."]
	quest.49E73DF03C8D28C7.quest_subtitle: "Контроль Афритів"
