	quest.26A44EDA4AABFF6F.quest_desc: [
		"&bСтиснута сталь&f створюється шляхом &6кидання&f &bЗалізного злитка&f на землю та &6підриву&f його за допомогою &bТНТ&f, але ви не завжди отримаєте повернення ресурсів."
