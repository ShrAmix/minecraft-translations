	quest.497660DB9611C67C.quest_desc: ["Як звичайний &bЖолоб,&r але з &6фільтрацією&r та &6контролем швидкості&r."]
	quest.497DD2B3AC5E7841.title: "unlocks/blocks/ominous_sapling"
	quest.4980C231ECDB0BF2.quest_desc: ["  &bСталевий бур&r дає вам решту &6більш часто використовуваних руд&r, які знадобляться для подальшого прогресу у вашій подорожі до повної автоматизації, а також у вашій подорожі світом. Перевірте свій EMI для всіх можливих результатів."]
	quest.4980C231ECDB0BF2.title: "Сталевий бур"
	quest.49910F2EFEA1CDF2.quest_desc: [
		"  &bПростий&r:"
		"    • &bРідини&r &6збираються&r"
		"    • Елементи керування &eшвидкістю&r та &eорієнтацією&r"
		"    • Опціональна чутливість до &4редстоуну&r"
		""
		"  &bПросунутий&r:"
		"    • Додає &6фільтрацію&r та &3зміщення зони дії (AOE)&r"
		"    • Потребує &cенергії&r"
		""
		"{image:justdirethings:block/fluidcollectort2_side width:100 height:100 align:center}"
	]
