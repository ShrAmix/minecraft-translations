	quest.2A4F8CE1B4627285.title: "unlocks/items/bottle_of_fading_essence"
	quest.2A5CD188C06D7F3C.quest_desc: [
		"- &bEnchanting Apparatus&r (Апарат для зачарування)"
		"&6Клацніть правою кнопкою миші&r по апарату для зачарування &6порожньою рукою&r."
		"Він підсвітить усі &bп'єдестали&r у радіусі дії."
		""
		"- &bImbuement Chamber&r (Камера накладання)"
		"&6Клацніть правою кнопкою миші&r по камері накладання з &bпредметом&r, щоб підсвітити п'єдестали."
		"&8(не використовуйте аметист/лазурит)"
		""
		"- &bWixie Cauldron&r (Котел Віксі), &bWixie's Enchanting Apparatus&r"
		"&8(не підсвічуватиметься, але &9радіус &8такий &2самий&8, як у &bImbuement Chamber&8)"
	]
	quest.2A5CD188C06D7F3C.quest_subtitle: "Як дізнатися, чи ви в радіусі дії"
	quest.2A5CD188C06D7F3C.title: "Як дізнатися, чи ви в радіусі дії?"
