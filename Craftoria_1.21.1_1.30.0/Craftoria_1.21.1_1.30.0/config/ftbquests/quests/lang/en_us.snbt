	quest.059D14148B6D2071.title: "hidden/collect_every_pure_cmy_resource"
	quest.059D284AFBC6B0CD.title: "hidden/status_effects/somnolence"
	quest.05A0AC380BB141A0.quest_desc: ["&bОбмежувальний транспортер&r — це тип &bЛогістичного транспортера&r, який практично працює як труба для \"&6переповнення&r\". Коли &3предмети&r більше нікуди не можуть потрапити, вони &6рухатимуться&r через &bОбмежувальний транспортер&r."]
	quest.05A0AC380BB141A0.title: "Обмежувальний транспортер"
	quest.05B2AA73EAEDCCF4.quest_desc: [
		"Ці &bЕкспортні шини&r мають більш розширену функціональність порівняно зі звичайною &bЕкспортною шиною&r."
		""
		"&bЕкспортна шина за тегами&r експортує предмети з відфільтрованих тегів."
		""
		"&bЕкспортна шина за модами&r експортує предмети з відфільтрованих модів."
		""
		"&bТочна експортна шина&r експортує рівно ту кількість предметів, яку ви встановили, ні більше, ні менше."
		""
		"&bЕкспортна шина за порогом&r експортує предмети, коли їх кількість вище/нижче встановленого порогу."
	]
	quest.05B2AA73EAEDCCF4.title: "Розширені експортні шини"
