	quest.3500610FAB47D261.title: "unlocks/trinkets/artists_palette"
	quest.3504BCE26041D225.quest_desc: [
		"&bКамера реакцій &fдозволить вам &6створювати &bКристали&r та &bСпеціальні злитки &fз &bAE2&f ціною &4ЕНЕРГІЇ&f."
		""
		"Ефективніше, ніж рецепти у світі."
	]
	quest.3509C1CA2A82707E.title: "hidden/visit_dd_biomes/razor_edge"
