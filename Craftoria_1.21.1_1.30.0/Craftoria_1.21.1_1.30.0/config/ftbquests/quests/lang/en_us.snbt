	quest.18D1995FE0140399.title: "Електролітичний сепаратор для хлору"
	quest.18D6860E893D80D2.quest_desc: [
		"Дозволяє &aпереміщувати предмети&f з ваших &bДисків зберігання&f в інші &bДиски зберігання&f."
		""
		"Корисно, якщо ви хочете &aстиснути предмети&f на &bДисках&f або звільнити &bДиски&f, щоб зробити більші."
	]
	quest.18DED87B3E23350F.quest_subtitle: "Може виконувати рецепти будь-якої електричної мультиблочної машини, наданої йому партіями."
	quest.18E944F145FEBB8C.quest_desc: [
		"- &4Підпалює&r свою &cціль&r "
		"""Будьте обережні — він також може &6підпалити&r &aнавколишнє середовище&r!"
	]
	quest.18F1D911289E9B7D.title: "unlocks/blocks/blackslag_shimmerstone_light"
	quest.1910E0D1BB24E94D.quest_desc: [
		"Для виробництва &eенергії&r &bСонячній панелі&r потрібен відповідний за рівнем &bФотоелектричний елемент&r у її &6інвентарі&r."
		""
		"Якщо подати &9Дистильовану воду&r до &bСонячної панелі&r, &bФотоелектричний елемент&r у її слоті прослужить у &a2 рази&r довше!"
		""
		"Швидкість &eгенерації енергії&r залежить від того, наскільки високо &6сонце&r у &bнебі&r і чи &bнебо&r &aвидиме&r."
	]
	quest.1910E0D1BB24E94D.quest_subtitle: "Будьте кращими для &aдовкілля&r!"
	quest.1910E0D1BB24E94D.title: "Сонячні панелі"
	quest.193CF7B64BAA89DD.title: "unlocks/enchantments/vanilla_trial"
	quest.19514A457A242CE5.title: "unlocks/reagents/vegetal"
	quest.19645FBFDD22B0F3.title: "unlocks/food/triple_meat_pot_stew"
	quest.1987DF7742136DC4.quest_desc: [
		"  Пам'ятаєте, я казав, що &bДистилятор&r може видавати лише один тип рідини за цикл? Що ж, це ваше покращення!"
		""
		"  &6Ви можете вибрати кількість шарів, до 9&r, і він видаватиме по одній рідині &oна шар&r!"
		""
		"  Щоб вибрати розмір, на який ви хочете налаштувати &bДистиляційну вежу&r, скористайтеся селектором у верхньому лівому куті її екрана. Вдалої дистиляції!"
	]
	quest.1987DF7742136DC4.title: "Дистиляційна вежа"
	quest.19A2B9A9862C59F2.quest_desc: [
		"Використовується для &aпакування та переміщення&b Дисків &fбез&a вилучення&f &bДисків зберігання&f."
		""
		"Працює з більшістю блоків AE2."
	]
	quest.19A71430646BD65B.quest_desc: [
		"&9Потік рідини&r від механічного обертання!"
		""
		"Може працювати паралельно для &6збільшення&r потоку рідини або послідовно для &6проштовхування&r потоків через довгі трубопроводи."
	]
	quest.19B550F54950E253.quest_subtitle: "Зустрічається в рідкісних вежах у холодних біомах. Знайдіть вежі, слідуючи за зірками душ."
	quest.19B550F54950E253.title: "&bНічний ліч"
	quest.19C33613F2811BAA.quest_desc: ["&bБазовий термінал&f дозволяє отримати доступ до вашого &bсховища&f, але його можна покращити."]
	quest.19C33613F2811BAA.title: "Термінал"
	quest.19C79CA0BFD0C590.title: "unlocks/blocks/cmy_pedestal"
	quest.19CAF58A4B2F15DF.title: "unlocks/items/bottle_of_ruin"
	quest.19D4E82652707BA6.title: "hidden/status_effects/frenzy"
	quest.19E67B032C65C7C8.title: "triggers/hints/radiating_ender_page0"
	quest.19F7B6A670D4A707.quest_desc: ["Отримана з &bДистилятора&r, це &bРтуть&r у своєму найчистішому вигляді."]
	quest.19F7B6A670D4A707.quest_subtitle: "Сира ртуть"
	quest.19F7B6A670D4A707.title: "Кристалізована ртуть"
	quest.1A1037C6CD830D8A.title: "milestones/unlock_ink_use"
	quest.1A1C915A4A1F7741.quest_desc: [
		"   &bСлиз вогняного цвіту&r &6перетворить&r блоки &bпервісного вугілля&r на &bсирий вогняний вуглик&r "
