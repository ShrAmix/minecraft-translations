	quest.72845761EA8EA5BC.title: "unlocks/gemstone_lights/amethyst"
	quest.728B2D5E65E7736A.title: "hidden/collect_vanilla/echo_shard"
	quest.7290F8670BBBF12E.quest_desc: ["&bАктивна площина формування ME&f працює як звичайна &bПлощина формування&r, за винятком того, що вона витягує блоки/предмети з системи без необхідності проштовхувати їх до неї, досить зручно, чи не так?"]
