	quest.28D8463C6036B3BF.title: "Хамідиня"
	quest.28EB489B44A05070.quest_desc: ["&aРеплікатори&r будуть використовувати &dМатерію&r, що зберігається в резервуарах, щоб відтворити предмет з нуля і відправити його назад до &bтерміналу&r."]
	quest.28EB489B44A05070.quest_subtitle: "Використовує збережену матерію для створення предметів."
	quest.2909AE63FA355344.quest_desc: [
