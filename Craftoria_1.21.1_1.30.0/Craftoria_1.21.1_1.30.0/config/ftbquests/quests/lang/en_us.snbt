	quest.7948BA211BD790C8.quest_desc: ["Може вміщувати &aнескінченну&r кількість однієї рідини."]
	quest.79515634992D02A3.quest_desc: [
		"Ви можете взяти щойно утворений &dГаз антиматерії&r і перетворити його на &dПелету антиматерії&r."
