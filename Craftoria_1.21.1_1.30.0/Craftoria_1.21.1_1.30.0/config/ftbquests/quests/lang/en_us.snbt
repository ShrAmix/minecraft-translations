	quest.2C7BABC76D6DE355.title: "unlocks/glowblocks/purple_glowblock"
	quest.2C8902E340DD210E.title: "hidden/collect_pigment/green"
	quest.2C92B957A5E8646F.quest_desc: ["&bBlank Pattern&f (Порожній шаблон) використовується для &aавтоматизації рецептів крафту&f. Ви повинні &6закодувати&f &bBlank Pattern&f у &bPattern Encoder&f (Кодувальник шаблонів), а потім помістити його в &bPattern Provider&f (Постачальник шаблонів)."]
