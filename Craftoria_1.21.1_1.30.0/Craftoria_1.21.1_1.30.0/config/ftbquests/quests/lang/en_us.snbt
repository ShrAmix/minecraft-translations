	file.0000000000000001.title: "&lCraftoria"
	quest.000F7897FF9ED7DC.quest_desc: ["Існує &a4 стадії&f росту, так само як і у &bКластерів сертусового кварцу&f. На &aперших трьох стадіях&f ви отримаєте &bЕнтро-пил&f, але на &aчетвертій стадії&f ви зможете отримати &bЕнтро-кристали&f."]
	quest.0012F8780D9172DE.quest_subtitle: "Знайдено за допомогою Ока Безодні"
	quest.0012F8780D9172DE.title: "&5Левіафан"
	quest.00237AB9C48C8A9B.quest_desc: ["&bКонденсатор матерії&f дозволить вам &6створювати &bКулі матерії&f для &bФарбопульта&f, а також &6створювати &bСингулярності&f ціною &aпредметних сутностей&f."]
	quest.002410CF49E1E14E.quest_desc: ["Створюйте за допомогою &bКомпонентів зберігання FE&f для накопичення &4енергії&f."]
	quest.0035439F73199781.quest_desc: ["Я думав, що &bсталь&f — це &bзалізо та вуглець&f, а це просто енергізоване, навіть не коване."]
	quest.0035439F73199781.quest_subtitle: "І вони називають це \"сталлю\""
	quest.0035439F73199781.title: "&eЕнергізована сталь"
	quest.003AC28EAB72F0E6.title: "unlocks/equipment/early_elytra"
	quest.003C38C78609709B.quest_desc: ["Створений у &bВписувачі&f, &bПрес накопичення&f використовується разом із &bЗлитками небесного каменю&f для виробництва &bМікросхем накопичення&f."]
	quest.006DFA2A9D28D01B.title: "unlocks/blocks/fabrication_chest"
	quest.0075009DEEA010B7.quest_desc: [
		"Починайте війну..."
		"...і запрошуйте друзів!"
