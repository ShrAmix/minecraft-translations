	quest.3423502520249615.title: "unlocks/equipment/dreamflayer"
	quest.3438F71F3FE2FD49.title: "unlocks/potions/strong_sleep_effects"
	quest.3442EB0EFAD95794.title: "unlocks/equipment/gemstone_armor_category"
	quest.3447A04FA017C790.quest_desc: [
		"!!! ПРЕДМЕТИ НА &bП'ЄДЕСТАЛАХ&r НЕ БУДУТЬ СПОЖИТІ !!!"
		""
		"&8Основний предмет (центр у рецепті EMI)"
		"&8Додатковий(і) предмет(и) (навколо основного предмета)"
		"&l1. Як використовувати?&r "
		"Покладіть &bдодаткові предмети&r на &bП'єдестали&r &8(якщо рецепт потребує)&r -> покладіть &bосновний предмет&r у &bКамеру наділення&r"
		"-> зачекайте на обробку -> заберіть результат із &bКамери наділення&r."
		""
		"&l2. Розміщення&r"
		"&8П = П'єдестал  |  К = Камера наділення "
		"П П П"
		"П К П"
		"П П П"
		"&8(порада: П'єдестали можуть бути на 1 блок вище/нижче)&r"
		""
		""
		"&4ПРИМІТКА 1&r: не потребує &5джерела&r для роботи. (можна прискорити за допомогою &5джерела&r)."
		"&4ПРИМІТКА 2&r: ВХІД \\& ВИХІД можна автоматизувати за допомогою &bтруб&r."
		""
		"!!! ПРЕДМЕТИ НА &bП'ЄДЕСТАЛАХ&r НЕ БУДУТЬ СПОЖИТІ !!!"
	]
