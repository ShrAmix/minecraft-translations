	quest.75F866DE4306D3EA.title: "unlocks/colored_lamps/black_lamp"
	quest.75FE996305813D68.quest_desc: ["Щоб знайти &6Метеорит&r, вам потрібно буде створити &bМетеоритний компас&r. З &bКомпасом&f він вкаже вам на найближчий &6Метеорит&f."]
