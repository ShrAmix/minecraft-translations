	quest.2D5A0399B7FFA5DB.quest_desc: ["Ктулху дозволяє вам &6дихати&r &bпід водою&r."]
	quest.2D5A0399B7FFA5DB.quest_subtitle: "Прихистіть лавкрафтівське жахіття вже сьогодні"
