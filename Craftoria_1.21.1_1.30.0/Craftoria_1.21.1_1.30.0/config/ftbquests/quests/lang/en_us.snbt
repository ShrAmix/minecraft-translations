	quest.5BBD4DE3D735DFEA.title: "unlocks/ampoules/raw_azurite_ampoule"
	quest.5BCED97AA55DE2E3.quest_desc: [
		"- За замовчуванням: "
		"&8Self -> Leap -> Amplify"
		""
		"- Довший стрибок "
		"&8Self -> Leap -> Amplify -> Amplify"
		""
		""
		"&8Можна додати &5Bounce &8в кінці, якщо ви хвилюєтеся про шкоду від падіння."
		"&8З чарами &6Feather Falling &8ви можете використовувати це заклинання горизонтально перед торканням землі. (шкода від падіння буде мінімальною)"
	]
