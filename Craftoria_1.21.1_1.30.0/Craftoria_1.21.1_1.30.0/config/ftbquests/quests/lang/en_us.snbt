	quest.5D4BE18E15E32353.title: "triggers/hints/moonstone_cores_page1"
	quest.5D584858B61E534B.quest_desc: ["Цей &bКаталізатор&f повільно перетворює &bРтуть&f на &dРтутний потік&r, джерело &6Енергії&r для алхімічних пристроїв."]
	quest.5D584858B61E534B.quest_subtitle: "Ртуть = Потік"
	quest.5D5FC5420738FDE8.quest_desc: ["Звичайний старий &bКартон&r. Такий простий, і все ж... шлях до останнього набору можливостей &oCreate&r, представленого в крилі &c\"Factory Smarts\"&r цієї галереї."]
	quest.5D852AA1930E1019.quest_desc: ["Захоплені іфрити &6люблять&r &bяйця&r, як і їхній далекий предок, Кальцифер"]
	quest.5D88B5377DE5EA19.title: "hidden/collect_shards/topaz"
	quest.5D8F22574EAEDFC2.title: "hidden/collect_primordial_torch"
	quest.5D92326B02E9DC0F.title: "Конвеєри"
	quest.5D93BE4441F7B783.title: "hidden/collect_rock_candy"
	quest.5D9A37AAEC9A2A7B.title: "unlocks/colored_lamps/cyan_lamp"
	quest.5DBFD3F917C4E49C.quest_subtitle: "Знайдено за допомогою Ока Меха"
	quest.5DBFD3F917C4E49C.title: "&4Вісник"
	quest.5DD99224F29419C1.quest_desc: [
		"  Це ваш момент для виробництва справжньої &6електрики&r, використовуючи &bПару&r, яку ви виробляли досі. &bПарова турбіна низької напруги&r перетворюватиме кожен &61 мб пари на 1 EU&r енергії і робитиме це до 32 разів за тік, створюючи &6максимальну швидкість виробництва енергії 32 EU/т&r."
		""
		"  &bПарова турбіна&r автоматично надсилатиме електрику на будь-яку машину, підключену безпосередньо до її вихідної сторони. Вона також підключатиметься лише до кабелів, розміщених на її вихідній стороні."
		""
		"  Перша, яку ви зробите, буде рівня низької напруги. Є парові турбіни вищого рівня, але ви ще не зовсім там."
	]
	quest.5DD99224F29419C1.title: "Парова турбіна НН"
	quest.5DF4A4E6D5E448D0.title: "Вода для електролітичного сепаратора"
