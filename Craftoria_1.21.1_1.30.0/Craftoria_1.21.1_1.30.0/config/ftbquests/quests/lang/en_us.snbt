	quest.0E50E568DFA078D5.quest_subtitle: "Гарна робота!"
	quest.0E50E568DFA078D5.title: "Початок Just Dire Things"
	quest.0E616270A77B2B14.title: "triggers/hints/radiating_ender_page1"
