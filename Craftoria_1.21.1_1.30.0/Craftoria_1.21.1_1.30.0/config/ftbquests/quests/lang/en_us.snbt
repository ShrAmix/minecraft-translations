	quest.345F2EDA7007A031.title: "unlocks/food/bodacious_berry_bar"
	quest.3461AB3CF534FBFA.title: "unlocks/blocks/pastel_network"
	quest.3480351307F0DD04.quest_desc: ["Ці компоненти мають ємність до 256M, але я не змушуватиму вас робити вищі рівні."]
	quest.3492CFBA1602D7F2.quest_desc: [
		"  Коли &6підключена до живлення&r, забезпечує рівень захисту та міцності &bалмазної броні&r."
