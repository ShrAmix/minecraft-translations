	quest.5643738FABBFB6CE.title: "unlocks/trinkets/any_base_trinket"
	quest.5663A6C559490A29.quest_desc: ["&6Клацніть правою кнопкою миші&f &bперлиною аріеля&f на &bзомбі&f або &bхаску&f, і вона буде завершена."]
