	quest.183EB573F8F1DC8C.quest_subtitle: "Зілля | Крафт | Апарат"
	quest.185A13426F0F2D9F.title: "unlocks/equipment/knotted_sword"
	quest.18680FEE2B6FF16F.quest_desc: [
		"  Культури, посаджені на &bҐрунті Блейзблум&r, будуть &6збиратися&r і &6пересаджуватися&r автоматично."
		""
		"  Ви можете використовувати &bЗбирач предметів&r з &oJust Dire Things&r, щоб автоматично &6збирати&r врожай у сховище."
		""
		"  &bҐрунт Блейзблум&r також трохи &6прискорює&r ріст культур і стійкий до &6витоптування.&r"
		"  "
		"{image:justdirethings:block/goofarmland_tier2_moist width:100 height:100 align:center fit:true}"
	]
	quest.18680FEE2B6FF16F.quest_subtitle: "АвтоВрожай"
	quest.186F257352F2E844.quest_desc: ["  Ця машина вимагає зовсім іншого рівня міцності. Час використати той новий &bТитан&r, який ви створили. &bПресувальник&r дозволяє стискати &bВоду&r &6у &bВТ&r&6, або &bвисокого тиску воду&6, а &r&bПару&r &6у &bВТ Пару&r. Він також працює у зворотному напрямку для зниження тиску рідин. &bПресувальник&r також &6дозволяє збирати &bРідке повітря&r &6через &bПовітрозабірник&r, до того ж він набагато ефективніший за &bВакуумний морозильник&r."]
	quest.186F257352F2E844.title: "Пресувальник"
	quest.188CF922D562E21A.quest_desc: [
		"&l1. Запис&r"
		"&6Клацніть правою кнопкою миші&r цим предметом у &6основній руці&r, і він запише всі ваші поточні &5відомі гліфи.&r"
		""
		"&l2. Передача іншим&r"
		"Використовуйте його, щоб вивчити всі гліфи в &bКодексі&r."
		""
		""
		"&4ПРИМІТКА&r: для запису знадобиться &2ДОСВІД&r."
	]
	quest.188CF922D562E21A.quest_subtitle: "Граєте в команді?"
	quest.18956DB32D96ED2B.quest_desc: ["Вже покращення? Намагаєтеся забрати свій будинок із собою? Гарна ідея! Намети часто шкодять спині."]
	quest.18956DB32D96ED2B.title: "Середній просторовий компонент"
	quest.189A301A1489939B.title: "unlocks/enchantments/vanilla_water_luck"
	quest.18ACE29810E1A1F1.title: "unlocks/trinkets/ring_of_aerial_grace"
	quest.18AD60B0941147FD.title: "hidden/collect_fissure_plum"
	quest.18CEE2F64F6E53E6.quest_desc: [
		"  Вітаємо!"
		""
		"  Ви &6розблокували&r &oтретій&r рівень &lJDT&r &bпредметів&r та &bблоків&r."
