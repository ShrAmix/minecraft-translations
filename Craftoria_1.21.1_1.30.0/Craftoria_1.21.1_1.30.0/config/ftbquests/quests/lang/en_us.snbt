	quest.05204F6C709B47BE.title: "unlocks/blocks/ender_blocks"
	quest.053F19ACEEAC0233.title: "unlocks/trinkets/fanciful_gloves"
	quest.0541F90AD95B4B5E.quest_desc: ["Будьте уважні: він може &6зробити&r одну річ на &bДепо&r, а іншу — у &bБасейні&r."]
	quest.0541F90AD95B4B5E.quest_subtitle: "Можу я запропонувати вам сендвіч з огірком?"
	quest.054643E17B416240.title: "unlocks/ampoules/raw_malachite_ampoule"
	quest.0547229FF5334CF5.quest_desc: ["&bІнтерфейс&f діє як скриня, ви можете &aвстановити предмет або рідину&f всередині &bІнтерфейсу&f, і він буде витягувати цей предмет з&5 мережі&f, щоб підтримувати запас."]
	quest.05658FB0767F9CC0.title: "unlocks/items/staff_of_remembrance"
