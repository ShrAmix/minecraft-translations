	quest.790A06C71EAA44A5.title: "unlocks/blocks/sludge"
	quest.79140DD34AF4FA23.title: "unlocks/blocks/pastel_network"
	quest.791CAEBAE57EF0E1.quest_desc: ["  &bМотори&r споживають електрику і створюють обертальну силу. Ви будете використовувати мотори для створення багатьох машин та інших компонентів у майбутньому. &6Вам слід автоматизувати їх&r."]
	quest.791CAEBAE57EF0E1.quest_subtitle: "Крути мене, крути"
	quest.791CAEBAE57EF0E1.title: "Мотори"
	quest.7921D6460E480F82.quest_desc: [
