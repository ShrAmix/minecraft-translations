	quest.2059A9B8174A219A.title: "unlocks/trinkets/azure_dike_belt"
	quest.20620325AB50B7C1.title: "unlocks/enchantments/vanilla_unbreaking"
	quest.206C9BCE1D67C3B8.quest_desc: ["Очищення &bКрейди&r вручну може бути досить виснажливим. На щастя, це вирішена проблема: використовуйте &bЩітку&r!"]
