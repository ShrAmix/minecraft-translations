	quest.1F96BF9252C4CBDB.title: "unlocks/redstone/block_breaker"
	quest.1F9A1456487655B0.quest_desc: [
		"Використовуючи своє &bЯдро Телепортації&r, побудуйте &9Телепортер&r, щоб миттєво подорожувати на будь-яку відстань."
		""
		"Кожен &bПортал Телепортера&r потребує один &9Телепортер&r та &a9&r &bРамок Телепортера&r, створюючи отвір один на два блоки, через який може пройти гравець."
		""
		"&6Налаштуйте&r частоту і вперед!"
	]
