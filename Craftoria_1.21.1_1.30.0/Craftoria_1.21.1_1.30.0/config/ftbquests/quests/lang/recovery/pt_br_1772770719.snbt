		quest.7BDBE300D4B0B1F7.quest_subtitle: {
			new: "Переповнення кістковим борошном!"
			old: "Надлишок кісткового борошна!"
		}
		quest.20A093E5684D2E30.quest_desc: {
			new: [
				"  Ще більш просунута електроніка! Ці друковані плати базуються на алюмінії та дозволяють створювати складніші машини."
				""
				"  Я б порадив &6автоматизувати&r &bЕлектронну схему&r, оскільки вони &6знадобляться вам&r для багатьох &bпокращень MT&r, а також для нових машин, які ви зможете створити."
			]
			old: [
				"  Ще більш просунута електроніка! Ці друковані плати базуються на алюмінії та дозволяють створювати складніші машини."
				""
				"  Я б порадив &6автоматизувати&r &bЕлектронну схему&r, оскільки вони &6знадобляться вам&r для багатьох &bпокращень MV&r, а також для нових машин, які ви зможете створити."
			]
		}
		quest.5DD99224F29419C1.quest_desc: {
			new: [
				"  Це ваш момент виробляти справжню &6електрику&r, використовуючи &bПару&r, яку ви виробляли досі. &bПарова турбіна НН&r перетворюватиме кожні &61 мб пари на 1 EU&r енергії, роблячи це до 32 разів за тік, що дає &6максимальну швидкість виробництва енергії 32 EU/т&r."
				""
				"  &bПарова турбіна&r автоматично надсилатиме електрику до будь-якої машини, підключеної безпосередньо до її вихідної сторони. Вона також підключатиметься лише до кабелів, розміщених на її вихідній стороні."
				""
				"  Перша, яку ви зробите, буде рівня низької напруги. Існують парові турбіни вищого рівня, але ви ще не дійшли до них."
			]
			old: [
				"  Це ваш момент виробляти справжню &6електрику&r, використовуючи &bПару&r, яку ви виробляли досі. &bПарова турбіна НН&r перетворюватиме кожні &61 мб пари на 1 EU&r енергії, роблячи це до 32 разів за тік, що дає &6максимальну швидкість виробництва енергії 32 EU/т&r."
				""
				"  &bПарова турбіна&r автоматично надсилатиме електрику до будь-якої машини, підключеної безпосередньо до її вихідної сторони. Вона також підключатиметься лише до кабелів, розміщених на її вихідній стороні."
				""
				"  Перша, яку ви зробите, буде рівня низької напруги. Існують парові турбіни вищого рівня, але ви ще не дійшли до них."
			]
		}
		quest.04A69DE982F47E64.quest_desc: {
			new: [
				"  Час для ще одного великого оновлення! Тепер ви зможете виробляти &6максимум 512 EU/т&r за допомогою нової &bПарової турбіни ВН&r! Окрім чотирикратного збільшення виробництва енергії (знову), вона працює точно так само, як парова турбіна НН та &bMT&r."
				""
				"  Тепер вам потрібно використовувати новий набір кабелів для ВН. Вам знадобляться кабелі з &bАлюмінію&r або &bКанталу&r, щоб передавати цей новий рівень енергії ВН."
			]
			old: [
				"  Час для ще одного великого покращення! Тепер ви зможете виробляти &6максимум 512 EU/т&r за допомогою нової &bПарової турбіни ВН&r! Окрім чотирикратного збільшення виробництва енергії (знову), вона працює точно так само, як НН та &bMT&r."
				""
				"  Тепер вам потрібно використовувати новий набір кабелів для ВН. Вам знадобляться кабелі з &bАлюмінію&r або &bКанталу&r, щоб передавати цей новий рівень енергії ВН."
			]
		}
		quest.1094111FB9512D75.quest_desc: {
			new: [
				"  Існує три &bМалих дизельних генератори&r, які є початком генерації енергії через рідини або гази. Ви можете використовувати свій EMI, щоб перевірити, скільки EU буде вироблено на мілібакет кожного типу палива."
				""
				"  &bДизельний генератор НН&r вироблятиме до 64 EU/т, &bДизельний генератор MT&r вироблятиме до 256 EU/т, а &bДизельний генератор ВН&r вироблятиме до 1024 EU/т."
				""
				"  &bДизельні генератори&r &6використовуватимуть паливо лише тоді, коли це необхідно&r, тому не хвилюйтеся про марну витрату палива, коли не використовуєте енергію. Однак, якщо вам потрібне постійне постачання енергії, ви можете подавати ці рідкі палива у &bВеликий паровий котел&r (і вищі його рівні) замість того, щоб використовувати лише предмети."
				""
				"  Повністю розігрітий &bВеликий паровий котел&r &6вироблятиме таку ж кількість енергії, як і &bДизельний генератор MT&r, використовуючи ту саму кількість палива."
			]
			old: [
				"  Існує три &bМалих дизельних генератори&r, які є початком генерації енергії через рідини або гази. Ви можете використовувати свій EMI, щоб перевірити, скільки EU буде вироблено на мілібакет кожного типу палива."
				""
				"  &bДизельний генератор НН&r вироблятиме до 64 EU/т, &bДизельний генератор MT&r вироблятиме до 256 EU/т, а &bДизельний генератор ВН&r вироблятиме до 1024 EU/т."
				""
				"  &bДизельні генератори&r &6використовуватимуть паливо лише тоді, коли це необхідно&r, тому не хвилюйтеся про марну витрату палива, коли не використовуєте енергію. Однак, якщо вам потрібне постійне постачання енергії, ви можете подавати ці рідкі палива у &bВеликий паровий котел&r (і вищі його рівні) замість того, щоб використовувати лише предмети."
				""
				"  Повністю розігрітий &bВеликий паровий котел&r &6вироблятиме таку ж кількість енергії, як і &bДизельний генератор MT&r, використовуючи ту саму кількість палива."
			]
		}
