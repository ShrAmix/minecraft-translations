		quest.3F581374C4DDD0A9.quest_desc: {
			new: [
				"&bПокращення «Неламкість»&f робить саме те, що сказано в назві: ваш &bБудівельний жезл&f &6ніколи&f не зламається!"
				""
				"Використовуйте &bКовальський стіл&f, щоб застосувати покращення до свого жезла, використовуючи &5плачучий обсидіан&f як матеріал."
			]
			old: [
				"&bПокращення «Неламкість»&f робить саме те, що сказано в назві: ваш &bБудівельний жезл&f &6ніколи&f не зламається!"
				""
				"Використовуйте &bКовальський стіл&f, щоб застосувати покращення до свого жезла, використовуючи &5плачучий обсидіан&f як матеріал."
			]
		}
		quest.010F3BEDCA334DCB.quest_desc: {
			new: [
				"&bПокращення «Руйнування»&f &6руйнує&f блоки (&cне&f &bблочні сутності&f) з того боку, куди ви дивитеся. Вони &4зникнуть&f повністю, хоча ви можете &6скасувати&f помилку, використовуючи функцію скасування."
				""
				"Використовуйте &bКовальський стіл&f, щоб застосувати покращення до свого жезла, використовуючи &cблок редстоуну&f як матеріал."
			]
			old: [
				"&bПокращення «Руйнування»&f &6руйнує&f блоки (&cне&f &bблочні сутності&f) з того боку, куди ви дивитеся. Вони &4зникнуть&f повністю, хоча ви можете &6скасувати&f помилку, використовуючи функцію скасування."
				""
				"Використовуйте &bКовальський стіл&f, щоб застосувати покращення до свого жезла, використовуючи &cблок редстоуну&f як матеріал."
			]
		}
		quest.4E56C9A5F225A883.quest_subtitle: {
			new: "Спосіб прискорити тіки блоків."
			old: "Спосіб прискорити тіки блоків."
		}
		quest.2A2E1C7C34C9A4AA.quest_desc: {
			new: ["Жезл руйнування видаляє блоки та анулює їх."]
			old: ["Жезл руйнування видаляє блоки та анулює їх."]
		}
		quest.407FD46B5C5A1EC0.quest_desc: {
			new: [
				"&bНайлипший жезл&f — це перша ітерація набору з &9п'яти&f будівельних жезлів, які дозволяють будувати швидше та точніше. Цей може &6будувати&f максимум &9трьома&f блоками в багатьох різних режимах."
				""
				"&6Використовуючи&f клавішу апострофа ('), ви можете відкрити &9екран налаштувань&f. Тут ви можете зробити багато чого:"
				"- &bЗаміна&f дозволяє вирішити, чи хочете ви &6замінювати&f певні блоки, такі як рідини, сніг та висока трава."
				"- &bОбмеження&f дозволяє вирішити, де ви хочете &6розширювати&f розміщені блоки. Натисніть на них, щоб побачити, що можна зробити."
				"- &bВідповідність&f дозволяє вирішити, чи хочете ви &6відповідати&f схожим блокам (типи землі/трави), точним блокам або будь-яким блокам."
				"- &bНапрямок&f дозволяє &6розміщувати&f блоки відповідно до напрямку &9цільового блоку&f або &9гравця&f."
				"- &bВипадковість&f дозволяє &6рандомізувати&f розміщення блоків з вашої панелі швидкого доступу."
				""
				"&6Перевірте&f свої гарячі клавіші в категорії: \"&bConstruction Sticks&f\", щоб налаштувати автоматичні клавіші для &bперемикання напрямку&f, &bобмеження&f та &bпокращення&f. Ви також можете &6налаштувати&f клавіші для &bПоказати попереднє&f та &bСкасувати операцію&f."
				""
				"При &6утриманні&f клавіші для \"&bПоказати попереднє&f\", вона &6підсвітить&f блоки вашої останньої операції &aзеленим&f кольором. Натискання клавіші \"&bСкасувати операцію&f\" та &6правий клік&f &6скасує&f ваше останнє розміщення блоків."
				""
				"Наявність блоків у вашій другій руці дозволить &6розміщувати&f їх замість блоку, на який ви дивитеся."
				"Наявність контейнерів, таких як &bшалкерові скрині&f, &bвузли&f та багато інших, може забезпечити жезл будівельними блоками."
			]
			old: [
				"&bНайлипший жезл&f — це перша ітерація набору з &9п'яти&f будівельних жезлів, які дозволяють будувати швидше та точніше. Цей може &6будувати&f максимум &9трьома&f блоками в багатьох різних режимах."
				""
				"&6Використовуючи&f клавішу апострофа ('), ви можете відкрити &9екран налаштувань&f. Тут ви можете зробити багато чого:"
				"- &bЗаміна&f дозволяє вирішити, чи хочете ви &6замінювати&f певні блоки, такі як рідини, сніг та висока трава."
				"- &bОбмеження&f дозволяє вирішити, де ви хочете &6розширювати&f розміщені блоки. Натисніть на них, щоб побачити, що можна зробити."
				"- &bВідповідність&f дозволяє вирішити, чи хочете ви &6відповідати&f схожим блокам (типи землі/трави), точним блокам або будь-яким блокам."
				"- &bНапрямок&f дозволяє &6розміщувати&f блоки відповідно до напрямку &9цільового блоку&f або &9гравця&f."
				"- &bВипадковість&f дозволяє &6рандомізувати&f розміщення блоків з вашої панелі швидкого доступу."
				""
				"&6Перевірте&f свої гарячі клавіші в категорії: \"&bConstruction Sticks&f\", щоб налаштувати автоматичні клавіші для &bперемикання напрямку&f, &bобмеження&f та &bпокращення&f. Ви також можете &6налаштувати&f клавіші для &bПоказати попереднє&f та &bСкасувати операцію&f."
				""
				"При &6утриманні&f клавіші для \"&bПоказати попереднє&f\", вона &6підсвітить&f блоки вашої останньої операції &aзеленим&f кольором. Натискання клавіші \"&bСкасувати операцію&f\" та &6правий клік&f &6скасує&f ваше останнє розміщення блоків."
				""
				"Наявність блоків у вашій другій руці дозволить &6розміщувати&f їх замість блоку, на який ви дивитеся."
				"Наявність контейнерів, таких як &bшалкерові скрині&f, &bвузли&f та багато інших, може забезпечити жезл будівельними блоками."
			]
		}
