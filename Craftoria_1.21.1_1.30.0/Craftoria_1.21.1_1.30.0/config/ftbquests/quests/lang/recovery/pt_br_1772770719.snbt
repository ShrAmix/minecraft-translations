		quest.6531DF5573672E9E.quest_subtitle: {
			new: "Знайдено в перетвореному Порожнистому пагорбі посеред &6Вогняного болота&r."
			old: "Encontrado em uma Colina Oca convertida no meio do &6Pântano de Fogo&r."
