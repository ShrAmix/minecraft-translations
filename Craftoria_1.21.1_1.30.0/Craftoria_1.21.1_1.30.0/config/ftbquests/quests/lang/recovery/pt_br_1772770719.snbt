		quest.39FCE3168C26B863.quest_desc: {
			new: [
				"  Як тільки у вас з'явиться запас цього &bНадпотужного вугілля&r, ви зможете почати відмовлятися від своїх бронзових машин. Вони повільні й мають такий яскраво-помаранчевий колір, що сліплять очі."
				""
				"  Виготовлення &bКоксового вугілля&r — це просто нагрівання &bВугілля&r за відсутності кисню. Це не дає йому згоріти, піддаючи процесу деструктивної дистиляції. Отримавши його, ви зможете почати працювати зі &bСталлю&r та сталевими машинами, прискорюючи час обробки ціною більшого використання пари."
				""
				"  &6Незабаром ви будете націлені на створення &bКар'єру&r, щоб він міг копати за вас&r. Уявіть, що вам більше ніколи не доведеться видобувати руду!"
			]
			old: [
				"  Як тільки у вас з'явиться запас цього &bНадпотужного вугілля&r, ви зможете почати відмовлятися від своїх бронзових машин. Вони повільні й мають такий яскраво-помаранчевий колір, що сліплять очі."
				""
				"  Виготовлення &bКоксового вугілля&r — це просто нагрівання &bВугілля&r за відсутності кисню. Це не дає йому згоріти, піддаючи процесу деструктивної дистиляції. Отримавши його, ви зможете почати працювати зі &bСталлю&r та сталевими машинами, прискорюючи час обробки ціною більшого використання пари."
				""
				"  &6Незабаром ви будете націлені на створення &bКар'єру&r, щоб він міг копати за вас&r. Уявіть, що вам більше ніколи не доведеться видобувати руду!"
			]
		}
		quest.0ED4263270D37EF6.title: {
