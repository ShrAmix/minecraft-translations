		quest.4A5466E364B85AEF.quest_desc: {
			new: [
				"  Темніше і холодніше за Залізо... Приблизно в 1000 разів міцніше. Час зробити трохи &bСталі&r! Використовуйте той вугільний кокс, який ви виробили раніше, і подрібніть його на порошок. Потім змішайте це з залізним порошком, щоб отримати &bСирий сталевий порошок&r. Пам'ятайте, &6використання &bЗмішувача&r збільшить ваше виробництво.&r"
				""
				"  Тепер пам'ятайте, що найкраща сталь повинна пройти через найгарячіший вогонь; тому ми будемо використовувати &6Парову доменну піч&r, щоб досягти екстремальних температур, необхідних для розплавлення порошкової суміші та її виплавки."
				""
				"  Тепер, коли ви отримали сталь, ви можете оновити свої бронзові машини за допомогою &bПокращень сталевих машин&r. Сталеві машини можуть обробляти рецепти до 4 EU/t і &6оброблятимуть рецепти з подвійною швидкістю&r, за умови, що споживання енергії не перевищує 4 EU/t. З цією вищою межею споживання енергії ви тепер зможете робити нові речі."
			]
			old: [
				"  Темніше і холодніше за Залізо... Приблизно в 1000 разів міцніше. Час зробити трохи &bСталі&r! Використовуйте той вугільний кокс, який ви виробили раніше, і подрібніть його на порошок. Потім змішайте це з залізним порошком, щоб отримати &bСирий сталевий порошок&r. Пам'ятайте, &6використання &bЗмішувача&r збільшить ваше виробництво.&r"
				""
				"  Тепер пам'ятайте, що найкраща сталь повинна пройти через найгарячіший вогонь; тому ми будемо використовувати &6Парову доменну піч&r, щоб досягти екстремальних температур, необхідних для розплавлення порошкової суміші та її виплавки."
				""
				"  Тепер, коли ви отримали сталь, ви можете оновити свої бронзові машини за допомогою &bПокращень сталевих машин&r. Сталеві машини можуть обробляти рецепти до 4 EU/t і &6оброблятимуть рецепти з подвійною швидкістю&r, за умови, що споживання енергії не перевищує 4 EU/t. З цією вищою межею споживання енергії ви тепер зможете робити нові речі."
			]
		}
		quest.0C6D0B1C1AF75292.quest_desc: {
			new: [
				"  Вінстон? Ви абсолютно праві."
				""
				"  &bХімічний реактор&r можна використовувати як закриту машину, щоб скористатися &6хімічною реакцією між речовинами&r у цьому світі для створення нових речей."
				""
				"  &bХімічний реактор&r стимулюватиме ці реакції та триматиме їх ізольованими, щоб ви не поранилися і не захворіли від виділених випарів, рідин або твердих речовин."
				""
				"  Отже, що скажете? Давайте готувати."
			]
			old: [
				"  Вінстон? Ви абсолютно праві."
				""
				"  &bХімічний реактор&r можна використовувати як закриту машину, щоб скористатися &6хімічною реакцією між речовинами&r у цьому світі для створення нових речей."
				""
				"  &bХімічний реактор&r стимулюватиме ці реакції та триматиме їх ізольованими, щоб ви не поранилися і не захворіли від виділених випарів, рідин або твердих речовин."
				""
				"  Отже, що скажете? Давайте готувати."
			]
		}
		quest.454FF6E2926163F7.title: {
			new: "Здатися?"
			old: "Здатися?"
		}
		quest.2C4CA092A557205E.quest_desc: {
			new: [
				"  1985 рік дзвонив з 2015-го, хоче повернути свою антигравітаційну технологію!"
				""
				"  &bГравітаційний нагрудник&r використовує надпровідний кабель, намотаний на платинове ядро, щоб створити поле просторових змін навколо гравця, інвертуючи гравітаційне тяжіння, достатньо, щоб підняти гравця з землі."
				""
				"  Він керується регулюванням енергії до котушок, спрямованих у різні боки. Оскільки він впливає на гравітаційне поле, ви не отримаєте шкоди від падіння, хоча через те, що компоненти, з яких складається &bГравітаційний нагрудник&r, є крихкими та складними, він не захистить від інших видів шкоди."
				""
				"  &6Він використовує EU (і багато) для роботи&r, тому його можна зарядити, натиснувши правою кнопкою миші на блок, який може постачати енергію."
			]
			old: [
				"  1985 рік дзвонив з 2015-го, хоче повернути свою антигравітаційну технологію!"
				""
				"  &bГравітаційний нагрудник&r використовує надпровідний кабель, намотаний на платинове ядро, щоб створити поле просторових змін навколо гравця, інвертуючи гравітаційне тяжіння, достатньо, щоб підняти гравця з землі."
				""
				"  Він керується регулюванням енергії до котушок, спрямованих у різні боки. Оскільки він впливає на гравітаційне поле, ви не отримаєте шкоди від падіння, хоча через те, що компоненти, з яких складається &bГравітаційний нагрудник&r, є крихкими та складними, він не захистить від інших видів шкоди."
				""
				"  &6Він використовує EU (і багато) для роботи&r, тому його можна зарядити, натиснувши правою кнопкою миші на блок, який може постачати енергію."
			]
		}
		quest.779C3C6B89AD2526.quest_subtitle: {
			new: "Час для великого оновлення"
			old: "Час для великого покращення"
		}
		quest.47A8E5DC11E846C5.quest_desc: {
			new: [
				"  Ще до того, як ви зможете зробити &bБронзу&r, вам потрібно буде зібрати &b&oКовальський молот&r. Це практично більша &bКовадло&r, але вона має лише плоский верх, тому ви не зможете використовувати її як ковадло."
				""
				"  Використовуйте його для створення базових речей, таких як &bПластини&r та &bЗлитки&r. Однак &6бити&r по &bКовальському молоту&r &bЗлитком&r може бути дуже &6неефективно&r, і ви отримаєте &6менше&r зі свого &bЗлитка&r через &6пошкоджений&r або &6відколотий&r метал."
				"""  Якщо ви &6створите&r один із багатьох &bМолотів&r, ви &6підвищите ефективність&r та продуктивність; тобто коефіцієнт зросте. Як тільки ви використаєте &bМолот&r, для вас відкриється більше формувань цього &bЗлитка&r. Будьте розумні зі своїми ресурсами, оскільки &bМолот&r не вічний, і його міцність зрештою &6зменшуватиметься&r, поки він не зламається."
				""
				"  Ви також можете використовувати &bКовальський молот&r як спосіб отримати більше &bСирої руди&r зі своїх &bРуд&r. Знову ж таки, використання &bМолота&r дасть вам &6більше&r ціною міцності."
			]
			old: [
				"  Перш ніж ви зможете зробити &bБронзу&r, вам потрібно буде зібрати &b&oКовальський молот&r. Це практично більша &bКовадло&r, але вона має лише плаский верх, тому ви не зможете використовувати її як звичайне ковадло."
				""
				"  Використовуйте його для створення базових речей, таких як &bЛисти&r та &bСтрижні&r. Однак &6бити&r &bКовальським молотом&r по &bЗлитку&r може бути дуже &6неефективно&r, і ви отримаєте &6менше&r зі свого &bЗлитка&r через &6пошкоджений&r або &6відколотий&r метал."
				""
				"  Якщо ви &6створите для себе&r один із багатьох &bМолотів&r, ви &6підвищите ефективність&r та продуктивність; тобто коефіцієнт зросте. Як тільки ви використаєте &bМолот&r, для вас відкриється більше формувань цього &bЗлитка&r. Будьте розумні зі своїми ресурсами, оскільки &bМолот&r не вічний, і його міцність зрештою &6зменшуватиметься&r, поки він не зламається."
				""
				"  Ви також можете використовувати &bКовальський молот&r як спосіб отримати більше &bСирої руди&r зі своїх &bРуд&r. Знову ж таки, використання &bМолота&r дасть вам &6більше&r ціною міцності."
			]
		}
		quest.3C3519AFEBBAEC70.quest_desc: {
			new: [
				"  &bПоршні&r використовують обертальну силу, щоб висувати стрижень з максимально можливою силою."
				""
				"  Це дуже корисно для стиснення речей, а також для їх пакування. &6Ви повинні автоматизувати це&r."
			]
			old: [
				"  &bПоршні&r використовують обертальну силу, щоб висувати стрижень з максимально можливою силою."
				""
				"  Це дуже корисно для стиснення речей, а також для їх пакування. &6Ви повинні автоматизувати їх&r."
			]
		}
		quest.47C1108CF46C81FC.quest_desc: {
			new: ["  &6&bАлюмінієвий бур&r &6дозволяє вам бурити в пошуках &bСирої нафти&r. Він знайде кишені нафти в ґрунті й автоматично викачуватиме її через бур на поверхню."]
			old: ["  &6&bАлюмінієвий бур&r &6дозволяє вам бурити в пошуках &bСирої нафти&r. Він знайде кишені нафти під землею і автоматично викачуватиме її через бур на поверхню."]
		}
		quest.40915337B7E427F8.quest_desc: {
			new: ["  Кабель, здатний передавати достатньо енергії для всієї вашої фабрики, &bу 10 разів більше&r, в межах одного кабелю. Це &bпікова передача енергії&r."]
			old: ["  Кабель, здатний передавати достатньо енергії для всієї вашої фабрики, &bу 10 разів більше&r, в межах одного кабелю. Це &bпікова передача енергії&r."]
		}
