		quest.000F7897FF9ED7DC.quest_desc: {
			new: ["Існує &a4 стадії&f росту, так само як і у &bДруз стиснутого кварцу&f. Якщо на &aперших трьох стадіях&f ви отримаєте &bЕнтро-пил&f, то на &aчетвертій стадії&f ви зможете отримати &bЕнтро-кристали&f."]
