		quest.5408EFD0B9CA0527.quest_desc: {
			new: ["Кожен &bВищий індукційний постачальник&r, доданий до вашої матриці, додає &e52.42 МФЕ за тік&r швидкості передачі енергії в матрицю та з неї."]
			old: ["Cada &bProvedor de Indução Final&r adicionado à sua matriz adiciona &e52.42 MFE por tick&r de taxa de transferência de energia, para dentro e para fora de sua matriz."]
		}
		quest.50D1398BBF8DBBB2.quest_desc: {
			new: ["&bЕлектролітичний сепаратор&r дозволяє брати кілька &7рідин&r і &6розділяти&r їх на основні елементарні компоненти, використовуючи &eелектрику&r для розщеплення молекул у процесі, що називається \"&6Електроліз&r\""]
			old: ["O &bSeparador Eletrolítico&r permite que você pegue múltiplos &7fluidos&r e os &6separe&r em seus componentes elementares principais usando &eeletricidade&r para quebrar as moléculas em um processo chamado \"&6Eletrólise&r\""]
		}
		quest.39A4FF688D140EC2.quest_desc: {
			new: ["&bЛогістичний організатор&r — це &6машина для автоматичного сортування на основі фільтрів&r, яка дозволяє не лише &6надсилати&r &3предмети&r з одного інвентарю в інший безпосередньо за допомогою &bфільтра&r, а й обирати, куди саме ви хочете, щоб відфільтрований (або невідфільтрований) предмет потрапив у межах мережі. Ви можете використовувати &bСловник&r, щоб знайти теги предметів та блоків, щоб &6допомогти&r вам створити більш специфічні фільтри."]
			old: ["O &bClassificador Logístico&r é uma &6máquina de classificação automática baseada em filtros&r que permite não apenas &6enviar&r &3itens&r de um inventário para outro diretamente com um &bfiltro&r, mas também escolher para onde você quer que o item filtrado (ou não filtrado) vá dentro de uma rede. Você pode usar o &bDicionário&r para encontrar tags de itens e blocos para &6auxiliá-lo&r a ter filtros mais específicos."]
		}
		quest.0DA354D54D288D20.quest_desc: {
			new: [
				"&bБазовий термодинамічний провідник&r використовується для передачі &4тепла&r з одного місця в інше. "
				""
				"Кожен провідник, доданий до &cтермодинамічної мережі&r, збільшує її загальну &4теплоємність&r на &a1.0&r, хоча вся мережа підтримуватиме провідність &e5.0&r та ізоляцію &c10.0&r"
				""
				"Ізоляційні можливості &bТермодинамічних провідників&r залежать від &2біому&r. "
				""
				"Якщо ви перебуваєте в &cгарячому&r біомі, ефективність передачі &aвища&r; якщо ви в &bхолодному/замерзлому&r біомі, ефективність передачі &cнижча&r."
			]
			old: [
				"O &bCondutor Termodinâmico Básico&r é usado para conduzir &4calor&r de um local para outro. "
				""
				"Cada condutor adicionado à &crede termodinâmica&r aumenta sua &4capacidade de calor&r total em &a1.0&r, embora toda a rede mantenha uma condução de &e5.0&r e um isolamento de &c10.0&r"
				""
				"As capacidades de isolamento dos &bCondutores Termodinâmicos&r dependem do &2bioma&r. "
				""
				"Se você estiver em um bioma &cquente/morno&r, a eficiência de transferência é &amaior&r; se você estiver em um bioma &bfrio/congelado&r, a eficiência de transferência é &cmenor&r."
			]
		}
		quest.78756CC2F8821E41.title: {
			new: "Покращення газу"
			old: "Melhoria de G00e1s"
