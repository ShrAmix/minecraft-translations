	"chapters/replication.snbt": {
		quest.6B5431B3A107C9D5.title: {
			new: "Термінал реплікації"
			old: "Термінал реплікації"
		}
		quest.24A9E9A5E3B7B041.quest_desc: {
			new: [
				"&aКамера ідентифікації&r &6скануватиме&r предмети, щоб дізнатися їхні значення матерії та зберегти їх у &cчипи&r."
				""
				"Ці &cЧипи&r можна зберігати у &bСховищі чипів&r, і вони будуть доступні для мережі."
			]
			old: [
				"&aКамера ідентифікації&r &6скануватиме&r предмети, щоб дізнатися їхні значення матерії та зберегти їх у &cчипи&r."
				""
				"Ці &cЧипи&r можна зберігати у &bСховищі чипів&r, і вони будуть доступні для мережі."
			]
		}
		quest.6B5431B3A107C9D5.quest_subtitle: {
			new: "Інтерфейс для всіх операцій."
			old: "Інтерфейс для всіх операцій."
		}
		quest.7FCA9352AF05C235.quest_desc: {
			new: [
				"Ці труби &6автоматизують&r деякі процеси:"
				""
				"Передача &6Енергії&r:"
				"- Вони працюють як будь-яка інша &bЕнергетична труба&r."
				""
				"Передача &dМатерії&r:"
				"- Від &bДезінтегратора&r до &bРезервуарів матерії&r."
				""
				"- Від &d&lРезервуарів матерії&r до інших &bмашин&r, яким вона потрібна."
			]
			old: [
				"Ці труби &6автоматизують&r деякі процеси:"
				""
				"Передача &6Енергії&r:"
				"- Вони працюють як будь-яка інша &bЕнергетична труба&r."
				""
				"Передача &dМатерії&r:"
				"- Від &bДезінтегратора&r до &bРезервуарів матерії&r."
				""
				"- Від &d&lРезервуарів матерії&r до інших &bмашин&r, яким вона потрібна."
			]
		}
		quest.4513758183EFECE7.quest_desc: {
			new: [
				"&aReplication&r — це технологічний мод, який дозволяє &6реплікувати&r ресурси схожих типів."
				""
				"Ви можете перетворити &eземлю&r на &8камінь&r, але не можете перетворити &eземлю&r на &bдіаманти&r."
			]
			old: [
				"&aReplication&r — це технологічний мод, який дозволяє &6реплікувати&r ресурси схожих типів."
				""
				"Ви можете перетворити &eземлю&r на &8камінь&r, але не можете перетворити &eземлю&r на &bдіаманти&r."
			]
		}
		quest.1CD404EA948FF868.quest_desc: {
			new: [
				"Використовуючи цю &bмашину&r, ви &6перетворите&r будь-який предмет зі значеннями матерії на &dМатерію&r."
				""
				"Ви помітите, що при &6наведенні курсора&r на певні предмети, вони матимуть додані &9Значення матерії&r."
				""
				"Точні значення можна переглянути, утримуючи клавішу &6Shift&r під час наведення на предмет."
			]
			old: [
				"Використовуючи цю &bмашину&r, ви &6перетворите&r будь-який предмет зі значеннями матерії на &dМатерію&r."
				""
				"Ви помітите, що при &6наведенні курсора&r на певні предмети, вони матимуть додані &9Значення матерії&r."
				""
				"Точні значення можна переглянути, утримуючи клавішу &6Shift&r під час наведення на предмет."
			]
		}
		quest.7FCA9352AF05C235.quest_subtitle: {
			new: "Труби матерії дозволять підключати машини з &aReplication&r."
			old: "Труби матерії дозволять підключати машини з &aReplication&r."
		}
		quest.28EB489B44A05070.quest_desc: {
			new: ["&aРеплікатори&r використовуватимуть &dМатерію&r, що зберігається в резервуарах, щоб відтворити предмет з нуля і відправити його назад у &bтермінал&r."]
			old: ["&aРеплікатори&r використовуватимуть &dМатерію&r, що зберігається в резервуарах, щоб відтворити предмет з нуля і відправити його назад у &bтермінал&r."]
		}
		quest.4513758183EFECE7.title: {
			new: "&aReplication!"
			old: "&aReplication!"
		}
		quest.6B5431B3A107C9D5.quest_desc: {
			new: [
				"Після сканування деяких предметів і збереження їхніх значень у &cчипи&r, ви можете використовувати &aТермінал реплікації&r для &6запиту предметів&r."
				""
				"Після створення запиту &aРеплікатори&r використовуватимуть &dМатерію&r, що зберігається в резервуарах, щоб відтворити предмет з нуля і відправити його назад у &aтермінал&r."
				""
				"{@pagebreak}"
				""
				"&dМатері&aОпедія&r — це список для пошуку, який дозволить &6шукати&r, які предмети мають певне &dЗначення матерії&r."
				""
				"Ви можете отримати доступ до неї за допомогою кнопки &9ліворуч&r від &bРядка пошуку&r на екрані &aТерміналу реплікації&r; ви також можете отримати доступ до неї, натиснувши на дисплеї матерії &9праворуч&r від терміналу."
				""
				"У рядку пошуку &dМатері&aОпедії&r ви можете використовувати:"
				""
				"&l*&r &aearth>10&r покаже всі предмети, які мають більше 10 землі"
				""
				"&l*&r &4nether=20&r покаже всі предмети, які мають рівно 20 незеру"
				""
				"&l*&r &dquantum<6&r покаже всі предмети, які мають менше 6 квантуму"
				""
				"&l*&r &2!earth&r покаже всі предмети, які не мають землі"
				""
				"&l*&r &7*metallic&r покаже всі предмети, які мають лише металеві властивості"
			]
			old: [
				"Після сканування деяких предметів і збереження їхніх значень у &cчипи&r, ви можете використовувати &aТермінал реплікації&r для &6запиту предметів&r."
				""
				"Після створення запиту &aРеплікатори&r використовуватимуть &dМатерію&r, що зберігається в резервуарах, щоб відтворити предмет з нуля і відправити його назад у &aтермінал&r."
				""
				"{@pagebreak}"
				""
				"&dМатері&aОпедія&r — це список для пошуку, який дозволить &6шукати&r, які предмети мають певне &dЗначення матерії&r."
				""
				"Ви можете отримати доступ до неї за допомогою кнопки &9ліворуч&r від &bРядка пошуку&r на екрані &aТерміналу реплікації&r; ви також можете отримати доступ до неї, натиснувши на дисплеї матерії &9праворуч&r від терміналу."
				""
				"У рядку пошуку &dМатері&aОпедії&r ви можете використовувати:"
				""
				"&l*&r &aearth>10&r покаже всі предмети, які мають більше 10 землі"
				""
				"&l*&r &4nether=20&r покаже всі предмети, які мають рівно 20 незеру"
				""
				"&l*&r &dquantum<6&r покаже всі предмети, які мають менше 6 квантуму"
				""
				"&l*&r &2!earth&r покаже всі предмети, які не мають землі"
				""
				"&l*&r &7*metallic&r покаже всі предмети, які мають лише металеві властивості"
			]
		}
	}
	"chapters/Create.snbt": {
		quest.0A67575BAF8596B0.quest_desc: {
			new: ["Краще, ніж ваші іграшкові залізничні колії: прямі, повороти (двох типів) і підйоми — працює через портали в Незер і навіть у незавантажених чанках!"]
			old: ["Краще, ніж ваші іграшкові залізничні колії: прямі, повороти (двох типів) і підйоми — працює через портали в Незер і навіть у незавантажених чанках!"]
		}
		quest.1CACDF56CB395997.quest_subtitle: {
			new: "Руки вгору!"
			old: "Руки вгору!"
		}
		quest.6711E72048BBDB08.quest_desc: {
			new: ["&6Вміщує&r багато предметів до восьми різних типів, можна фарбувати, і до всіх &bЯщиків з інструментами&r поруч можна &6отримати доступ&r за допомогою гарячої клавіші — корисно, щоб не відволікатися від роботи."]
			old: ["&6Вміщує&r багато предметів до восьми різних типів, можна фарбувати, і до всіх &bЯщиків з інструментами&r поруч можна &6отримати доступ&r за допомогою гарячої клавіші — корисно, щоб не відволікатися від роботи."]
		}
		quest.1FDE63D5EA5DA3CB.quest_subtitle: {
			new: "Це не те місце, де жаби сідають і злітають."
			old: "Це не те місце, де жаби сідають і злітають."
		}
		quest.33C2042F320B2D34.quest_desc: {
			new: [
				"Жолоби гнучкіші, ніж ви можете подумати спочатку."
				""
				"Вони можуть розташовуватися вертикально, а також по діагоналі."
				""
				"Гайковий ключ додасть або видалить вікна на жолобах."
				""
				"Переміщує предмети вгору, використовуючи Корпусні вентилятори на будь-якому кінці, щоб нагнітати повітря."
				""
				"Переміщуйте предмети вниз за допомогою... нічого іншого. (дякуємо гравітації!)"
			]
			old: [
				"Жолоби гнучкіші, ніж ви можете подумати спочатку."
				""
				"Вони можуть розташовуватися вертикально, а також по діагоналі."
				""
				"Гайковий ключ додасть або видалить вікна на жолобах."
				""
				"Переміщує предмети вгору, використовуючи Корпусні вентилятори на будь-якому кінці, щоб нагнітати повітря."
				""
				"Переміщуйте предмети вниз за допомогою... нічого іншого. (дякуємо гравітації!)"
			]
		}
		quest.36F22AA68C1841F6.quest_subtitle: {
			new: "Ви в безпеці, захищені та стійкі до лави!"
			old: "Ви в безпеці, захищені та стійкі до лави!"
		}
		quest.264DA461C59E31C3.quest_subtitle: {
			new: "Блейзи! Це не брехня."
			old: "Блейзи! Це не брехня."
