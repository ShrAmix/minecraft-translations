		quest.434D7EDCDD954B40.quest_desc: {
			new: ["Окрім того, що це інгредієнт для крафту, &bАндезитовий корпус&r можна використовувати для &6обшивки&r &bВалів&r та &bКонвеєрів&r, а також &bВеликих&r та &bМалих шестерень&r. Останнє корисно для того, щоб зробити систему передач, призначену для підвищення обертів від початкових джерел енергії, максимально компактною."]
			old: ["Окрім того, що це інгредієнт для крафту, &bАндезитовий корпус&r можна використовувати для &6обшивки&r &bВалів&r та &bКонвеєрів&r, а також &bВеликих&r та &bМалих шестерень&r. Останнє корисно для того, щоб зробити систему передач, призначену для підвищення обертів від початкових джерел енергії, максимально компактною."]
		}
		quest.1FDE63D5EA5DA3CB.quest_desc: {
			new: ["Якщо інтернет-протокол має порти, то &bПакетні жабопорти&r мають бути частиною CCP: Протоколу Ланцюгового Конвеєра."]
			old: ["Якщо інтернет-протокол має порти, то &bПакетні жабопорти&r мають бути частиною CCP: Протоколу Ланцюгового Конвеєра."]
		}
