				"Derrotar o &bAlpha Yeti&r em combate e reivindicar um pouco de sua pele macia tornará a &3Geleira&r disponível para você."
			]
		}
		quest.7DB4E20D476B5786.quest_desc: {
			new: ["Вбивство &cМіногриба&r і поїдання його &bМіф-строганіни&r дозволить вам увійти у &6Вогняне болото&r, не обпікаючись."]
			old: ["Matar o &cMinoshroom&r, e comer um pouco de seu &bMeef Stroganoff&r permitir00e1 que voc00ea entre no &6P00e2ntano de Fogo&r sem se queimar."]
