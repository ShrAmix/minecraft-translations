		quest.6F6898DC529D1120.quest_desc: {
			new: [
				"  Пам'ятаєте, я казав, що ви можете побудувати &bКар'єр&r, щоб більше ніколи не видобувати ресурси? Що ж, настав час! Він не дасть вам &oвсього&r, але дасть багато основних руд. &oВсе&r буде пізніше."
				""
				"  &bПаровий кар'єр&r — це багатоблокова машина на паровій тязі, яка використовує різні &6бури&r, що ви встановлюєте в неї, щоб копати глибше за корінну породу та видобувати руди прямо з надр, що б там не було."
				""
				"  Ви можете перевірити, які руди надасть цей метод, переглянувши EMI. Я рекомендую вам мати кілька працюючих &bПарових доменних печей&r, перш ніж почати збирати &bКар'єр&r, тому що &6це використає БАГАТО &r&bСталі&r."
			]
			old: [
				"  Пам'ятаєте, я казав, що ви можете побудувати &bКар'єр&r, щоб більше ніколи не видобувати ресурси? Що ж, настав час! Він не дасть вам &oвсього&r, але дасть багато основних руд. &oВсе&r буде пізніше."
				""
				"  &bПаровий кар'єр&r — це багатоблокова машина на паровій тязі, яка використовує різні &6бури&r, що ви встановлюєте в неї, щоб копати глибше за корінну породу та видобувати руди прямо з надр, що б там не було."
				""
				"  Ви можете перевірити, які руди надасть цей метод, переглянувши EMI. Я рекомендую вам мати кілька працюючих &bПарових доменних печей&r, перш ніж почати збирати &bКар'єр&r, тому що &6це використає БАГАТО &r&bСталі&r."
			]
		}
		quest.6F57A2A5AA6E3F49.title: {
			new: "Нафтова бурова платформа"
			old: "Нафтова бурова платформа"
		}
		quest.164F4710E109F7F2.quest_desc: {
			new: [
				"  Час для того самого яскравого &bПомаранчевого злитка&r? Вам потрібно буде взяти трохи порошку &bМіді&r та &bОлова&r, які ви отримуєте з &bКовальського молота&r, щоб зробити його. Це проста суміш &63:1&r &bМіді&r до &bОлова&r у вашій сітці крафту. Як тільки ви &6прогресуєте&r, ви знайдете спосіб виробляти цю суміш більш &6ефективно&r, оскільки зараз ви розсипаєте трохи &bпорошку&r, роблячи це вручну."
				""
				"  Тепер, коли ви входите в &aПарову еру&r з цією &bБронзою&r, я дам вам кілька &6порад&r щодо &bмашин&r, які ви будете робити. Пам'ятайте, що &bПарові машини&r прийматимуть вхідні дані з &6будь-якого боку&r, будь то &bпредмети, пара чи інша рідина&r. Ви можете &6заблокувати&r свої слоти, &6клацнувши&r на кнопку, яка виглядає як &bзамок&r в &bінтерфейсі&r."
				""
				"&6Заблоковані&r слоти гарантують, що машина прийматиме &6лише&r один тип &bпредмета&r або &bрідини&r на слот."
				""
				"  Кожна &bмашина&r також має &bвихідну сторону&r, і ви можете &6увімкнути&r &bавтоматичний вихід&r зсередини &bінтерфейсу&r. Використовуючи свій вірний &bГайковий ключ&r, ви можете легко &6налаштувати&r вихідну сторону!"
				""
				"  Якщо ви не хочете, щоб у слотах було забагато &bпредметів&r одночасно, &6використовуйте&r своє &bКоліщатко миші&r, щоб &6налаштувати&r максимальну кількість &bпредметів&r, що зберігаються за раз."
				""
				"  &cP.S.&r Клацання правою кнопкою миші по &bпаровій машині&r з &7порохом&r подвоїть її &6швидкість&r та &6споживання пари&r. Майте це на увазі, коли дивитесь на рецепти. Цей &7порох&r може просто врятувати вас від подорожі в пекло."
			]
			old: [
				"  Час для того самого яскравого &bПомаранчевого злитка&r? Вам потрібно буде взяти трохи порошку &bМіді&r та &bОлова&r, які ви отримуєте з &bКовальського молота&r, щоб зробити його. Це проста суміш &63:1&r &bМіді&r до &bОлова&r у вашій сітці крафту. Як тільки ви &6прогресуєте&r, ви знайдете спосіб виробляти цю суміш більш &6ефективно&r, оскільки зараз ви розсипаєте трохи &bпорошку&r, роблячи це вручну."
				""
				"  Тепер, коли ви входите в &aПарову еру&r з цією &bБронзою&r, я дам вам кілька &6порад&r щодо &bмашин&r, які ви будете робити. Пам'ятайте, що &bПарові машини&r прийматимуть вхідні дані з &6будь-якого боку&r, будь то &bпредмети, пара чи інша рідина&r. Ви можете &6заблокувати&r свої слоти, &6клацнувши&r на кнопку, яка виглядає як &bзамок&r в &bінтерфейсі&r."
				""
				"&6Заблоковані&r слоти гарантують, що машина прийматиме &6лише&r один тип &bпредмета&r або &bрідини&r на слот."
				""
				"  Кожна &bмашина&r також має &bвихідну сторону&r, і ви можете &6увімкнути&r &bавтоматичний вихід&r зсередини &bінтерфейсу&r. Використовуючи свій вірний &bГайковий ключ&r, ви можете легко &6налаштувати&r вихідну сторону!"
				""
				"  Якщо ви не хочете, щоб у слотах було забагато &bпредметів&r одночасно, &6використовуйте&r своє &bКоліщатко миші&r, щоб &6налаштувати&r максимальну кількість &bпредметів&r, що зберігаються за раз."
				""
				"  &cP.S.&r Клацання правою кнопкою миші по &bпаровій машині&r з &7порохом&r подвоїть її &6швидкість&r та &6споживання пари&r. Майте це на увазі, коли дивитесь на рецепти. Цей &7порох&r може просто врятувати вас від подорожі в пекло."
			]
		}
		quest.2F66F85A601AC908.quest_desc: {
			new: [
				"{image:modern_industrialization:block/machines/macerator/overlay_top_active width:32 height:32 align:center}"
				"  Тепер ви можете &6збільшити видобуток руди в 4 рази&r! Це означає, що у вас буде 50% шанс отримати додатковий порошок з вашої &bСирої руди&r. Ви також можете взяти &bЦілісну руду&r і видобути багато &bСирої руди&r з неї, використовуючи &bПодрібнювач&r."
				""
				"  Будучи &bПодрібнювачем&r, ви можете кидати деякі металеві предмети, щоб &6переробити їх назад у порошки&r, це хороший спосіб отримати трохи ресурсів після пригод або переробити старий інструмент."
			]
			old: [
				"{image:modern_industrialization:block/machines/macerator/overlay_top_active width:32 height:32 align:center}"
				"  Тепер ви можете &6збільшити видобуток руди в 4 рази&r! Це означає, що у вас буде 50% шанс отримати додатковий порошок з вашої &bСирої руди&r. Ви також можете взяти &bЦілісну руду&r і видобути багато &bСирої руди&r з неї, використовуючи &bПодрібнювач&r."
				""
				"  Будучи &bПодрібнювачем&r, ви можете кидати деякі металеві предмети, щоб &6переробити їх назад у порошки&r, це хороший спосіб отримати трохи ресурсів після пригод або переробити старий інструмент."
			]
		}
		quest.6F63B60042A7F6AE.quest_desc: {
			new: [
				"{image:modern_industrialization:block/machines/compressor/overlay_front_active width:32 height:32 align:center}"
				"  Це &bКомпресор&r і, ймовірно, перша машина, яку ви захочете побудувати. Можливість &6перетворювати злитки на пластини&r у співвідношенні 1:1 надзвичайно корисна під час парової ери."
				""
				"  Ви економите ресурси і вам не доведеться витрачати молоти лише на те, щоб зібрати достатньо пластин для свого першого проекту."
				""
				"  Він також може брати ті &bПодвійні злитки&r, які ви можете складати молотом у &o2&r пластини, заощаджуючи пару та час."
			]
			old: [
				"{image:modern_industrialization:block/machines/compressor/overlay_front_active width:32 height:32 align:center}"
				"  Це &bКомпресор&r і, ймовірно, перша машина, яку ви захочете побудувати. Можливість &6перетворювати злитки на пластини&r у співвідношенні 1:1 надзвичайно корисна під час парової ери."
				""
				"  Ви економите ресурси і вам не доведеться витрачати молоти лише на те, щоб зібрати достатньо пластин для свого першого проекту."
				""
				"  Він також може брати ті &bПодвійні злитки&r, які ви можете складати молотом у &o2&r пластини, заощаджуючи пару та час."
			]
		}
		quest.3761B64135EA94C0.quest_subtitle: {
			new: "Це для вас містер Ф'южн!"
			old: "Це для вас містер Ф'южн!"
		}
		quest.707EBB99AA8F4C57.quest_desc: {
			new: [
				"  Час зробити свій перший дріт; довгі нитки металів з високою провідністю для передачі електрики. &6Ви можете поєднати ці прості дроти з вашими &bГумовими листами&r &6щоб зробити &bКабелі&r."
				""
				"  Переконайтеся, що ви намотали достатньо гуми навколо цих дротів, ви ж не хочете отримати удар струмом!"
			]
			old: [
				"  Час зробити свій перший дріт; довгі нитки металів з високою провідністю для передачі електрики. &6Ви можете поєднати ці прості дроти з вашими &bГумовими листами&r &6щоб зробити &bКабелі&r."
				""
				"  Переконайтеся, що ви намотали достатньо гуми навколо цих дротів, ви ж не хочете отримати удар струмом!"
			]
		}
		quest.74C5FDC3B1E74586.quest_desc: {
			new: [
				"&bТрансформатор потоку&r — це потужна машина, яка дозволяє практично &6множити&r тип енергії під назвою &eEU&r на енергію &eFE&r. Він настільки потужний, що &6множить&r вихід енергії на &a50&r (у 5 разів більше, ніж стандартно)!"
				""
				"Майте на увазі, ви не можете створити цикл &aенергії&r назад, це процес &cв один бік&r."
			]
			old: [
				"&bТрансформатор потоку&r — це потужна машина, яка дозволяє практично &6множити&r тип енергії під назвою &eEU&r на енергію &eFE&r. Він настільки потужний, що &6множить&r вихід енергії на &a50&r (у 5 разів більше, ніж стандартно)!"
				""
				"Майте на увазі, ви не можете створити цикл &aенергії&r назад, це процес &cв один бік&r."
			]
		}
		quest.16AAEB122CDC1A46.quest_desc: {
			new: [
				"{image:modern_industrialization:block/machines/mixer/overlay_top_active width:32 height:32 align:center}""  Елегантне бронзове покриття з блискучою металевою чашею, куди опускаються змішувальні лопаті для &6змішування&r безлічі різних речей! Ви можете &6змішувати порошки&r з більшою продуктивністю, оскільки нічого не розсипатиметься."
				""
				"  Він змішує не лише порошки, а й рідини. Приклад: &eМастило&r!"
			]
			old: [
				"{image:modern_industrialization:block/machines/mixer/overlay_top_active width:32 height:32 align:center}"
				"  Елегантний бронзовий корпус із блискучою металевою чашею, куди опускаються змішувальні лопаті для &6змішування&r безлічі різних речей! Ви можете &6змішувати порошки&r з більшою продуктивністю, оскільки нічого не розсипатиметься."
				""
				"  Він змішує не лише порошки, а й рідини. Приклад: &eМастило&r!"
			]
		}
		quest.58CA2853D9620919.quest_desc: {
			new: [
				"&bБазове покращення&f — це апгрейд, який ви можете &6створити&f лише з простих компонентів, щоб &9прискорити&f свої машини."
				""
				"Кожне з них додає до максимального ліміту &eенергії&f по &62 EU/t&f."
			]
			old: [
				"&bБазове покращення&f — це апгрейд, який ви можете &6створити&f лише з простих компонентів, щоб &9прискорити&f свої машини."
				""
				"Кожне з них додає &62 EU/t&f до максимального ліміту &eенергії&f."
			]
		}
		quest.707EBB99AA8F4C57.title: {
