		quest.0075009DEEA010B7.quest_desc: {
			new: [
				"Готуйтеся до війни..."
				"...і запрошуйте друзів!"
				""
				"Цей звір має місце для чотирьох осіб, три двигуни, два слоти для зброї та достатньо місця для ваших бойових припасів або для транспортування трофеїв перемоги назад на базу."
			]
			old: [
				"Готуйтеся до війни..."
				"...і запрошуйте друзів!"
				""
				"Цей звір має місце для чотирьох осіб, три двигуни, два слоти для зброї та достатньо місця для ваших бойових припасів або для транспортування трофеїв перемоги назад на базу."
			]
		}
		quest.0075009DEEA010B7.quest_subtitle: {
			new: "Чи я чую \"Політ валькірій\"?"
			old: "Чи я чую \"Політ валькірій\"?"
		}
		quest.4E062B9B4960632D.quest_desc: {
			new: [
				"Надійний транспорт на паливі... вміщує двох!"
				""
				"Має пристойне місце для зберігання, три слоти для покращень, слот для зброї, слот для прапора та слот для барвника — щоб розфарбувати ніс і хвіст."
