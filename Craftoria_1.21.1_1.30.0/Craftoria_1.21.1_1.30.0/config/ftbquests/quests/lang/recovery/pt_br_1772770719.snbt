		quest.2209DC294580BF3D.quest_subtitle: {
			new: "Можна знайти в &6Лігві Єті&r на пагорбах напівквадратної форми."
			old: "Pode ser encontrado no &6Covil do Yeti&r nas colinas de formato um tanto quadrado."
		}
		quest.320C2F44DD138054.quest_desc: {
			new: [
				"На відміну від інших босів, цю тварину не слід вбивати."
				""
				"Замість цього гравець повинен виконати його &6Місію&r — дати йому &bВовну&r усіх кольорів."
				""
				"Вовну можна дати, кинувши її під &cБарана&r або використавши &bВовну&r на ньому."
				""
				"Кожного разу, коли дається блок &bВовни&r, його тіло подовжується, і смужка вовни цього кольору додається до його тіла."
				""
				"Коли місія буде виконана, він скине &6Трофей&r, який завершує це завдання."
			]
			old: [
				"Ao contrário de outros chefes, este animal não deve ser morto."
				""
				"Em vez disso, o jogador deve completar sua &6Missão&r de dar a ele &bLã&r de todas as cores."
				""
				"A Lã pode ser dada a ele jogando a &bLã&r debaixo do &cCarneiro&r, ou usando a &bLã&r nele."
				"""Кожного разу, коли дається блок &bВовни&r, ваше тіло подовжуватиметься, і смужка цього кольору вовни буде додана до вашого тіла."
				""
				"Коли ваше завдання буде виконано, він скине &6Трофей&r, який завершує це завдання."
			]
		}
		quest.5DBFD3F917C4E49C.title: {
			new: "&4Вісник"
			old: "&4Анонсувальник"
		}
		quest.7DB4E20D476B5786.quest_subtitle: {
			new: "Ви можете знайти природний вхід через прірву чи печеру, або ж знайти вхід на невеликому пагорбі."
			old: "Ви можете знайти природний вхід через прірву чи печеру, або ж знайти вхід на невеликому пагорбі."
