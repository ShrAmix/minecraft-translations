	"chapters/Irons Spells.snbt": {
		quest.37A5C2FCA8F75BE6.title: {
			new: "Торгуйте зі Священником"
			old: "Торгуйте з Папою"
		}
		quest.43ACFDB5CD949C74.quest_desc: {
			new: ["Використовуйте Кузню сувоїв та Отруйну картоплю, щоб створити Сувій природи, який корисний для завдання шкоди отрутою або утримання ворогів на місці."]
			old: ["Використовуйте Кузню сувоїв та Отруйну картоплю, щоб створити Сувої природи, які корисні для завдання шкоди отрутою або для утримання ворогів на місці."]
		}
		quest.3D4317C2B25D5680.quest_desc: {
			new: [
				"&bКузня сувоїв&r використовується для &6створення&r сувоїв за допомогою &bПаперу&r та &bЧорнила&r."
				""
				"Існують різні типи &bзаклинань&r, які можна створити за допомогою різних предметів."
				""
				"Ці предмети називаються &bФокусами&r."
				""
				"Кожен &bФокус&r використовується для певної категорії сувоїв."
				""
				"Пам'ятайте, що залежно від &6Рівня&r обраного &bЧорнила&r, будуть доступні більш рідкісні сувої, і сам сувій буде потужнішим."
			]
			old: [
				"&bКузня сувоїв&r використовується для &6створення&r сувоїв за допомогою &bПаперу&r та &bЧорнила&r."
				""
				"Існують різні типи &bзаклинань&r, які можна створити за допомогою різних предметів."
				""
				"Ці предмети називаються &bФокусами&r."
				""
				"Кожен &bФокус&r використовується для певної категорії сувоїв."
				""
				"Пам'ятайте, що залежно від &6Рівня&r обраного &bЧорнила&r, будуть доступні більш рідкісні сувої, і сам сувій буде потужнішим."
			]
		}
		quest.7422BD3C0F060AC5.title: {
			new: "Магічні книги заклинань"
			old: "Магічні книги заклинань"
		}
		quest.0696635896D223CA.quest_desc: {
			new: ["Посох Сивоборода зробить саме це — дасть вам Сивобороду... Жартую, цей посох допоможе вам відновлювати ману, а також збільшить силу вашого сувою. Це один із найпростіших у створенні посохів."]
			old: ["Посох Сивоборода зробить саме це — дасть вам Сивобороду... Жартую, цей посох допоможе вам відновлювати ману, а також збільшить силу вашого сувою. Це один із найпростіших у створенні посохів."]
		}
		quest.480F170F7028C337.quest_desc: {
			new: ["Слот для нижчого заклинання"]
			old: ["Слот для меншого заклинання"]
		}
		task.1ACF33BDD92D15DA.title: {
			new: "ВБИТИ Священника"
			old: "ВБИТИ Папу"
		}
		quest.74D9B681E8EFE064.quest_desc: {
			new: ["Перли Ендермена випадають з ендерменів і використовуються для створення Сувоїв Ендермена."]
			old: ["Перли Ендермена випадають з ендерменів і використовуються для створення Сувоїв Ендермена."]
		}
		quest.7CF09238E123231F.quest_desc: {
			new: [
				"&bЖезл блискавки&r дає вам &a+15%&r до &9Зменшення часу перезарядки заклинань&r та &eСилу заклинань блискавки&r, він також дає &a5%&r до сили сувоїв для &bСувоїв&r, що не належать до стихії блискавки."
				""
				"Використовуйте це, щоб ефективніше чаклувати."
			]
			old: [
				"&bЖезл блискавки&r дає вам &a+15%&r до &9Зменшення часу перезарядки заклинань&r та &eСилу заклинань блискавки&r, він також дає &a5%&r до сили сувоїв для &bСувоїв&r, що не належать до стихії блискавки."
				""
				"Використовуйте це, щоб ефективніше чаклувати."
			]
		}
		quest.2F53567C34E86536.quest_desc: {
			new: ["Це найпростіша книга заклинань, вона може містити лише п'ять заклинань"]
			old: ["Це найпростіша книга заклинань, вона може містити лише п'ять заклинань"]
		}
		quest.69400E62D67A21FC.quest_desc: {
			new: ["Використовуючи Кузню сувоїв та Смарагд, створіть Сувій виклику."]
			old: ["Використовуючи Кузню сувоїв та Смарагд, створіть Сувій виклику."]
		}
		quest.28724CA9F837F710.quest_desc: {
			new: ["Амулет аметистового резонансу — при використанні цей амулет надасть вам 15% бонус до відновлення мани."]
			old: ["Амулет аметистового резонансу — при використанні цей амулет надасть вам 15% бонус до відновлення мани."]
		}
		quest.3B3FDF02E891DD39.quest_desc: {
			new: ["Книга заклинань учня, будучи кращою книгою, вимагає від вас подорожі до Незеру."]
			old: ["Книга заклинань учня, будучи кращою книгою, вимагає від вас подорожі до Незеру."]
		}
		quest.3E212B5DE277B73A.quest_subtitle: {
			new: "Ойк-ойк"
			old: "Ойк-ойк"
		}
		quest.67792A4DE6EDBC37.quest_desc: {
			new: ["Елдрітський манускрипт створюється з восьми Фрагментів знань та одного Фрагмента відлуння. Обидва можна знайти, грабуючи Стародавні міста. При використанні він дасть вам силу Елдрітського сувою на ваш вибір. Ви можете розблокувати більше, але для кожного сувою потрібен новий манускрипт."]
			old: ["Елдрітський манускрипт створюється з восьми Фрагментів знань та одного Фрагмента відлуння. Обидва можна знайти, грабуючи Стародавні міста. При використанні він дасть вам силу Елдрітського сувою на ваш вибір. Ви можете розблокувати більше, але для кожного сувою потрібен новий манускрипт."]
		}
		quest.0C37E9D8A7823264.quest_desc: {
			new: ["Тростина ремісника допомагає ходити всім вам, стареньким — знову ж таки, жартую. Цей посох дасть зменшення часу перезарядки та часу заклинання, а також збільшить силу ваших заклинань. Він трохи дорожчий за посох Сивоборода, проте вартий того для використання потужніших заклинань."]
			old: ["Тростина ремісника допомагає ходити всім вам, стареньким — знову ж таки, жартую. Цей посох дасть зменшення часу перезарядки та часу заклинання, а також збільшить силу ваших заклинань. Він трохи дорожчий за посох Сивоборода, проте вартий того для використання потужніших заклинань."]
		}
		quest.5F2801445E518E49.quest_desc: {
			new: ["Флакони з кров'ю отримуються шляхом стояння в Алхімічному казані або в звичайному казані з вогнем під ним. Як тільки він наповниться кров'ю, ви можете натиснути правою кнопкою миші з порожнім флаконом, щоб зібрати кров."]
			old: ["Флакони з кров'ю отримуються шляхом стояння в Алхімічному казані або в звичайному казані з вогнем під ним. Як тільки він наповниться кров'ю, ви можете натиснути правою кнопкою миші з порожнім флаконом, щоб зібрати кров."]
		}
		quest.71A219DF9715D153.quest_desc: {
			new: ["Використовуючи Кузню сувоїв та Заморожену кістку, створіть Сувій льоду."]
			old: ["Використовуючи Кузню сувоїв та Заморожену кістку, створіть Сувій льоду."]
		}
		quest.51A8026A0F8A83B1.quest_desc: {
			new: ["Смарагди можна знайти під час видобутку, дослідження або торгівлі з жителями, і вони використовуються для створення Сувоїв виклику."]
			old: ["Смарагди можна знайти під час видобутку, дослідження або торгівлі з жителями, і вони використовуються для створення Сувоїв виклику."]
		}
		quest.573FAED7B35F6C86.quest_desc: {
			new: ["Для більш досвідченого мага Зачарована книга заклинань має десять слотів."]
			old: ["Для більш досвідченого мага Зачарована книга заклинань має десять слотів."]
		}
		quest.5F8E418D6A0AD158.quest_desc: {
			new: ["Божественні перлини створюються за допомогою Золотого злитка та Аметистового уламка на Верстаку. Вони використовуються для створення Священних сувоїв."]
			old: ["Божественні перлини створюються за допомогою Золотого злитка та Аметистового уламка на Верстаку. Вони використовуються для створення Священних сувоїв."]
		}
		quest.3AAE23B6BE07E5DC.quest_desc: {
			new: ["Використовуючи Кузню сувоїв та Божественну перлину, створіть Священний сувій, який корисний для лікування та накладання ефектів."]
			old: ["Використовуючи Кузню сувоїв та Божественну перлину, створіть Священний сувій, який корисний для лікування та накладання ефектів."]
		}
		quest.77719A9FBDFE49A7.quest_desc: {
			new: ["Як тільки ви отримаєте порожній рунічний камінь, ви можете створити такий, що наповнений силою різних видів магії. Вони використовуються для створення покращень для вашого спорядження або просто кращого спорядження загалом."]
			old: ["Як тільки ви отримаєте порожній рунічний камінь, ви можете створити такий, що наповнений силою різних видів магії. Вони використовуються для створення покращень для вашого спорядження або просто кращого спорядження загалом."]
		}
		quest.33EEBDD0730C020E.quest_desc: {
			new: ["Використовуючи Кузню сувоїв та Флакон з кров'ю, створіть Сувій крові."]
			old: ["Використовуючи Кузню сувоїв та Флакон з кров'ю, створіть Сувій крові."]
		}
		quest.5221657F939FE63B.quest_desc: {
			new: ["Використовуйте Кузню сувоїв та Флакон з блискавкою, щоб створити Сувій блискавки."]
			old: ["Використовуйте Кузню сувоїв та Флакон з блискавкою, щоб створити Сувій блискавки."]
		}
		quest.0ED5CB1120D1BD6E.quest_desc: {
			new: ["Знайдені під час дослідження, сувої можна знайти по всьому світу, але якщо ви не будете обережні і вирішите використати сувій, він матиме лише одне використання."]
			old: ["Знайдені під час дослідження, сувої можна знайти по всьому світу, але якщо ви не будете обережні і вирішите використати сувій, він матиме лише одне використання."]
		}
		quest.6D092A4BC4A22314.quest_desc: {
			new: ["Фрагменти стародавніх знань можна рідко знайти в здобичі з книжкових полиць, найчастіше вони зустрічаються в Стародавніх містах або при торгівлі з мандрівним торговцем. Вони використовуються для створення Елдрітського манускрипту, який є ключем до розблокування стародавніх знань, що були втрачені дуже давно і тепер використовуються лише Варденами та тими небагатьма, хто наважується шукати цю стару школу магії."]
			old: ["Фрагменти стародавніх знань можна рідко знайти в здобичі з книжкових полиць, найчастіше вони зустрічаються в Стародавніх містах або при торгівлі з мандрівним торговцем. Вони використовуються для створення Елдрітського манускрипту, який є ключем до розблокування стародавніх знань, що були втрачені дуже давно і тепер використовуються лише Варденами та тими небагатьма, хто наважується шукати цю стару школу магії."]
		}
		quest.7422BD3C0F060AC5.quest_desc: {
			new: ["Це книги заклинань найвищого рівня, які може отримати досвідчений маг"]
			old: ["Це книги заклинань найвищого рівня, які може отримати досвідчений маг"]
		}
		quest.3E8C6BD8557C6F08.quest_desc: {
			new: [
				"Після використання манускрипту для розблокування Елдрітського сувою, ви можете використати Фрагмент відлуння в Кузні сувоїв для створення Елдрітського заклинання. Ці сувої можна створити лише за допомогою Легендарного чорнила."
				"""Мантія Безодні - Вже хотіли просто ухилятися від атак? Кріпер вибухає, а ви просто кажете \"Ха-ха, не влучив\"? З цим заклинанням ви перетворюєтеся на ендермена, телепортуючись геть, коли вас атакують, і стаєте практично невразливими, поки діє заклинання."
				""
				"Елдрітч-вибух - Після активації ви можете випустити до 7 вибухів чистої енергії. Кожен постріл може летіти на відстань до 30 блоків, тільки переконайтеся, що не підірвете власну голову."
				""
				"Планарний зір - Це схоже на чітерство... ви можете бачити будь-яку сутність у межах дозволеної дальності промальовування. Так, це працює з невидимими та видимими сутностями і змушує їх світитися крізь стіни."
				""
				"Щупальця Скалку - Це дуже тривожне заклинання, яке вивільняє ліс Щупалець Скалку з-під землі, чудово підходить для розіграшів друзів, які новачки в грі, або для знищення груп мобів, і завдає пристойної кількості шкоди."
				""
				"Звуковий удар - Станьте Варденом і випустіть звукову хвилю, яка завдає великої шкоди сутностям у радіусі 20-30 блоків (залежно від рівня)."
				""
				"Телекінез - Вже був моб або друг, якого ви просто хотіли викинути в небуття? З цим заклинанням ви можете схопити сутність і жбурляти її, поки заклинання не закінчиться. Але будьте обережні: якщо ви змусите їх врізатися в стіну, вони отримають кінетичну шкоду."
			]
			old: [
				"Після використання Манускрипту для розблокування Елдрітч-сувою, ви можете використати Ехо-фрагмент у кузні сувоїв, щоб створити Елдрітч-заклинання. Ці сувої можна створити лише за допомогою Легендарного чорнила."
				""
				"Мантія Безодні - Вже хотіли просто уникати атак? Кріпер вибухає, а ви просто кажете \"Ха-ха, не влучив\"? З цим заклинанням ви перетворюєтеся на ендермена, телепортуючись геть, коли вас атакують, і стаєте практично невразливими, поки діє заклинання."
				""
				"Елдрітч-вибух - Після активації ви можете випустити до 7 вибухів чистої енергії. Кожен постріл може летіти на відстань до 30 блоків, тільки будьте обережні, щоб не підірвати власну голову."
				""
				"Планарний зір - Це схоже на чітерство... ви можете бачити будь-яку сутність у межах дозволеної дальності промальовування. Так, це працює з невидимими та видимими сутностями і змушує їх світитися крізь стіни."
				""
				"Щупальця Скалку - Це дуже тривожне заклинання, яке вивільняє ліс Щупалець Скалку з-під землі, чудово підходить для розіграшів друзів, які новачки в грі, або для знищення груп мобів, і завдає пристойної кількості шкоди."
				""
				"Звуковий удар - Станьте Варденом і випустіть звукову хвилю, яка завдає великої шкоди сутностям у радіусі 20-30 блоків (залежно від рівня)."
				""
				"Телекінез - Вже був моб або друг, якого ви просто хотіли викинути в небуття? З цим заклинанням ви можете схопити сутність і жбурляти її, поки заклинання не закінчиться. Але будьте обережні: якщо ви змусите їх врізатися в стіну, вони отримають кінетичну шкоду."
			]
		}
		quest.704C0B04EFF5024C.quest_desc: {
			new: [
				"Цей стіл використовується для компіляції &bСувоїв&f, які ви знайшли та створили, у &bКнигу заклинань&f."
				""
				"Щоб видалити &bСувій&f, &6клацніть&f на заклинання, яке ви хочете &6видалити&f, і &6клацніть&f на &bСувій&f накреслення з &6правого боку&f."
			]
			old: [
				"Цей стіл використовується для компіляції &bСувоїв&f, які ви знайшли та створили, у &bКнигу заклинань&f."
				""
				"Щоб видалити &bСувій&f, &6клацніть&f на заклинання, яке ви хочете &6видалити&f, і &6клацніть&f на &bСувій&f накреслення з &6правого боку&f."
			]
		}
		quest.0D8988AF02D890EA.quest_subtitle: {
			new: "Знайдіть Стародавнє поле битви"
			old: "Знайдіть Стародавнє поле битви"
		}
		quest.37F1166AB7EF132E.quest_subtitle: {
			new: "Що це за слиз?"
			old: "Що це за слиз?"
		}
		quest.72539873C7201A47.quest_desc: {
			new: ["Отруйні картоплі використовуються для створення Сувоїв природи."]
			old: ["Отруйні картоплі використовуються для створення Сувоїв природи."]
		}
		quest.51542DCB5C8E5C3A.quest_desc: {
			new: ["Другий рівень Книги заклинань, що містить лише 6 заклинань"]
			old: ["Другий рівень Книги заклинань, що містить лише 6 заклинань"]
		}
		quest.42AC14C7D41F0CAB.quest_desc: {
			new: ["Використовуючи Кузню сувоїв та Стрижень іфріта, створіть Сувій вогню, який дуже добре підходить для спалення ваших ворогів... а іноді й ваших друзів... Просто переконайтеся, що випадково не кинете вогняну кулю в їхніх улюбленців, і все буде добре!"]
			old: ["Використовуйте Кузню сувоїв та Стрижень іфріта для створення Сувоїв вогню, які дуже добре підходять для спалення ваших ворогів... а іноді й ваших друзів... Просто переконайтеся, що випадково не кинете вогняну кулю в їхніх улюбленців, і все буде добре!"]
		}
		quest.2085CB41244C2783.quest_desc: {
			new: ["Перебуваючи в Незері, ви повинні пробитися до Хоглінів і добути Шкуру Хогліна."]
			old: ["Перебуваючи в Незері, ви повинні битися з Хоглінами і добути Шкуру Хогліна."]
		}
		quest.0BDF41399223A10A.quest_desc: {
			new: ["Використовуючи Кузню сувоїв та Перлину Ендермена, створіть Сувій Ендермена."]
			old: ["Використовуючи Кузню сувоїв та Перлину Ендермена, створіть Сувій Ендермена."]
		}
		quest.7EDF633DDB5DA2A1.quest_desc: {
			new: ["Заморожені кістки випадають зі Зимових блукальців і використовуються для створення Сувоїв льоду"]
			old: ["Заморожені кістки випадають зі Зимових блукальців і використовуються для створення Сувоїв льоду"]
		}
		quest.30ED8D5374012D92.quest_desc: {
			new: ["Пляшку з блискавкою можна отримати, клацнувши правою кнопкою миші з порожньою пляшкою на зарядженого кріпера."]
			old: ["Пляшку з блискавкою можна отримати, клацнувши правою кнопкою миші з порожньою пляшкою на зарядженого кріпера."]
		}
	}
	"chapters/Mekanism.snbt": {
		quest.66F756E370750359.quest_desc: {
			new: [
				"Гарні штани! "
				""
				"&bШтани MekaSuit&r захистять ваші ноги майже від будь-якої &4атаки&r, як тільки ви їх повністю &6покращите&r. "
			]
			old: [
				"Гарні штани! "
				""
				"&bШтани MekaSuit&r захистять ваші ноги майже від будь-якої &4атаки&r, як тільки ви їх повністю &6покращите&r. "
			]
		}
		quest.22D2716905D415E5.quest_desc: {
			new: [
				"&bКамера збагачення&r — це простий механізм, який не тільки дозволяє &6збагачувати руди&r у два або більше &bпорошків&r, але й дозволяє &6збагачувати&r багато інших речей, таких як:"
				""
				"- Квіти на порошки"
				"- Видалення моху з блоків"
				"- Видалення окислення"
				"- І багато іншого!"
				""
				"Порада: &6Збагачуйте&r свої типи інгредієнтів для інфузії, такі як вугілля, редстоун, алмази, очищений обсидіан, щоб отримати більше &bматеріалу для інфузії&r, ніж зі звичайного самоцвіту/порошку."
			]
			old: [
				"&bКамера збагачення&r — це простий механізм, який не тільки дозволяє &6збагачувати руди&r у два або більше &bпорошків&r, але й дозволяє &6збагачувати&r багато інших речей, таких як:"
				""
				"- Квіти на порошки"
				"- Видалення моху з блоків"
				"- Видалення окислення"
				"- І багато іншого!"
				""
				"Порада: &6Збагачуйте&r свої типи інгредієнтів для інфузії, такі як вугілля, редстоун, алмази, очищений обсидіан, щоб отримати більше &bматеріалу для інфузії&r, ніж зі звичайного самоцвіту/порошку."
			]
		}
		quest.6A382549A4C55A5E.quest_desc: {
			new: ["&cВдосконалена схема керування&r — це наступний рівень &6схем&r, що дозволяє створювати ще більш просунуті механізми."]
			old: ["&cВдосконалена схема керування&r — це наступний рівень &6схем&r, що дозволяє створювати ще більш просунуті механізми."]
		}
		quest.5F95D00149FB24FD.quest_desc: {
			new: ["&bКамера хімічного розчинення&r бере &9руду&r і хімічно &6розчиняє&r усі домішки, отримуючи необроблену &dпульпу руди&r."]
			old: ["&bКамера хімічного розчинення&r бере &9руду&r і хімічно &6розчиняє&r усі домішки, отримуючи необроблену &dпульпу руди&r."]
		}
		quest.60F4F5FE0C3748C3.title: {
			new: "Хімічний промивач"
			old: "Хімічний промивач"
		}
		quest.3CABE90D2D99AAD0.quest_desc: {
			new: ["&bФормула створення&r використовується для зберігання рецептів крафту, які використовуються у &bФормульних збирачах&r."]
			old: ["&bФормула створення&r використовується для зберігання рецептів крафту, які використовуються у &bФормульних збирачах&r."]
		}
		quest.117C9FABE86447D1.quest_desc: {
			new: ["&bКвантовий заплутувач&r дозволяє миттєво &6транспортувати&r &bпредмети&r, &7рідини&r, &eгази&r, &4тепло&r, &dпігменти&r, &9пульпи&r, &aтипи інфузії&r та &6енергію&r у будь-яке місце, так само як і &bТелепортер&r."]
			old: ["&bКвантовий заплутувач&r дозволяє миттєво &6транспортувати&r &bпредмети&r, &7рідини&r, &eгази&r, &4тепло&r, &dпігменти&r, &9пульпи&r, &aтипи інфузії&r та &6енергію&r у будь-яке місце, так само як і &bТелепортер&r."]
		}
		quest.7BB4CE27736F4C08.title: {
			new: "Динамічний клапан"
			old: "Динамічний клапан"
		}
		quest.110B0C8DD2FD5BE7.quest_subtitle: {
			new: "Світ автоматизації чекає!"
			old: "Світ автоматизації чекає!"
		}
		quest.5408EFD0B9CA0527.title: {
			new: "Вищий індукційний постачальник"
			old: "Вищий індукційний постачальник"
		}
		quest.183E523C25CC6C3F.quest_desc: {
			new: [
				"&bБазовий логістичний транспортер&r використовується для &6транспортування предметів&r з однієї точки в іншу."
				""
				"Кожна труба \"&cзабору&r\" може передавати &a2&r предмети на секунду в логістичну мережу. "
				""
				"Сама труба дозволяє швидкість передачі лише &e1.0 метр на секунду&r. Це швидкість, з якою предмет летить через трубу. "
				""
				"Вищі рівні &bтруб&r можуть значно збільшити цей показник."
				""
				"Хоча, попри обмеження труби \"&cзабору&r\", ліміт \"&aвиштовхування&r\" для контейнера або механізму є нескінченним, якщо ви можете помістити предмет у мережу."
			]
			old: [
				"&bБазовий логістичний транспортер&r використовується для &6транспортування предметів&r з однієї точки в іншу."
				""
				"Кожна труба \"&cзабору&r\" може передавати &a2&r предмети на секунду в логістичну мережу. "
				""
				"Сама труба дозволяє швидкість передачі лише &e1.0 метр на секунду&r. Це швидкість, з якою предмет летить через трубу. "
				""
				"Вищі рівні &bтруб&r можуть значно збільшити цей показник."
				""
				"Хоча, попри обмеження труби \"&cзабору&r\", ліміт \"&aвиштовхування&r\" для контейнера або механізму є нескінченним, якщо ви можете помістити предмет у мережу."
			]
		}
		quest.34B822EC25F66B54.quest_desc: {
			new: ["&bКомпресор осмію&r використовується для &6стиснення&r &3осмію&r у певні порошки для &6створення&r їхніх аналогів у злитках."]
			old: ["&bКомпресор осмію&r використовується для &6стиснення&r &3осмію&r у певні порошки для &6створення&r їхніх аналогів у злитках."]
		}
		quest.1A885E0BA312B916.quest_desc: {
			new: ["&bРезистивний нагрівач&r дозволяє перетворювати &aенергію&r на тепло. Потім ви можете &6ввести&r тепло у вежу через &bКлапан термічного випаровування&r, щоб допомогти &rпідвищити&r температуру вежі."]
			old: ["&bРезистивний нагрівач&r дозволяє перетворювати &aенергію&r на тепло. Потім ви можете &6ввести&r тепло у вежу через &bКлапан термічного випаровування&r, щоб допомогти &rпідвищити&r температуру вежі."]
		}
		quest.39A4FF688D140EC2.title: {
			new: "Логістичний сортувальник"
			old: "Логістичний сортувальник"
		}
		quest.1A9AD40B2F094DCF.title: {
			new: "Покращення генератора каменю"
			old: "Покращення генератора каменю"
		}
		quest.27B6C6079B5FE918.quest_desc: {
			new: ["&bРотаційний конденсатор&r дозволяє &6конденсувати&r &eгаз&r у його &7рідку&r форму і навпаки, натиснувши кнопку у верхньому лівому куті графічного інтерфейсу."]old: ["O &bCondensador Rotativo&r permite que você &6condense&r um &gás&r em sua forma &7líquida&r e vice-versa, pressionando o botão no canto superior esquerdo da GUI."]
		}
		quest.22AC242F0A230278.quest_desc: {
			new: ["O &bAdaptador de Redstone OIQ&r permite que você &6monitore&r o conteúdo do seu sistema de armazenamento através de &4sinais de redstone&r."]
			old: ["O &dAdaptador de Redstone QIO&r permite que você &6monitore&r o conteúdo do seu sistema de armazenamento através de &4sinais de redstone&r."]
		}
		quest.703C1F1E9A6F4A9E.title: {
			new: "Хімічний інфузор"
			old: "Infusor Qu00edmico"
		}
		quest.67A41E4D6BCA5F2B.quest_desc: {
			new: ["Це серце системи квантової оркестрації предметів (QIO). Ви будете зберігати тут свої диски QIO. Бережіть його як зіницю ока."]
			old: ["Este é o coração do sistema de Orquestração Quântica de Itens. Você armazenará seus drives QIO aqui. Proteja-o com sua vida."]
		}
		quest.6EDFD510DC096B12.title: {
			new: "Станція модифікації"
			old: "Esta00e700e3o de Modifica00e700e3o"
		}
		quest.3C6E442CEB73191F.quest_desc: {
			new: [
				"&bГазовий генератор&r може використовувати безліч &cзаймистих газів&r для виробництва &eелектрики&r. "
				""
				"Такі гази, як &7водень&r та &dетилен&r, можуть бути корисними для отримання великої кількості &eенергії&r на ранніх етапах. "
				""
				"Перевірте свій &dEMI&r, щоб побачити, які &7гази&r є справді &cзаймистими&r і скільки &6енергії&r ви можете з них отримати."
			]
			old: [
				"O &bGerador a Gás&r pode usar uma infinidade de &cgases inflamáveis&r para gerar &eeletricidade&r."
				""
				"Gases como &7Hidrogênio&r e &dEteno&r podem ser bons para uma grande quantidade de &eenergia&r no início."
				""
				"Verifique seu &dEMI&r para ver quais &7gases&r são verdadeiramente &cinflamáveis&r e quanta &6energia&r você pode gerar com eles."
			]
		}
		quest.59451B5DAD78C46F.quest_desc: {
			new: [
				"&bАтомний розбирач&r — це найкращий інструмент, який ви коли-небудь будете використовувати. "
				""
				"Це всі інструменти в одному, і він може завдавати &4величезної шкоди&r."
			]
			old: [
				"O &bDesmontador Atômico&r é a melhor ferramenta que você já usará. "
				""
				"É todas as ferramentas em uma e pode infligir &4muito dano&r."
			]
		}
		quest.2571BC62616A45AB.quest_desc: {
			new: [
				"Це ваша &bПанель QIO&r. "
				""
				"Саме тут ви отримаєте доступ до всіх своїх &bпредметів&r. "
				""
				"Елегантна та темна; вона впишеться майже в будь-яке місце."
			]
			old: [
				"Este é o seu &dPainel QIO&r. "
				""
				"É onde você acessará todos os seus &bitens&r. "
				""
				"Elegante e escuro; caberá em quase qualquer lugar."
			]
		}
		quest.30D584EAD9243548.title: {
			new: "Рідинний наповнювач"
			old: "Plenificador Fluídico"
		}
		quest.1B65CA6898CC3F9E.quest_desc: {
			new: [
				"&bБазова фабрика інфузії&r може обробляти до &a3&r процесів інфузії одночасно. "
				""
				"Зліва є кнопка \"&6Авто-організація&r\", яка дозволяє машині автоматично розподіляти вхідні матеріали між &a3&r слотами введення. "
				""
				"&bБазова фабрика інфузії&r може вмістити до &92 960 мб&r інфузійного матеріалу."
			]
			old: [
				"A &bFábrica de Infusão Básica&r pode processar até &a3&r processos de infusão de uma vez. "
				""
				"Há um botão à esquerda chamado \"&6Auto-Ordenar&r\" que permite à máquina dividir automaticamente as entradas entre os &a3&r slots de entrada. "
				""
				"A &bFábrica de Infusão Básica&r pode conter até &92.960 mb&r de material de infusão."
			]
		}
