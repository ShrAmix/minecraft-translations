		quest.33D0760B5FEF7C46.quest_desc: {
			new: [
				"  &oЦе&r найкращий генератор."
				""
				"  &bПлазмова турбіна&r використовує &bГелієву плазму&r для виробництва енергії, &6до 1 048 576 EU/т&r. Це приблизно 100 000 EU на мілібакет &bГелієвої плазми&r, зі &6швидкістю споживання близько 11 мб/т&r."
				""
				"  Якщо ви вмієте доглядати за своєю фабрикою, вам &oніколи&r більше не доведеться турбуватися про енергію."
			]
			old: [
				"  &oЦе&r найкращий генератор."
				""
				"  &bПлазмова турбіна&r використовує &bГелієву плазму&r для виробництва енергії, &6до 1 048 576 EU/т&r. Це приблизно 100 000 EU на мілібакет &bГелієвої плазми&r, зі &6швидкістю споживання близько 11 мб/т&r."
				""
				"  Якщо ви вмієте доглядати за своєю фабрикою, вам &oніколи&r більше не доведеться турбуватися про енергію."
			]
		}
		quest.640DB4139DF8AFA4.quest_desc: {
			new: [
				"  &bКвантова схема&r. Вершина обчислювальних технологій."
				""
				"  Початок для найдосконаліших машин, які ви тільки можете собі уявити."
				""
				"  Відтепер &aнемає меж для вашої уяви&r."
			]
			old: [
				"  &bКвантова схема&r. Вершина обчислювальних технологій."
				""
				"  Початок для найдосконаліших машин, які ви тільки можете собі уявити."
				""
				"  Відтепер &aнемає меж для вашої уяви&r."
			]
		}
		quest.3143EA7DF096CE61.quest_desc: {
			new: [
				"  Нова машина! Її можна зробити лише зі сталі; вона справді потребує цієї додаткової міцності."
				""
				"  &bПакувальник&r може виконувати прості крафти за вас. Ви можете &6автоматизувати подвійні злитки, труби, багато видів цегли та інше&r! Перевірте свій EMI для отримання додаткових рецептів."
			]
			old: [
				"  Нова машина! Її можна зробити лише зі сталі; вона справді потребує цієї додаткової міцності."
				""
				"  &bПакувальник&r може виконувати прості крафти за вас. Ви можете &6автоматизувати подвійні злитки, труби, багато видів цегли та інше&r! Перевірте свій EMI для отримання додаткових рецептів."
			]
		}
		quest.0B2FF8169FD3812D.quest_desc: {
			new: [
				"  &bСталеві люки&r мають &6подвійну місткість порівняно з бронзовими&r, збільшуючи інвентарний слот до 2, а також збільшуючи максимальну швидкість споживання пари мультиблоком з 2 EU/т до 4 EU/т. Якщо є хоча б один сталевий люк для входу рідини, що отримує пару, весь ваш мультиблок оновлюється до \"сталевого рівня\"."
				""
				"  Дозвіл мультиблокам використовувати 4 EU/т означає саме те, що ви думаєте — подвоєння максимальної швидкості процесів."
				""
				"  &bСталевий котел&r вироблятиме вдвічі більше пари, ніж бронзовий. Це означає, що він досягне максимуму в &o16 EU/т&r замість 8. &bСталевий водяний насос&r також вироблятиме вдвічі більше &bВоди&r, ніж його бронзовий аналог, загалом до 250 мб &bВоди&r для кожного сусіднього джерела води, до 2000 мб &bВоди&r кожні 5 секунд."
			]
			old: [
				"  &bСталеві люки&r мають &6подвійну місткість порівняно з бронзовими&r, збільшуючи інвентарний слот до 2, а також збільшуючи максимальну швидкість споживання пари мультиблоком з 2 EU/т до 4 EU/т. Якщо є хоча б один сталевий люк для входу рідини, що отримує пару, весь ваш мультиблок оновлюється до \"сталевого рівня\"."
				""
				"  Дозвіл мультиблокам використовувати 4 EU/т означає саме те, що ви думаєте — подвоєння максимальної швидкості процесів."
				""
				"  &bСталевий котел&r вироблятиме вдвічі більше пари, ніж бронзовий. Це означає, що він досягне максимуму в &o16 EU/т&r замість 8. &bСталевий водяний насос&r також вироблятиме вдвічі більше &bВоди&r, ніж його бронзовий аналог, загалом до 250 мб &bВоди&r для кожного сусіднього джерела води, до 2000 мб &bВоди&r кожні 5 секунд."
			]
		}
		quest.7342F6461382E839.quest_desc: {
			new: [
				"Ви &aдосягли&r фінального кроку до &bнепереможності&r."
				""
				"&bБроня&r, наповнена &dКвантовою технологією&r, щоб &6відбивати&r всі &cфізичні&r та &5магічні&r атаки."
				""
				"Ви не можете померти, навіть від &6Божественного удару&r."
				""
				"Тепер ви можете &6вільно літати&r без потреби в &eелектриці&r."
				""
				"Цей &bкомплект броні&r взаємодіє безпосередньо з &dквантовим царством&r, щоб змінювати простір і час навколо вас."
				""
				"Теоретично, ви все ще будете &6нерухомі&r, а простір просто &6рухатиметься&r відносно вас. --Це-- &6сила&r, якою ви володієте."
				""
				"Цей &bмеч&r може і буде розрізати &bбудь-що&r на вашому шляху."
				""
				"Лезо вашого меча має &aздатність&r розсікати час і стирати будь-яку &eсутність&r, яку ви оберете, з існування. Використовуйте цю &6силу&r відповідально."
			]
			old: [
				"Ви &aдосягли&r фінального кроку до &bнепереможності&r."
				""
				"&bБроня&r, наповнена &dКвантовою технологією&r, щоб &6відбивати&r всі &cфізичні&r та &5магічні&r атаки."
				""
				"Ви не можете померти, навіть від &6Божественного удару&r."
				""
				"Тепер ви можете &6вільно літати&r без потреби в &eелектриці&r."
				""
				"Цей &bкомплект броні&r взаємодіє безпосередньо з &dквантовим царством&r, щоб змінювати простір і час навколо вас."
				""
				"Теоретично, ви все ще будете &6нерухомі&r, а простір просто &6рухатиметься&r відносно вас. --Це-- &6сила&r, якою ви володієте."
				""
				"Цей &bмеч&r може і буде розрізати &bбудь-що&r на вашому шляху."
				""
				"Лезо вашого меча має &aздатність&r розсікати час і стирати будь-яку &eсутність&r, яку ви оберете, з існування. Використовуйте цю &6силу&r відповідально."
			]
		}
		quest.469641436BC858D3.quest_desc: {
			new: [
				"  Ви прочитали &bКнигу&r? Ну, я все одно дам вам короткий виклад цієї &6технологічної подорожі&r; ви мені подякуєте."
				"""{image:modern_industrialization:item/guidebook width:32 height:32 align:center}"
				"  Те, чим ви будете займатися, — це практично &o&aModern Industrialization&r&r, використовуючи безліч різних механік, від &bЛогістики&r до &6Дистиляції&r, що дозволяє досягти &6Повної Автоматизації&r. Наведу кілька &6прикладів&r:"
				""
				"  Ви отримаєте доступ до потужних &bЛогістичних Інструментів&r, таких як &bБагатокомпонентні Предмети&r та &bТруби для Рідин&r, а також &bЕнергетичні Кабелі&r. Це означає, що до трьох одиниць кожного можна розмістити в &bОдному Блоці&r!"
				""
				"  Вам більше ніколи не доведеться видобувати ресурси вручну, оскільки ви зможете будувати &bКар'єри&r для безперервної генерації ресурсів!"
				""
				"  Зрештою, вам потрібно буде &6живити&r всі свої &bМашини&r, &bПарові&r чи ні. Вам доведеться використовувати &bПару&r та &bНафту&r, перероблену на &bДизель&r за допомогою &6Дистиляції&r, &6Ядерного Поділу&r і, нарешті, у механічному домініоні: &6Термоядерного Синтезу&r. Ви можете збільшити швидкість передачі енергії, використовуючи &bВищу Напругу&r."
				""
				"  Більше не хочете &6вручну&r збирати &bШестерню&r, &bМолот&r чи &bСтрижень&r? Добре, що це світ, який ви створюєте. Ви зможете створити машину практично для будь-чого! Повна автоматизація цілком можлива, і ви можете робити це, літаючи з &bГравітаційним Нагрудником&r."
				""
				"  &aВи готові до подорожі всього життя?&r &cЧас вирушати!&r"
				""
				"  &6P.S&r. Якщо ви застрягли з машиною, просто візьміть свій &bКнигу-Посібник&r і &6наведіть курсор&r на &bМашину&r або &bМультиблок&r. Це дасть вам додаткову &bінформацію&r."
			]
			old: [
				"  Ви прочитали &bКнигу&r? Ну, в будь-якому разі, я дам вам короткий огляд цієї &6технологічної подорожі&r; ви мені подякуєте."
				""
				"{image:modern_industrialization:item/guidebook width:32 height:32 align:center}"
				"  Те, чим ви будете займатися, — це практично &o&aСучасна Індустріалізація&r&r, використовуючи безліч різних механік, від &bЛогістики&r до &6Дистиляції&r, що дозволяє досягти &6Повної Автоматизації&r. Наведу кілька &6прикладів&r:"
				""
				"  Ви отримаєте доступ до потужних &bЛогістичних Інструментів&r, таких як &bБагатокомпонентні Предмети&r та &bТруби для Рідин&r, а також &bЕнергетичні Кабелі&r. Це означає, що до трьох одиниць кожного можна розмістити в &bОдному Блоці&r!"
				""
				"  Вам більше ніколи не доведеться видобувати ресурси вручну, оскільки ви зможете будувати &bКар'єри&r для безперервної генерації ресурсів!"
				""
				"  Зрештою, вам потрібно буде &6живити&r всі свої &bМашини&r, &bПарові&r чи ні. Вам доведеться використовувати &bПару&r та &bНафту&r, перероблену на &bДизель&r за допомогою &6Дистиляції&r, &6Ядерного Поділу&r і, нарешті, у механічному домініоні: &6Термоядерного Синтезу&r. Ви можете збільшити швидкість передачі енергії, використовуючи &bВищу Напругу&r."
				""
				"  Більше не хочете &6вручну&r збирати &bШестерню&r, &bМолот&r чи &bСтрижень&r? Добре, що це світ, який ви створюєте. Ви зможете створити машину практично для будь-чого! Повна автоматизація цілком можлива, і ви можете робити це, літаючи з &bГравітаційним Нагрудником&r."
				""
				"  &aВи готові до подорожі всього життя?&r &cЧас починати!&r"
				""
				"  &6P.S&r. Якщо ви застрягли з машиною, просто візьміть свій &bКнигу-Посібник&r і &6наведіть курсор&r на &bМашину&r або &bМультиблок&r. Це дасть вам додаткову &bінформацію&r."
			]
		}
		quest.40915337B7E427F8.quest_subtitle: {
			new: "Я — справжній дріт під напругою"
			old: "Я — дріт високої напруги"
		}
		quest.186F257352F2E844.quest_desc: {
			new: ["  Ця машина вимагає зовсім іншого рівня сили. Час використати той новий &bТитан&r, який ви створили. &bПресувальник&r дозволяє стискати &bВоду&r &6у &bВП&r&6, або &bводу високого тиску&6, та &r&bПару&r &6у &bПару ВП&r. Також працює у зворотному напрямку для зниження тиску рідин. &bПресувальник&r також &6дозволяє збирати &bРідке Повітря&r &6через &bПовітряний Вхід&r, і він набагато ефективніший за &bВакуумний Морозильник&r."]
			old: ["  Ця машина вимагає зовсім нового рівня сили. Час використати той новий &bТитан&r, який ви створили. &bПресувальник&r дозволяє стискати &bВоду&r &6у &bВоду високого тиску&6, або &bВП&6, та &r&bПару&r &6у &bПару ВП&r. Також працює у зворотному напрямку для зниження тиску рідин. &bПресувальник&r також &6дозволяє збирати &bРідке Повітря&r &6через &bПовітряний Вхід&r, і він набагато ефективніший за &bВакуумний Морозильник&r."]
		}
		quest.61748279816F2D7F.quest_desc: {
			new: [
				"&bМодуль керування редстоуном&f призначений для того, щоб ви могли керувати своїми машинами за допомогою &cредстоуну&f! &6Клацання правою кнопкою миші&f по модулю в руці &6змінить&f налаштування машини з вимоги &9Високого сигналу&f на &9Низький сигнал&f і навпаки. Потім вставте його в слот модуля &cредстоуну&f."
				""
				"Це означає наступне:"
				"- Поки налаштування встановлено на &9Високий сигнал&f, машина &6працюватиме&f лише тоді, коли отримує сигнал &cредстоуну&f. Відсутність сигналу &cредстоуну&f вимкне її."
				"- Поки налаштування встановлено на &9Низький сигнал&f, машина &6працюватиме&f лише тоді, коли не отримує сигнал &cредстоуну&f. Сигнал &cредстоуну&f вимкне її."
			]
			old: [
				"&bМодуль керування редстоуном&f призначений для того, щоб ви могли керувати своїми машинами за допомогою &cредстоуну&f! &6Клацання правою кнопкою миші&f по модулю в руці &6змінить&f налаштування машини з вимоги &9Високого сигналу&f на &9Низький сигнал&f і навпаки. Потім вставте його в слот модуля &cредстоуну&f."
				""
				"Це означає наступне:"
				"- Поки налаштування встановлено на &9Високий сигнал&f, машина &6працюватиме&f лише тоді, коли отримує сигнал &cредстоуну&f. Відсутність сигналу &cредстоуну&f вимкне її."
				"- Поки налаштування встановлено на &9Низький сигнал&f, машина &6працюватиме&f лише тоді, коли не отримує сигнал &cредстоуну&f. Сигнал &cредстоуну&f вимкне її."
			]
		}
