	"chapters/PneumaticCraft.snbt": {
		quest.688DEE1D1C4F9BDA.quest_desc: {
			new: [
				"Цей &9модуль&r випромінює &4сигнал редстоуну&r з силою, пропорційною &7тиску&r всередині &bтруб&r. "
				""
				"Коли &6обладнаний&r &bКартою розширення модуля&r, ви можете &6налаштувати&r поріг через &3GUI&r."
			]
			old: [
				"Цей &9модуль&r випромінює &4сигнал редстоуну&r з силою, пропорційною &7тиску&r всередині &bтруб&r. "
				""
				"Коли &6обладнаний&r &bКартою розширення модуля&r, ви можете &6налаштувати&r поріг через &3GUI&r."
			]
		}
		quest.07F1FA5EF3E6A7F3.quest_desc: {
			new: [
				"Ця &3речовина&r може бути &6оброблена&r у &bТермопневматичній установці&r для &6виробництва&r &bГасу&r або, при додаванні &4Редстоуну, Мастила&r. "
				""
				"Служить &aхорошим&r &7рідким паливом&r, а також може бути &6поміщена&r у &8Піч&r."
			]
			old: [
				"Ця &3речовина&r може бути &6оброблена&r у &bТермопневматичній установці&r для &6виробництва&r &bГасу&r або, при додаванні &4Редстоуну, Мастила&r. "
				""
				"Служить &aхорошим&r &7рідким паливом&r, а також може бути &6поміщена&r у &8Піч&r."
			]
		}
		quest.325A0651CB2D1279.quest_desc: {
			new: [
				"Ця машина піддає &cПорожні друковані плати&r впливу &eУФ-світла&r, готуючи їх до &6обробки&r у &bТанку травлення&r."
				""
				"Більш тривалий &eчас експозиції&r покращує ймовірність &aуспішного травлення&r, хоча процес &7сповільнюється&r з часом. "
				""
				"Ви можете встановити &3поріг&r, щоб визначити, коли &bдрукована плата&r вважається &aзавершеною&r; &eнижчий поріг&r прискорює &6обробку&r, але збільшує ризик &cневдалого травлення&r. "
				""
				"&cБраковані плати&r можна &2переробити&r у &8Доменній печі&r для ще однієї спроби."
			]
			old: [
				"Ця машина піддає &cПорожні друковані плати&r впливу &eУФ-світла&r, готуючи їх до &6обробки&r у &bТанку травлення&r."
				""
				"Більш тривалий &eчас експозиції&r покращує ймовірність &aуспішного травлення&r, хоча процес &7сповільнюється&r з часом."
				""
				"Ви можете встановити &3поріг&r, щоб визначити, коли &bдрукована плата&r вважається &aзавершеною&r; &eнижчий поріг&r прискорює &6обробку&r, але збільшує ризик &cневдалого травлення&r."
				""
				"&cБраковані плати&r можна &2переробити&r у &8Доменній печі&r для ще однієї спроби."
			]
		}
		quest.16B74C92EB86AD0C.title: {
			new: "&7Розплавлений пластик"
			old: "&7Розплавлений пластик"
		}"Ця машина &6виробляє&r &7Стиснене Повітря&r. "
				""
				"Щоб керувати нею, &6помістіть&r будь-який предмет &8твердого палива&r, який може &cгоріти&r у &8Печі&r, у слот для палива. "
				""
				"Зауважте, що &7відра з паливом&r не сумісні; для &7рідкого палива&r використовуйте натомість &bРідинний Компресор&r."
			]
			old: [
				"Ця машина &6виробляє&r &7Стиснене Повітря&r."
				""
				"Щоб керувати нею, &6помістіть&r будь-який предмет &8твердого палива&r, який може &cгоріти&r у &8Печі&r, у слот для палива."
				""
				"Будь ласка, зауважте, що &7відра з паливом&r не сумісні; для &7рідкого палива&r використовуйте натомість &bРідинний Компресор&r."
			]
		}
		quest.525658A19130AF37.quest_desc: {
			new: [
				"Генерує &7Стиснене Повітря&r, використовуючи різні &7рідкі види палива&r. "
				""
				"Щоб побачити всі доступні &8види палива&r, відкрийте вкладку «&9Доступне Паливо&r», яка відсортована від &aнайбільш&r до &cнайменш&r ефективного. "
			]
			old: [
				"Генерує &7Стиснене Повітря&r, використовуючи різні &7рідкі види палива&r. "
				""
				"Щоб побачити всі доступні &8види палива&r, відкрийте вкладку «&9Доступне Паливо&r», яка відсортована від &aнайбільш&r до &cнайменш&r ефективного. "
			]
		}
		quest.6070283AEA8DFA7E.quest_desc: {
			new: [
				"&bНафтопереробний завод&r — це &3мультиблок&r, у якому ви &6розміщуєте&r &bКонтролер Нафтопереробного заводу&r внизу, а &bНафтопереробні установки&r зверху, &dдві&r для початку. "
				""
				"Ви можете &6розмістити&r до &a4&r, але це &cне збільшить&r &eшвидкість&r &bНафтопереробного заводу&r, проте дозволить йому &6виробляти&r інші &7рідини&r з &8Сирої Нафти&r. "
				""
				"Маючи лише дві &bНафтопереробні установки&r зверху, ви почнете &6виробляти&r &8Дизель&r та &eЗВГ&r. У міру збору &bресурсів&r, додавання ще однієї &bНафтопереробної установки&r дасть вам &bГас&r, а ще однієї — &8Бензин&r."
				""
				"Для роботи &bНафтопереробного заводу&r вам знадобиться &4тепло&r. &4Тепло&r можна отримати від &bСмолоскипів&r навколо &bмашини&r для &aнизької ефективності&r, &4лави&r для &eсередньої ефективності&r, та &cвиробництва тепла&r від &bВихрової Трубки&r з використанням &7тиску&r."
			]
			old: [
				"&bНафтопереробний завод&r — це &3мультиблок&r, у якому ви &6розміщуєте&r &bКонтролер Нафтопереробного заводу&r внизу, а &bНафтопереробні установки&r зверху, &aдві&r для початку. "
				""
				"Ви можете &6розмістити&r до &a4&r, але це &cне збільшить&r &eшвидкість&r &bНафтопереробного заводу&r, проте дозволить йому &6виробляти&r інші &7рідини&r з &8Сирої Нафти&r. "
				""
				"Маючи лише дві &bНафтопереробні установки&r зверху, ви почнете &6виробляти&r &8Дизель&r та &eЗВГ&r. У міру збору &bресурсів&r, додавання ще однієї &bНафтопереробної установки&r дасть вам &bГас&r, а ще однієї — &8Бензин&r."
				""
				"Для роботи &bНафтопереробного заводу&r вам знадобиться &4тепло&r. &4Тепло&r можна отримати від &bСмолоскипів&r навколо &bмашини&r для &bнизької ефективності&r, &4лави&r для &eсередньої ефективності&r та &cвиробленого тепла&r від &bВихрової Трубки&r з використанням &7тиску&r."
			]
		}
		quest.7342ABDAD6467123.quest_desc: {
			new: [
				"Логістичні структури спрощують логістичні завдання у вашій мережі, будь то за допомогою дронів або труб під тиском щонайменше 3 бар. &4Логістичний ключ&r необхідний для роботи з усіма логістичними структурами."
				""
				"Структури працюють у вашій мережі наступним чином, у порядку пріоритетності:"
				""
				"- Активні структури-постачальники проштовхують предмети до структур-запитувачів, сховищ та стандартних сховищ"
				"- Стандартні структури-сховища проштовхують предмети до структур-запитувачів та сховищ, і приймають предмети від активних структур-постачальників"
				"- Структури-сховища проштовхують предмети до структур-запитувачів і приймають предмети від активних структур-постачальників та стандартних структур"
				"- Пасивні структури лише проштовхують предмети до структур-запитувачів і не приймають предмети від жодних інших структур"
				"- Структури-запитувачі не проштовхують предмети до жодних інших структур і приймають предмети від активних, пасивних структур та структур-сховищ."
				""
				"{@pagebreak}"
				"Фільтри можна налаштувати для кожної зі структур за допомогою фільтрів сортування або тегів, використовуючи Верстак Тегів для встановлення фільтра. "
				""
				"Функціональність залежить від структури, до якої застосовується фільтр:"
				""
				"- Активні структури-постачальники: фільтри контролюють, які рідини/предмети проштовхуються в мережу"
				"- Стандартні структури-сховища: фільтри контролюють, які рідини/предмети приймаються з мережі"
				"- Структури-сховища: фільтри контролюють, які рідини/предмети приймаються з мережі"
				"- Пасивні структури: фільтри контролюють, які рідини/предмети проштовхуються до структур-запитувачів у мережі"
				"- Структури-запитувачі: фільтри контролюють, які рідини/предмети приймаються з мережі"
				""
				"Зокрема для структур-запитувачів можна використовувати обидва типи фільтрів, прокручуючи/натискаючи їх для встановлення бажаної кількості (див. підказки в інтерфейсі структури-запитувача). Хоча фільтри можуть перекриватися (наприклад, один вказує 32 колоди, а інший — 32 будь-якого типу пального), це може призвести до того, що фільтри будуть адитивними, що дасть 32 колоди + ще 32 колоди як пальне."
				""
				"{@pagebreak}"
				"Для всіх логістичних структур нічого не буде транспортовано, якщо немає місця в жодному інвентарі/резервуарі всередині мережі. "
				""
				"Крім того, хоча логістичні завдання можуть виконуватися логістичними дронами або логістичними модулями, підключеними до труб під тиском щонайменше 3 бар, дрони не можуть отримати доступ до структур, коли вони заблоковані логістичними модулями; проте до одного блоку/інвентарю/резервуара можна підключити кілька структур, якщо це необхідно."
			]
			old: [
				"Логістичні структури спрощують логістичні завдання у вашій мережі, будь то за допомогою дронів або труб під тиском щонайменше 3 бар. &4Логістичний ключ&r необхідний для роботи з усіма логістичними структурами."
				""
				"Структури працюють у вашій мережі наступним чином, у порядку пріоритетності:"
				""
				"- Активні структури-постачальники проштовхують предмети до структур-запитувачів, сховищ та стандартних сховищ"
				"- Стандартні структури-сховища проштовхують предмети до структур-запитувачів та сховищ, і приймають предмети від активних структур-постачальників"
				"- Структури-сховища проштовхують предмети до структур-запитувачів і приймають предмети від активних структур-постачальників та стандартних структур"
				"- Пасивні структури лише проштовхують предмети до структур-запитувачів і не приймають предмети від жодних інших структур"
				"- Структури-запитувачі не проштовхують предмети до жодних інших структур і приймають предмети від активних, пасивних структур та структур-сховищ."
				""
				"{@pagebreak}"
				"Фільтри можна налаштувати для кожної зі структур за допомогою фільтрів сортування або тегів, використовуючи Верстак Тегів для встановлення фільтра."
				""
				"Функціональність залежить від структури, до якої застосовується фільтр:"
				""
				"- Активні структури-постачальники: фільтри контролюють, які рідини/предмети проштовхуються в мережу"
				"- Стандартні структури-сховища: фільтри контролюють, які рідини/предмети приймаються з мережі"
				"- Структури-сховища: фільтри контролюють, які рідини/предмети приймаються з мережі"
				"- Пасивні структури: фільтри контролюють, які рідини/предмети проштовхуються до структур-запитувачів у мережі"
				"- Структури-запитувачі: фільтри контролюють, які рідини/предмети приймаються з мережі"
				""
				"Зокрема для структур-запитувачів можна використовувати обидва типи фільтрів, прокручуючи/натискаючи їх для встановлення бажаної кількості (див. підказки в інтерфейсі структури-запитувача). Хоча фільтри можуть перекриватися (наприклад, один вказує 32 колоди, а інший — 32 будь-якого типу пального), це може призвести до того, що фільтри будуть адитивними, що дасть 32 колоди + ще 32 колоди як пальне."
				""
				"{@pagebreak}"
				"Для всіх логістичних структур нічого не буде транспортовано, якщо немає місця в жодному інвентарі/резервуарі всередині мережі."
				""
				"Крім того, хоча логістичні завдання можуть виконуватися логістичними дронами або логістичними модулями, підключеними до труб під тиском щонайменше 3 бар, дрони не можуть отримати доступ до структур, коли вони заблоковані логістичними модулями; проте до одного блоку/інвентарю/резервуара можна підключити кілька структур, якщо це необхідно."
			]
		}
		quest.18E944F145FEBB8C.quest_desc: {
			new: [
				"- &4Підпалює&r вашу &cціль&r "
				""
