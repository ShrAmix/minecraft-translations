		quest.16B74C92EB86AD0C.quest_desc: {
			new: [
				"&6Вилийте&r &7рідину&r у світ або &bохолодіть&r її в &3інвентарі&r за допомогою &cТеплової структури&r, щоб &6затвердіти&r її у &bПластикові листи&r. "
