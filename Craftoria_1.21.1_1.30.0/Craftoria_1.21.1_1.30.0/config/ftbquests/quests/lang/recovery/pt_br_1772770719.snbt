		quest.67F2212453B81446.quest_desc: {
			new: [
				"  Змішаний злиток, що містить пластину &bІридію&r, затиснуту між двома &bВибухозахищеними Сплавами&r, готовий до створення надміцної &bІридієвої Пластини&r."
				""
				"  До речі про сендвічі, виглядає досить &bапетитно&r, чи не так?"
			]
			old: [
				"  Змішаний злиток, що містить пластину &bІридію&r між двома &bВибухозахищеними Сплавами&r, готовий до створення надміцної &bІридієвої Пластини&r."
				""
				"  До речі про сендвічі, виглядає досить &bапетитно&r, чи не так?"
			]
		}
		quest.325D7C592E2FB05A.quest_desc: {
			new: [
				"  &bКінцевий&r стан твердої матерії, стиснутий настільки щільно, що став точкою нескінченної щільності та гравітації."
				""
				"  Хоча ви можете утримувати це для використання в різних цілях. Ви тримаєте... &bНескінченність&r."
			]
			old: [
				"  &bКінцевий&r стан твердої матерії, стиснутий настільки щільно, що став точкою нескінченної щільності та гравітації."
				""
				"  Однак ви можете утримувати це для використання в різних цілях. Ви тримаєте... &bНескінченність&r."
			]
		}
		quest.4722157BC8D3B965.quest_desc: {
			new: [
				"  Елегантний бронзовий корпус із жорстоким лезом, що обертається всередині, забезпечить вам &6ще кращі пропорції різання&r, ніж ви відчували, використовуючи свій &bКовальський Молот&r. &aЧас для додаткових гвинтів, шестерень, кілець та стрижнів!&r"
				""
				"  Тільки пам'ятайте, що ви не можете різати безкоштовно. Ця машина працює на &bПарі&r і використовує &bМастило&r для чистих зрізів без перегріву. &bМастило&r можна виготовити в &bЗмішувачі&r, використовуючи &bРедстоун&r та один із багатьох вуглеводнів. Раджу перевірити продукти &bКоксової Печі&r. Ви можете знайти щось, що можна &6змішати&r з &bРедстоуном&r!"
			]
			old: [
				"  Елегантний бронзовий корпус із жорстоким лезом, що обертається всередині, забезпечить вам &6ще кращі показники різання&r, ніж ви відчували, використовуючи свій &bКовальський Молот&r. &aЧас для додаткових гвинтів, шестерень, кілець та стрижнів!&r"
				""
				"  Тільки пам'ятайте, що ви не можете різати безкоштовно. Ця машина працює на &bПарі&r і використовує &bМастило&r для чистих зрізів без перегріву. &bМастило&r можна виготовити в &bЗмішувачі&r, використовуючи &bРедстоун&r та один із багатьох вуглеводнів. Раджу перевірити продукти &bКоксової Печі&r. Ви можете знайти щось, що можна &6змішати&r з &bРедстоуном&r!"
			]
		}
		quest.791CAEBAE57EF0E1.quest_desc: {
			new: ["  &bДвигуни&r споживають електрику і виробляють обертальну силу. Ви будете використовувати двигуни для створення багатьох машин та інших компонентів у майбутньому. &6Ви повинні автоматизувати це&r."]
			old: ["  &bДвигуни&r споживають електрику і виробляють обертальну силу. Ви будете використовувати двигуни для створення багатьох машин та інших компонентів у майбутньому. &6Ви повинні автоматизувати їх&r."]
		}
		quest.1CC910880728D896.quest_desc: {
			new: [
				"  Вам сподобався &bЯдерний Поділ&r? Що ж, настав час для &bЯдерного Синтезу&r!"
				""
				"  Замість того, щоб розщеплювати важке, нестабільне ядро на два легші, &bсинтез&r поєднує два легкі ядра, що, своєю чергою, вивільняє величезну кількість енергії."
				""
				"  Цю енергію можна утримувати та використовувати для виробництва &bГелієвої Плазми&r — надзвичайно енергоємної рідини, яка може стати найкращим джерелом енергії у світі."
				""
				"  Ви можете поєднувати газоподібні палива, такі як &bДейтерій&r, &bТритій&r та/або &bГелій-3&r, для створення різних комбінацій Гелієвої Плазми, Тритію, Дейтерію та Водню."
				""
				"  Майте на увазі, цей синтез споживає багато енергії для запуску, але в результаті може виробити набагато більше."
			]
			old: [
				"  Вам сподобався &bЯдерний Поділ&r? Що ж, настав час для &bЯдерного Синтезу&r!"
				""
				"  Замість того, щоб розщеплювати важке, нестабільне ядро на два легші, &bсинтез&r поєднує два легкі ядра, що, своєю чергою, вивільняє величезну кількість енергії."
				""
				"  Цю енергію можна утримувати та використовувати для виробництва &bГелієвої Плазми&r — надзвичайно енергоємної рідини, яка може стати найкращим джерелом енергії у світі."
				""
				"  Ви можете поєднувати газоподібні палива, такі як &bДейтерій&r, &bТритій&r та/або &bГелій-3&r, для створення різних комбінацій Гелієвої Плазми, Тритію, Дейтерію та Водню."
				""
				"  Майте на увазі, цей синтез потребує багато енергії для запуску, але в результаті може виробити набагато більше."
			]
		}
		quest.1CA2825FFA775BBE.quest_desc: {
			new: [
				"  Це нова електрична машина, яка використовує сильні електричні струми для розділення матеріалів на різні частини."
				""
				"  Найважливіше, ви можете &6розділити &bВоду&r &6на два її основні компоненти: &bВодень&r &6та &bКисень&r."
				""
				"  Цей процес називається &6Електроліз&r і працює за допомогою електричного струму для розділення ||іонних сполук|| на їхні елементи."
			]
			old: [
				"  Це нова електрична машина, яка використовує сильні електричні струми для розділення матеріалів на різні частини."
				""
				"  Найважливіше, ви можете &6розділити &bВоду&r &6на два її основні компоненти: &bВодень&r &6та &bКисень&r."
				""
				"  Цей процес називається &6Електроліз&r і працює за допомогою електричного струму для розділення ||іонних сполук|| на їхні елементи."
			]
		}
		quest.2472B23BC0C28C6C.title: {
			new: "Квантове покращення"
			old: "Квантове покращення"
		}"  Парові машини потребують, ну, &bПари&r! Спосіб отримати її — це зробити &bПаровий котел&r! &bПаровий котел&r поступово споживатиме майже будь-яке &6паливо&r, яке ви дасте для нагрівання. Коли він досягне достатньо високої температури, він почне виробляти &bПару&r, за умови, що у його &6внутрішньому резервуарі&r є &bВода&r; інакше ви просто витрачатимете паливо."
				""
				"  Або ви можете помістити &bВідро води&r у &bПіч&r, щоб отримати &bВідро пари&r. У цьому світі здається, що ємності для рідин утримують будь-яку рідину всередині, зберігаючи температуру, прив'язану до замкненої ємності; тому не хвилюйтеся, що вона конденсується у воду або витече. З &bПарою&r до котла ви можете зробити &bКомпресор&r, щоб заощадити на &bБронзових пластинах&r."
				""
				"  Це може здатися трохи дорогим на даний момент, але пам'ятайте, що ви можете практично потроїти кількість своєї руди, використовуючи &bКовальський молот&r. Не кажучи вже про те, що з часом, коли у вас з'являться перші дві машини, це стане більш ніж удвічі дешевше, ніж раніше!"
				""
				"  &bКотел&r автоматично почне виробляти та надсилати &bПару&r до сусідніх машин або підключених труб, &6до 8 мілівідер за тік.&r"
				""
				"  Бронзові машини можуть обробляти рецепти лише до 2 одиниць енергії за тік. Ви можете побачити це як \"2 EU/t\" під час використання машин. 1 мілівідро пари дорівнює 1 EU; я, наприклад, дуже радий, що це дуже просте перетворення, тому що я не фанат математики. Як тільки ваш &bКотел&r досягне максимальної температури, він зможе забезпечувати &bПарою&r 4 машини одночасно! Тепер &oце&r гаряче."
			]
			old: [
				"  Парові машини потребують, ну, &bПари&r! Спосіб отримати її — це зробити &bПаровий котел&r! &bПаровий котел&r поступово споживатиме майже будь-яке &6паливо&r, яке ви дасте для нагрівання. Коли він досягне достатньо високої температури, він почне виробляти &bПару&r, за умови, що у його &6внутрішньому резервуарі&r є &bВода&r; інакше ви просто витрачатимете паливо."
				""
				"  Або ви можете помістити &bВідро води&r у &bПіч&r, щоб отримати &bВідро пари&r. У цьому світі здається, що ємності для рідин утримують будь-яку рідину всередині, зберігаючи температуру, прив'язану до замкненої ємності; тому не хвилюйтеся, що вона конденсується у воду або витече. З &bПарою&r до котла ви можете зробити &bКомпресор&r, щоб заощадити на &bБронзових пластинах&r."
				""
				"  Це може здатися трохи дорогим на даний момент, але пам'ятайте, що ви можете практично потроїти кількість своєї руди, використовуючи &bКовальський молот&r. Не кажучи вже про те, що з часом, коли у вас з'являться перші дві машини, це стане більш ніж удвічі дешевше, ніж раніше!"
				""
				"  &bКотел&r автоматично почне виробляти та надсилати &bПару&r до сусідніх машин або підключених труб, &6до 8 мілівідер за тік.&r"
				""
				"  Бронзові машини можуть обробляти рецепти лише до 2 одиниць енергії за тік. Ви можете побачити це як \"2 EU/t\" під час використання машин. 1 мілівідро пари дорівнює 1 EU; я, наприклад, дуже радий, що це дуже просте перетворення, тому що я не фанат математики. Як тільки ваш &bКотел&r досягне максимальної температури, він зможе забезпечувати &bПарою&r 4 машини одночасно! Тепер &oце&r гаряче."
			]
		}
		quest.0ED4263270D37EF6.quest_desc: {
			new: [
				"&eДизельні аксесуари&r"
				""
				"  Існує кілька потужних інструментів та аксесуарів, що працюють на &6дизелі&r, які ви можете використовувати, щоб допомогти собі ще більше розширити свою фабрику. Ось вони:"
				""
				" &#8226; По-перше, це &bДизельний бур&r, значне покращення порівняно з вашим старим паровим буром. Різниця в тому, що з цим ви більше не можете використовувати функцію 3x3, але можете &6перемикатися між Шовковим дотиком та Удачею III&r за допомогою простого натискання shift + права кнопка миші. Чим потужніше паливо в ньому, тим швидше він буде видобувати ресурси."
				""
				" &#8226; По-друге, це &bДизельна бензопила&r. Бензопила має точно таку ж функціональність, як і бур, але вона призначена для зрізання дерев та подібного, замінюючи вашу сокиру."
				""
				" &#8226; По-третє, це &bДизельний реактивний ранець&r. Так, ви не помилилися. Реактивний ранець. Чим &6сильніше паливо&r в ньому, &6тим швидше ви будете літати&r. Використовуйте клавішу \"V\", щоб увімкнути або вимкнути реактивний ранець. Розправте крила і літайте з силою технологій! &oІ трохи палива...&r"
			]
			old: [
				"&eДизельні аксесуари&r"
				""
				"  Існує кілька потужних інструментів та аксесуарів, що працюють на &6дизелі&r, які ви можете використовувати, щоб допомогти собі ще більше розширити свою фабрику. Ось вони:"
				""
				" &#8226; По-перше, це &bДизельний бур&r, значне покращення порівняно з вашим старим паровим буром. Різниця в тому, що з цим ви більше не можете використовувати функцію 3x3, але можете &6перемикатися між Шовковим дотиком та Удачею III&r за допомогою простого натискання shift + права кнопка миші. Чим потужніше паливо в ньому, тим швидше він буде видобувати ресурси."
				""
				" &#8226; По-друге, це &bДизельна бензопила&r. Бензопила має точно таку ж функціональність, як і бур, але вона призначена для зрізання дерев та подібного, замінюючи вашу сокиру."
				""
				" &#8226; По-третє, це &bДизельний реактивний ранець&r. Так, ви не помилилися. Реактивний ранець. Чим &6сильніше паливо&r в ньому, &6тим швидше ви будете літати&r. Використовуйте клавішу \"V\", щоб увімкнути або вимкнути реактивний ранець. Розправте крила і літайте з силою технологій! &oІ трохи палива...&r"
			]
		}
		quest.40148704F9175B05.quest_desc: {
			new: [
				"Переконавшись, що у вас налаштовані гарячі клавіші, &rзатисніть&r shift над частиною &bШолома&r, щоб побачити, яку клавішу потрібно натиснути для активації &5Нічного бачення&r."
				""
				"Зробіть те саме для &bШтанів&r та &bЧобіт&r для &5Прискорення&r та &5Крокового імпульсу&r відповідно."
				""
				"Броню також можна &6Фарбувати&r та &6Оздоблювати&r."
			]
			old: [
				"Переконавшись, що у вас налаштовані гарячі клавіші, &rзатисніть&r shift над частиною &bШолома&r, щоб побачити, яку клавішу потрібно натиснути для активації &5Нічного бачення&r."
				""
				"Зробіть те саме для &bШтанів&r та &bЧобіт&r для &5Прискорення&r та &5Крокового імпульсу&r відповідно."
				""
				"Броню також можна &6Фарбувати&r та &6Оздоблювати&r."
			]
		}
