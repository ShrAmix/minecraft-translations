		quest.4F076E5D6F0BED74.quest_desc: {
			new: [
				"&bЗакляття&r — це комбінація &bгліфів&r."
				""
				"&bГліф Форми&r: лише 1 форма на &bзакляття&r."
				"&8(деякі інструменти зачаровувача додають свою форму автоматично, тому вам не потрібно додавати форму до закляття)&r"
				""
				"&bГліф Посилення&r: 1 або більше на Форму/Ефект."
				""
				"&bГліф Ефекту&r: 1 або більше на закляття."
				""
				"&bВартість закляття&r = &4вартість до знижки&r - &2знижка&r."
				"- &4Вартість до знижки&r: &5сума&r всіх &bгліфів&r."
				"- &2Знижка&r: від &bКільця меншої знижки&r / &bКільця більшої знижки&r."
				""
				"""&8Перевірте &bСторінку 2&8, якщо хочете переконатися, що вартість заклинання — це лише сума гліфів заклинання (без множення)"
				""
				"{@pagebreak}"
				"Перевірте github моду для цих файлів :)"
				""
				"&8- SpellResolver.java для виклику getResolveCost() ⬇"
				""
				"&8- SpellContext.java для виклику getSpell() ⬇"
				""
				"&8- Spell.java для getCost(), що є просто циклом, який проходить через кожен гліф (AbstractSpellPart), отримуючи вартість"
			]
			old: [
				"&bЗаклинання&r — це комбінація &bгліфів&r."
				""
				"&bГліф Форми&r: лише 1 форма на &bзаклинання&r."
				"&8(деякі інструменти чарівника автоматично додають свою форму, тому вам не потрібно додавати форму до заклинання)&r"
				""
				"&bГліф Підсилення&r: 1 або більше на Форму/Ефект."
				""
				"&bГліф Ефекту&r: 1 або більше на заклинання."
				""
				"&bВартість заклинання&r = &4вартість до знижки&r - &2знижка&r."
				"- &4Вартість до знижки&r: &5адитивна сума&r всіх &bгліфів&r."
				"- &2Знижка&r: від &bМалого кільця знижки&r / &bВеликого кільця знижки&r."
				""
				""
				"&8Перевірте &bСторінку 2&8, якщо хочете переконатися, що вартість заклинання — це лише сума гліфів заклинання (без множення)"
				""
				"{@pagebreak}"
				"Перевірте github моду для цих файлів :)"
				""
				"&8- SpellResolver.java для виклику getResolveCost() ⬇"
				""
				"&8- SpellContext.java для виклику getSpell() ⬇"
				""
				"&8- Spell.java для getCost(), що є просто циклом, який проходить через кожен гліф (AbstractSpellPart), отримуючи вартість"
			]
		}
