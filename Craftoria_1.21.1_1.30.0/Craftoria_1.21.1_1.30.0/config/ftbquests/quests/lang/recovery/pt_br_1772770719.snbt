		quest.5A49CB40AC643E67.quest_desc: {
			new: [
				"&bПокращення «Батарея»&f дозволяє використовувати &eенергію&f замість міцності. Жезл матиме здатність накопичувати &eенергію&f і використовувати її для розміщення блоків."
				""
				"Використовуйте &bКовальський стіл&f, щоб застосувати покращення до свого жезла, використовуючи &6мідний блок&f як матеріал."
			]
			old: [
				"&bПокращення «Батарея»&f дозволяє використовувати &eенергію&f замість міцності. Жезл матиме здатність накопичувати &eенергію&f і використовувати її для розміщення блоків."
				""
				"Використовуйте &bКовальський стіл&f, щоб застосувати покращення до свого жезла, використовуючи &6мідний блок&f як матеріал."
			]
		}
		quest.58ED87D90B7F7168.quest_desc: {
			new: [
				"&bПокращення «Ангел»&f дозволяє &6розміщувати&f блок на протилежному боці блоку (або лінії блоків), на який ви дивитеся."
				""
				"Ви також можете &6натиснути правою кнопкою миші&f на порожній простір, щоб розмістити блок у &9повітрі&f. Для цього переконайтеся, що у вас є &6блок у другій руці&f."
				""
				"Використовуйте &bКовальський стіл&f, щоб застосувати покращення до свого жезла, використовуючи &7пір'їну&f як матеріал."
			]
			old: [
				"&bПокращення «Ангел»&f дозволяє &6розміщувати&f блок на протилежному боці блоку (або лінії блоків), на який ви дивитеся."
				""
				"Ви також можете &6натиснути правою кнопкою миші&f на порожній простір, щоб розмістити блок у &9повітрі&f. Для цього переконайтеся, що у вас є &6блок у другій руці&f."
				""
				"Використовуйте &bКовальський стіл&f, щоб застосувати покращення до свого жезла, використовуючи &7пір'їну&f як матеріал."
			]
		}"Ви також можете &6клацнути правою кнопкою миші&f на порожньому місці, щоб поставити блок у &9повітря&f. Щоб зробити це, переконайтеся, що у вас є &6блок у вашій другій руці&f."
				""
				"Використовуйте &bКовальський стіл&f, щоб застосувати покращення до вашої палиці, використовуючи &7перо&f як матеріал."
			]
		}
		quest.1C4ADA8B75FBBED1.quest_subtitle: {
			new: "Може телепортувати вас до вашої особистої точки відродження або до спавну світу."
			old: "Може телепортувати вас до вашої особистої точки відродження або до спавну світу."
		}
