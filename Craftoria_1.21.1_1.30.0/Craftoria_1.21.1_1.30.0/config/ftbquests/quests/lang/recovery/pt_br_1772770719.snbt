		quest.40148704F9175B05.quest_subtitle: {
			new: "Техно-мода!"
			old: "Moda Tecnológica!"
		}
		quest.6EF133E0EC49BC33.quest_desc: {
			new: [
				"  Гнучка, непровідна та міцна. &bГума&r буде важливою частиною кожної електричної машини. Ви можете виготовити її, &6змішавши&r &bПапір&r із &bСинтетичною олією&r або &bСинтетичною гумою&r. Змішайте &bКоксовий порошок&r, який ви зробили, з &bВодою&r у &bЗмішувачі&r, щоб отримати &bСиру синтетичну олію&r. Використовуйте &bПарову доменну піч&r для виробництва цих двох рідин. &bСинтетичну гуму&r отримати важче, &6але вона дасть більше гуми на аркуш паперу&r."
				""
				"  Пам'ятайте, що в довгостроковій перспективі вам знадобиться &oбагато&r &bГумових листів&r, тому вам доведеться робити їх постійно. Зауважте, що ви можете використовувати &bДеревину&r, щоб &6подрібнити&r її на &bДеревну масу&r, яку потім можна перетворити на &bПапір&r з високим виходом продукції."
			]
			old: [
				"  Flex00edvel, n00e3o condutora e forte. A &bBorracha&r ser00e1 uma parte importante de toda m00e1quina el00e9trica. Voc00ea pode produzi-la &6misturando&r &bPapel&r com &b00d3leo Sint00e9tico&r ou &bBorracha Sint00e9tica&r. Misture o &bP00f3 de Coque&r que voc00ea fez com &b00c1gua&r em um &bMisturador&r para produzir &b00d3leo Sint00e9tico Bruto&r. Use um &bAlto-forno a Vapor&r para produzir esses dois fluidos. A &bBorracha Sint00e9tica&r 00e9 mais dif00edcil de obter, &6mas render00e1 mais borracha por folha de papel&r."
				""
				"  Lembre-se que voc00ea precisar00e1 de &omuitas&r &bFolhas de Borracha&r a longo prazo, ent00e3o voc00ea precisar00e1 faz00ea-las constantemente. Note que voc00ea pode usar &bMadeira&r para &6moer&r e transformar em &bPolpa de Madeira&r, que pode ent00e3o ser transformada em &bPapel&r com um alto rendimento."
			]
		}
		quest.21EDEEE1A1B82B53.quest_desc: {
			new: ["  Переробляючи &bІридієву руду&r зі своїх &bТитанових бурів&r, ви можете почати виробляти &bІридієвий порошок&r, який знадобиться для &bНадпровідного порошку&r — матеріалу, здатного до надзвичайної передачі та зберігання енергії."]
			old: ["  Processando o &bMinério de Irídio&r de suas &bBrocas de Titânio&r, você pode começar a produzir &bPó de Irídio&r, que será necessário para o &bPó de Supercondutor&r, um material capaz de extraordinária transferência e armazenamento de energia."]
		}
		quest.7533E0212EFE326D.quest_subtitle: {
			new: "Якщо розмістити перед &eвуликом&r, &6мед&r буде видобуватися у &bрідкій формі&r."
			old: "Quando colocado virado para uma &bcolmeia&r, o &6mel&r ser00e1 extra00eddo na &bforma l00edquida&r."
		}
		quest.5C8D7BD3DA61109F.quest_desc: {
			new: [
				"  Ви досягли електричної версії &bКар'єру&r! Він дозволяє видобувати руду ще швидше, ніж раніше, &oі&r надає більше варіантів бурів."
				""
				"  &6Тепер ви зможете використовувати бури зі &bСталі&r&6, &bЗолота&r&6, &bНержавіючої сталі&r&6 та &bТитану&r, щоб завершити решту видобутку руди та справді виконати мою обіцянку ніколи більше не копати руду вручну!"
				""
				"  Структура &oточно&r така ж, як у &bПарового кар'єру&r, за винятком потреби в &bЛюку енергоспоживання&r замість &bЛюка для рідини&r. &6Переконайтеся, що ви автоматизували свої &bБронзові бури&r&r зараз, інакше підтримувати роботу кар'єрів буде справжнім випробуванням."
			]
			old: [
				"  Você chegou à versão elétrica da &bPedreira&r! Esta permite que você produza minérios a uma taxa ainda mais rápida do que antes &oe&r te dá mais opções de brocas."
				""
				"  &6Agora você poderá usar brocas de &bAço&r&6, &bOuro&r&6, &bAço Inoxidável&r&6 e &bTitânio&r para finalizar o resto da produção de minério e realmente cumprir minha promessa de nunca mais precisar minerar minérios!"
				""
				"  A estrutura é &oexatamente&r a mesma da &bPedreira a Vapor&r, exceto por precisar de uma &bEscotilha de Entrada de Energia&r em vez de uma &bEscotilha de Entrada de Fluido&r.&6 Certifique-se de ter automatizado suas &bBrocas de Bronze&r&r até agora, ou será um pé no saco manter suas pedreiras funcionando."
			]
		}
		quest.0AC7D844C55119E1.quest_desc: {
			new: [
				"  Це не &bГриф-ключ&r, але краще сподіватися, що в майбутньому ви зможете рухатися як він."
				""
				"  Використовуючи &bГайковий ключ&r, ви можете &6обертати&r &oмайже&r &bбудь-яку машину&r, натиснувши &6праву кнопку миші&r, і &rзабирати&r &oмайже&r будь-яку &bтрубу&r, &bрідинну&r чи іншу."
				""
				"  Ви можете &6затиснути Shift і натиснути правою кнопкою миші&o на &bмашину&r, щоб &6налаштувати&r &bсторону виводу&r. Коли ви &6тримаєте&r &bГайковий ключ&r, ви можете &6навести курсор&r на будь-яку сторону &bмашини&r і побачите своєрідну &bсітку&r. &6Shift + правий клік&o по &bцентральному квадрату&r встановить &bсторону виводу&r на ту сторону, де знаходиться &bсітка&r. Виконання цього на прямокутниках &6встановить вивід&r на сторону під кутом &690&r градусів відносно обраного кута, що дозволяє &6налаштування&r у важкодоступних місцях. Нарешті, маленькі &bквадрати&r у кожному куті встановлять вивід на &bпротилежну&r сторону від сітки."
				""
				"  Пам'ятайте, ви не можете &6зламати&r машину за допомогою &bГайкового ключа&r, це ПРИЗВЕДЕ до її &6знищення&r, і ви &6не&r отримаєте її назад. Замість цього просто використовуйте свою вірну &bКирку&r."
			]
			old: [
				"  Esta não é uma &bChave Inglesa de Macaco&r, mas é melhor você esperar poder se mover como um no futuro."
				""
				"  Usando uma &bChave Inglesa&r, você pode &6girar&r &oquase&r &bqualquer máquina&r &6clicando com o botão direito&6 e &rpegar&r&o quase&r qualquer &bcano&r, de &bfluido&r ou &bnão&r."
				""
				"  Você pode &6clicar com shift e botão direito&o em uma &bmáquina&r para &6configurar&r o &blado de saída&r. Quando você está &6segurando&r a &bChave Inglesa&r, pode &6passar o mouse&r sobre qualquer face da &bmáquina&r e obterá uma &bgrade&r de certa forma. &6Clicar com shift e botão direito&o no &bquadrado do meio&r definirá a &bface de saída&r para o lado em que a &bgrade&r está. Fazer isso nos retângulos &6colocará a saída&r na face a &690&r graus em relação ao canto eleito para permitir a &6configuração&r em espaços de difícil acesso. Finalmente, os pequenos &bquadrados&r em cada canto definirão a saída para o lado &boposto&r da grade."
				""
				"  Lembre-se, você não pode &6quebrar&r a máquina usando a &bChave Inglesa&r, ela VAI &6destruí-la&r e você &6não&r a terá de volta. Apenas use sua fiel &bPicareta&r em vez disso."
			]
		}
		quest.268B0F87CC431A51.quest_desc: {
			new: ["- Потрібен &bКорпус&r для рівня кабелю для конвертації (&eНН&r за замовчуванням)."]
			old: ["- Precisa de &bInvólucro&r para o nível do cabo de onde converter (&eLV&r por padrão)."]
		}
		quest.215606B3A894512E.quest_desc: {
			new: [
				"  Ви бачите ті відсотки на кожній руді на виходах кар'єру?"
				""
				"  Це &oіндивідуальні&r відсотки. &6Кожна руда має свій власний шанс випадіння&r."
				""
				"  Якщо ви поставите бронзовий люк виводу предметів, ви отримаєте лише одну руду, але шанс випадіння іншої руди все одно існує, тому вона може бути втрачена, якщо для неї немає місця."
				""
				"  &6Встановіть кілька люків виводу предметів, бажано сталевих, щоб збільшити кількість можливих виходів.&r"
			]
			old: [
				"  Você vê aquelas porcentagens em cada minério nas saídas da pedreira?"
				""
				"  Essas são porcentagens &oindividuais&r. &6Cada minério tem sua própria chance individual&r. "
				""
				"  Se você colocar uma escotilha de saída de item de bronze, você só obterá um minério, mas a chance de outro minério ser produzido ainda existe e, portanto, pode ser perdido se não houver espaço para ele."
				""
				"  &6Coloque múltiplas escotilhas de saída de item, preferencialmente de aço, para aumentar o máximo de saídas possíveis.&r"
			]
		}
		quest.18DED87B3E23350F.quest_subtitle: {
			new: "Може виконувати рецепти будь-якої електричної мультиблочної машини, що подаються їй партіями."
			old: "Pode executar receitas de qualquer máquina multibloco elétrica fornecida a ele em lotes."
		}
	}
	"chapters/Theurgy.snbt": {
		quest.55391FF509DA53A5.title: {
			new: "&dЛаскаво просимо до Theurgy"
			old: "&dBem-vindo à Teurgia"
		}
		quest.5B9BFD4F72E79F5B.quest_desc: {
			new: ["Найрідкісніші з усіх, &dЦінні&r ресурси часто мають виняткову цінність."]
			old: ["Os mais raros de todos, os recursos &dPreciosos&r são frequentemente de valor excepcional."]
		}
		quest.3DC47060EEAB8975.quest_desc: {
			new: ["&bМасив реформації&r — це набір машин, здатних ефективно &6виробляти нескінченну кількість&r певної &bСірки&r, використовуючи інші типи &bСірки&r заданого &aрівня&r та &aтипу&r."]
			old: ["A &bMatriz de Reforma&r é um conjunto de máquinas capazes de &6produzir eficazmente quantidades infinitas&r de um determinado &bEnxofre&r, usando outros tipos de &bEnxofre&r do mesmo &anível&r e &atipo&r."]
		}
		quest.7DD81584380EE8F7.quest_desc: {
			new: ["Ця &bпаличка&r використовується для взаємодії з &6Меркуріальною логістикою&r."]
			old: ["Esta &bvarinha&r 00e9 usada para interagir com a &6Log00edstica Mercurial&r."]
		}
		quest.51E386BC7692D06C.quest_desc: {
			new: ["Щоб &6налаштувати&r &6Меркуріальну логістичну мережу&r, ці &bДроти&r повинні використовуватися для &6з'єднання&r входів і виходів. &bЗ'єднувальні вузли&r дозволяють кільком дротам сходитися в одній точці, якщо це необхідно."]
			old: ["Para &6estabelecer&r uma &6rede de Logística Mercurial&r, estes &bFios&r devem ser usados para &6conectar&r entradas e saídas. &bNós de Conexão&r permitem que múltiplos fios convirjam para um ponto, se necessário."]
		}
		quest.077658D04D0D4AB3.quest_desc: {
			new: [
				"&bРезервуар нашатирного спирту&r повинен бути &6розміщений під&r &bАкумулятором нашатирного спирту&r. Разом ці два пристрої створюватимуть &dРозчин нашатирного спирту&r з &9Води&r."
				""
				"Якщо ви хочете отримати розчин &aшвидше&r, ви можете &6подати&r в Акумулятор &bкристали нашатирного спирту&r, щоб значно прискорити процес."
			]
			old: [
				"O &bTanque de Sal Amoníaco&r deve ser &6colocado abaixo&r do &bAcumulador de Sal Amoníaco&r. Em conjunto, esses dois dispositivos criarão &dsolvente de Sal Amoníaco&r a partir de &9Água&r."
				""
				"Se você desejar solvente &amais rápido&r, pode &6fornecer&r ao Acumulador &bcristais de Sal Amoníaco&r para acelerar muito o processo."
			]
		}
		quest.0E30CFA6C5B58BEA.quest_desc: {
			new: ["Цей &bРезервуар&r дозволяє конвертувати вашу &bАлхімічну селітру&r з одного рівня на інший."]
			old: ["Este &bTanque&r permite que você converta seu &bNitro Alquímico&r de um nível para outro."]
		}
		quest.6DA3C5DEE0F6438D.quest_desc: {
			new: ["Ця паличка вже налаштована на пошук &dЦінного&r матеріалу."]
			old: ["Esta Vara j00e1 vem sintonizada para localizar um material &dPrecioso&r."]
		}
		quest.02D3AFC713077502.quest_desc: {
			new: ["Робить процеси ферментації більш &6ефективними&r. &aМожливо, ви захочете автоматизувати це&r."]old: ["Робить процеси ферментації більш &6ефективними&r. &aМожливо, ви захочете автоматизувати це&r."]
		}
		quest.58E5ADE9A50BDF29.quest_desc: {
			new: ["Цей жезл попередньо налаштований на пошук &bДрузи аметисту&r. &bАметист&r широко використовується в алхімії та &6необхідний&r для кращих Жезлів віщування."]
			old: ["Цей жезл попередньо налаштований на пошук &bАметисту, що росте&r. &bАметист&r широко використовується в алхімії та &6необхідний&r для кращих Жезлів віщування."]
		}
		quest.367A013744D689E4.quest_desc: {
			new: [
				"Ця машина дозволяє &6теплу&r &6очищати&r матерію в &bАлхімічну ртуть&r."
				""
				"На даний момент вам потрібно розмістити &bПіромантичну жаровню&r під Дистилятором і &6заправити її&r паливом для печі, щоб забезпечити тепло. &aПаливо горить удвічі довше, ніж у звичайній печі&r."
			]
			old: [
				"Ця машина дозволяє &6теплу&r &6очищати&r матерію в &bАлхімічну ртуть&r."
				""
				"На даний момент вам потрібно розмістити &bПіромантичну жаровню&r під Дистилятором і &6заправити її&r паливом для печі, щоб забезпечити тепло. &aПаливо горить удвічі довше, ніж у звичайній печі&r."
			]
		}
		quest.5C98D9127F4CEB74.quest_desc: {
			new: [
				"Існує кілька видів &bСолі&r, кожен з яких використовується для створення &6різних ресурсів&r у кінцевому результаті."
				""
				"Деякі солі можна &6кальцинувати&r повторно в інші види."
			]
			old: [
				"Існує кілька видів &bСолі&r, кожен з яких використовується для створення &6різних ресурсів&r у кінцевому результаті."
				""
				"Деякі солі можна &6кальцинувати&r повторно в інші види."
			]
		}
		quest.508E110FF82365E3.quest_desc: {
			new: ["&bВставники&r та &bВитягувачі&r &6переміщують предмети&r відповідно всередину та назовні контейнерів &6Меркуріальної логістичної мережі&r."]
			old: ["&bВставники&r та &bВитягувачі&r &6переміщують предмети&r відповідно всередину та назовні контейнерів &6Меркуріальної логістичної мережі&r."]
		}
		quest.376DD70A2C14F9A9.quest_desc: {
			new: ["&aЗвичайні&r ресурси трохи рідші за їхні &8Рясні&r аналоги, але їх все ще відносно легко знайти."]
			old: ["&aЗвичайні&r ресурси трохи рідші за їхні &8Рясні&r аналоги, але їх все ще відносно легко знайти."]
		}
		quest.7A6C1605F32F695F.quest_desc: {
			new: [
				"Ця піч дозволяє &6кальцинувати&r різноманітні матеріали в &bАлхімічну сіль&r."
				""
				"На даний момент вам потрібно розмістити &bПіромантичну жаровню&r під піччю і &6заправити її&r паливом для печі, щоб забезпечити тепло. &aПаливо горить удвічі довше, ніж у звичайній печі&r."
			]
			old: [
				"Ця піч дозволяє &6кальцинувати&r різноманітні матеріали в &bАлхімічну сіль&r."
				""
				"На даний момент вам потрібно розмістити &bПіромантичну жаровню&r під піччю і &6заправити її&r паливом для печі, щоб забезпечити тепло. &aПаливо горить удвічі довше, ніж у звичайній печі&r."
			]
		}
		quest.1FF9FB01DBE735FC.quest_desc: {
			new: [
				"Природу &bСірки&r можна &6змінити&r. Це основа трансмутації."
				""
				"Цей &bРезервуар&r, при отриманні правильних інгредієнтів, здатний &6перетворити&r Сірку на набагато більш податливий стан — &bАлхімічну селітру&r."
			]
			old: [
				"Природу &bСірки&r можна &6змінити&r. Це основа трансмутації."
				""
				"Цей &bРезервуар&r, при отриманні правильних інгредієнтів, здатний &6перетворити&r Сірку на набагато більш податливий стан — &bАлхімічну селітру&r."
			]
		}
		quest.2B2D3B338662F02C.quest_desc: {
			new: ["Цей особливо чистий варіант золота використовується для &6зміни&r &aрівня&r &bСірки&r."]
			old: ["Цей особливо чистий варіант золота використовується для &6зміни&r &aрівня&r &bСірки&r."]
