		quest.7277A0413086D71A.quest_desc: {
			new: ["&6Клацніть правою кнопкою миші&f на &bФлюїксний блок&f з &bНасінням ентропії&f, щоб перетворити його на &bЕнтропійну флюїксну друзу&f."]
			old: ["&6Клацніть правою кнопкою миші&f на &bФлюїксний блок&f з &bНасінням ентропії&f, щоб перетворити його на &bЕнтропійну флюїксну друзу&f."]
		}
		quest.3009C3939976FBD2.quest_desc: {
			new: ["&bТермінал крафту&f — це покращена версія &bТерміналу&f. Він дозволить вам створювати предмети, маючи доступ до всіх ваших ресурсів."]
			old: ["&bТермінал крафту&f — це покращена версія &bТерміналу&f. Він дозволить вам створювати предмети, маючи доступ до всіх ваших ресурсів."]
		}
		quest.35CA9D458FD5D791.quest_desc: {
			new: [
				"&bРозширений ME-термінал доступу до шаблонів&f надає 2 додаткові функції:"
				""
				"По-перше, він додає рядок пошуку та підсвічує те, що ви шукаєте, у &bТерміналі шаблонів&f."
				""
				"По-друге, він надає &aпідсвітку у світі&f того, який &bПостачальник шаблонів&f заблокований під час виконання великих завдань крафту."
			]
			old: [
				"&bРозширений ME-термінал доступу до шаблонів&f надає 2 додаткові функції:"
				""
				"По-перше, він додає рядок пошуку та підсвічує те, що ви шукаєте, у &bТерміналі шаблонів&f."
				""
				"По-друге, він надає &aпідсвітку у світі&f того, який &bПостачальник шаблонів&f заблокований під час виконання великих завдань крафту."
			]
		}
		quest.2F6C16939D136BF0.quest_desc: {
			new: ["&bПлощина анігіляції&f буде &6ламати блоки&f та &6збирати&b предмети&f безпосередньо перед собою."]
			old: ["&bПлощина анігіляції&f буде &6ламати блоки&f та &6збирати&b предмети&f безпосередньо перед собою."]
