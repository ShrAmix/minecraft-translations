		quest.3357A8B614D477B6.quest_desc: {
			new: [
				"  Нова машина, молодша сестра &bПакувальника&r! Ця може бути виготовлена тільки зі сталі; їй дійсно потрібна ця додаткова міцність."
				""
				"  &6Розпакувальник може виконувати прості операції для вас, наприклад, перетворювати порошки на дрібні порошки&r. Перевірте свій EMI для отримання додаткових рецептів."
			]
			old: [
				"  Нова машина, молодша сестра &bПакувальника&r! Ця може бути виготовлена тільки зі сталі; їй дійсно потрібна ця додаткова міцність."
				""
				"  &6Розпакувальник може виконувати прості операції для вас, наприклад, перетворювати порошки на дрібні порошки&r. Перевірте свій EMI для отримання додаткових рецептів."
			]
		}
		quest.2472B23BC0C28C6C.quest_desc: {
			new: [
				"  Пам'ятаєте ті \"тіки\", про які ми говорили? Як кожен з них є однією двадцятою секунди?"
				""
				"  Що ж, ви досягли &oцього&r рівня обробки машини. За наявності достатньої кількості енергії, кожен рецепт машини, незалежно від того, яка це машина, якщо вона електрична, займатиме лише один тік."
				""
				"  Майте на увазі, що кількість енергії, яку можуть споживати ці машини, буде величезною, тому використовуйте їх з розумом."
			]
			old: [
				"  Пам'ятаєте ті \"тіки\", про які ми говорили? Як кожен з них є однією двадцятою секунди?"
				""
				"  Що ж, ви досягли &oцього&r рівня обробки машини. За наявності достатньої кількості енергії, кожен рецепт машини, незалежно від того, яка це машина, якщо вона електрична, займатиме лише один тік."
				""
				"  Майте на увазі, що кількість енергії, яку можуть споживати ці машини, буде величезною, тому використовуйте їх з розумом."
			]
		}
		quest.2FB2FE782B1103D6.quest_desc: {
			new: [
				"  Ваш другий мультиблок: &bПарова доменна піч&r! Вона майже така сама, з тією лише різницею, що вона трохи вища і використовує &bВогнетривку цеглу&r замість звичайної &bЦегли&r."
				""
				"  Використовуйте той самий трюк з &bГайковим ключем&r, &6щоб побачити розміщення блоків&r, і не забувайте, що цього разу вам знадобиться лише &63 люки&r. Вони такі ж, як і в &bКоксовій печі&r, без люка для виходу рідини, принаймні поки що!"
				""
				"  Ви будете використовувати цю &bПарову доменну піч&r, щоб зробити свою першу &bСталь&r!"
			]
			old: ["  Ваш другий мультиблок: &bПарова доменна піч&r! Це майже те саме, з тією лише різницею, що вона на один блок вища і використовує &bВогнетривку цеглу&r замість звичайної &bЦегли&r."
				""
				"  Використовуйте той самий трюк із &bГайковим ключем&r, &6щоб побачити розміщення блоків&r, і не забувайте, що цього разу вам знадобиться лише &63 люки&r. Вони такі ж, як у &bКоксової печі&r, принаймні поки що без люка для виведення рідини!"
				""
				"  Ви будете використовувати цю &bПарову доменну піч&r для створення своєї першої &bСталі&r!"
			]
		}
