		quest.7A6C1605F32F695F.quest_subtitle: {
			new: "Це просто піч?"
			old: "Це просто піч?"
		}
		quest.3B117FA99DD7558F.quest_desc: {
			new: ["Можливо, ви захочете &6автоматизувати&r виробництво цього."]
			old: ["Можливо, ви захочете &6автоматизувати&r виробництво цього."]
		}
		quest.5143D5FD55C819CA.quest_desc: {
			new: [
				"На відміну від скляного Жезла віщування, цей &3Попередньо налаштований жезл&r &6вже налаштований&r на тип блоку, вказаний &bСіркою&r, використаною при його створенні."
				""
				"В іншому він поводиться так само, як і скляний Жезл віщування. Цей конкретний жезл був налаштований на пошук &8Рясного&r матеріалу."
			]
			old: [
				"На відміну від скляного Жезла віщування, цей &3Попередньо налаштований жезл&r &6вже налаштований&r на тип блоку, вказаний &bСіркою&r, використаною при його створенні."
				""
				"В іншому він поводиться так само, як і скляний Жезл віщування. Цей конкретний жезл був налаштований на пошук &8Рясного&r матеріалу."
			]
		}
		quest.2F7A213261682E1B.quest_desc: {
			new: [
				"&bКазан для розрідження&r &6вимочує&r ресурси в &dрозчиннику&r для отримання з них &bСірки&r. Для реакції потрібне &6тепло&r."
				""
				"Зауважте, що деякі ресурси, як-от руди, &aдають більше однієї сірки&r."
			]
			old: [
				"&bКазан для розрідження&r &6вимочує&r ресурси в &dрозчиннику&r для отримання з них &bСірки&r. Для реакції потрібне &6тепло&r."
				""
				"Зауважте, що деякі ресурси, як-от руди, &aдають більше однієї сірки&r."
			]
		}
		quest.392EC503FD52E32A.quest_desc: {
			new: ["Існує різноманітність типів &bСірки&r, розділених на багато &6рівнів&r."]
			old: ["Існує різноманітність типів &bСірки&r, розділених на багато &6рівнів&r."]
