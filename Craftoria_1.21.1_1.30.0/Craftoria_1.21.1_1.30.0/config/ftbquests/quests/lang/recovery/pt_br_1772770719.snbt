		quest.73DF4B8186890BFE.quest_desc: {
			new: [
				"- &bРеле джерела: Збирач&r"
				"Забирає все, &4крім дозволеного списку&r."
				"&8(все ще потрібно вказати, куди відправляти)"
				""
