	"chapters/Occultism.snbt": {
		quest.7A7F75393420DB4C.quest_desc: {
			new: ["Може бути клопітно збирати &bсаджанці Іншого Світу&r — оскільки вони нестабільні, ви можете бачити та збирати їх лише під дією Третього Ока."
				""
				"Цей дух обміну вирішує цю невелику проблему, &6обмінюючи&r ваші &bнестабільні саджанці&r на інші, для взаємодії з якими не потрібне &bТретє Око&r."
			]
			old: [
				"Pode ser um inc00f4modo colher &bmudas de Otherwood&r - como s00e3o inst00e1veis, voc00ea s00f3 pode v00ea-las e colh00ea-las sob o Terceiro Olho."
				""
				"Este esp00edrito de troca resolve esse pequeno problema, &6trocando&r suas &bmudas inst00e1veis&r por outras que n00e3o precisam do &bTerceiro Olho&r para interagir."
			]
		}
		task.6C6C366D034AF5C7.title: {
			new: "Закликати Торговця саджанцями Іншого Світу"
			old: "Evocar um Comerciante de Mudas do Outro Mundo"
		}
		quest.4F0F24F222AA434A.quest_desc: {
			new: ["&eЖовта крейда&r трохи потужніша за звичайну Білу. Вона використовується переважно для ритуалів Одержимості."]
			old: ["O &eGiz&r Amarelo é marginalmente mais poderoso que o simples Branco. É usado principalmente para rituais de Possessão."]
		}
		quest.7A5466B9F5C79793.quest_desc: {
			new: ["&bФоліоти&r — це перший тип духів, з якими ви працюватимете, і вони найменш небезпечні."]
			old: ["Os &bFoliot&r s00e3o o primeiro tipo de esp00edrito com o qual voc00ea trabalhar00e1, e o menos perigoso."]
		}
		quest.1E6ADDD42C99274D.quest_subtitle: {
			new: "Ці багатства всі мої"
			old: "Estas riquezas são todas minhas"
		}
		quest.67ACD099BDB606FA.quest_desc: {
			new: [
				"З цими &bОкулярами&r на очах ви бачитимете так, ніби у вас є &bТретє Око&r."
				""
				"Однак ви все одно не зможете збирати блоки без спеціалізованого інструменту..."
			]
			old: [
				"Com estes &bÓculos&r sobre seus olhos, você verá como se tivesse o &bTerceiro Olho&r."
				""
				"Você ainda será incapaz de colher blocos, no entanto, sem uma ferramenta especializada...."
			]
		}
		task.52C834FDFA57A474.title: {
			new: "Закликати Фамільяра Спостерігача"
			old: "Evocar um Familiar Observador"
		}
		quest.5C56A0938613CBC0.quest_desc: {
			new: [
				"Цей метал можна &6знайти&r у &bНедері&r, замаскований під Недеріт."
				""
				"&6Погляд&r крізь &bТретє Око&r розкриває його справжню форму. Можливо, ви захочете взяти з собою &bЛозохідну палицю&r."
			]
			old: [
				"Este metal pode ser &6encontrado&r no &bNether&r, disfarçado de Netherrack."
				""
				"&6Ver&r através do &bTerceiro Olho&r revela sua verdadeira forma. Você pode querer trazer uma &bVareta de Adivinhação&r."
			]
		}
		quest.44B09234621BDBA6.quest_subtitle: {
			new: "Кирка Демонічного сну"
			old: "Picareta do Sonho do Demônio"
		}
		quest.4EF9C36CED1EDDC4.quest_desc: {
			new: ["&bПір'я&r, &bКниги&r та &bЧорний барвник&r можна &6перетворити&r на &5Духовний вогонь&r, щоб отримати версії, більш сприйнятливі до роботи з Духами."]
			old: ["&bPenas&r, &bLivros&r e &bCorante Preto&r podem ser &6transformados&r em &5Fogo Espiritual&r para obter versões mais receptivas para trabalhar com Espíritos."]
		}
		task.4137D2B088325C60.title: {
			new: "Закликати Фоліота-транспортера"
			old: "Evocar um Transportador Foliot"
		}
		quest.4E026831A66E0A42.quest_desc: {
			new: ["&1Синя крейда&r дозволяє закликати та ув'язнювати Марідів."]
			old: ["O &1Giz&r Azul permite invocar e vincular Marids."]
		}
		quest.5BDEC0D157A43D9E.quest_desc: {
			new: ["&5Фіолетова крейда&r є звичайною для ритуалів, що ув'язнюють духів в об'єктах."]
			old: ["O Giz &5Roxo&r é comum em rituais que prendem espíritos em objetos."]
		}
		quest.4EF9C36CED1EDDC4.quest_subtitle: {
			new: "Правильний ритуал для правильного письменника"
			old: "O Rito Certo do Escritor Correto"
		}
		quest.15325B16AFE33D5C.quest_desc: {
			new: ["Вам знадобиться &bСало&r для виготовлення належних окультних свічок. &6Вбивство великих тварин&r будь-яким &bножем&r дозволить зібрати трохи."]
			old: ["Você precisará de &bSebo&r para fazer velas ocultistas adequadas. &6Matar animais maiores&r com qualquer &bfaca&r coletará um pouco."]
		}
		quest.656CBEFEE317E2E7.quest_subtitle: {
			new: "Скільки місця може знадобитися окультисту?"
			old: "De quanto espaço um ocultista poderia precisar?"
		}
		quest.4303A1A434C07540.quest_desc: {
			new: [
				"Духи-доглядачі можуть &6підбирати&r предмети та &6складати їх&r у &bконтейнери&r."
				""
				"Вони особливо корисні для збору продуктів інших духів."
			]
			old: [
				"Espíritos zeladores podem &6coletar&r itens e &6depositá-los&r em &brecipientes&r."
				""
				"Eles são particularmente úteis para reunir os produtos de outros espíritos."
			]
		}
		quest.7723EF8CE359646F.quest_desc: {
			new: ["Цей дух принесе назад &bвипадкові руди&r — включаючи &bглибинні руди&r."]
			old: ["Este esp00edrito trar00e1 de volta &bmin00e9rios aleat00f3rios&r - incluindo &bmin00e9rios de ardosiabissal&r."]
		}
		quest.2A1319D8CFE3653B.quest_desc: {
			new: [
				"За замовчуванням обсяг сховища Актуатора не найбільший."
				""
				"Ви можете вирішити цю проблему, використовуючи &bСтабілізатори&r. Вони &6стабілізують&r зв'язок Актуатора з виміром сховища, дозволяючи йому &6зберігати все більше&r і більше."
			]
			old: [
				"Por padrão, o espaço de armazenamento do Atuador não é dos maiores."
				""
				"Você pode resolver esse problema usando &bEstabilizadores&r. Eles irão &6estabilizar&r ainda mais a conexão do Atuador com a dimensão de armazenamento, permitindo que ele &6armazene mais&r e mais."
			]
		}
		quest.38E1A4E0A032E377.quest_desc: {
			new: [
				"&bСтабільні червоточини&r діють як точки доступу, що можна розмістити для &bАктуатора сховища&r. Предмети можна спрямовувати в них і з них, але рекомендується використовувати духа-транспортера при вилученні через проблеми з лагами."
				""
				"&bАксесуар сховища&r — це простий пристрій, який дозволяє &6взаємодіяти зі своїм сховищем&r здалеку. Він не має обмежень по дальності чи виміру, але актуатор повинен знаходитися в завантаженому чанку."
			]
			old: [
				"&bBuracos de Minhoca Estáveis&r agem como pontos de acesso posicionáveis para o &bAtuador de Armazenamento&r. Itens podem ser inseridos e retirados deles, mas é recomendado usar um espírito transportador ao extrair deles para evitar lag."
				""
				"O &bAcessor de Armazenamento&r é um dispositivo simples que permite que você &6interaja com seu armazenamento&r de longe. Ele não tem limite de alcance nem de dimensão, mas o atuador deve estar carregado (chunk loaded)."
			]
		}
		quest.448D7A215A175817.quest_desc: {
			new: [
				"&bОкультизм&r — це мистецтво, засноване на &6закликанні Духів&r для виконання роботи за вас."
				""
				"Ви будете &6будувати та вдосконалювати&r різні &bритуальні пентаклі&r. Через них ви будете &6закликати та наказувати&r — а іноді й &6битися&r — з різноманітними &bдухами&r."
				""
				"Духи можуть &6транспортувати&r &bпредмети&r для вас, &6виробляти та обробляти&r &bРуди&r, надавати бафи, захищати вас тощо."
				""
				"Читати &bСловник Духів&r &lнастійно рекомендується&r, оскільки він надає набагато повніший посібник, ніж я коли-небудь зможу, особливо щодо багатьох видів &bКрейди&r."
				""
				"Готові стати окультистом?"
			]
			old: [
				"&bOccultism&r é uma arte baseada em &6invocar Espíritos&r para realizar trabalhos para você."
				""
				"Você irá &6construir e refinar&r vários &bpentáculos rituais&r. Através deles, você irá &6invocar e comandar&r - e às vezes &6lutar&r - com uma variedade de &bespíritos&r."
				""
				"Espíritos podem &6transportar&r &bitens&r para você, &6produzir e processar&r &bMinérios&r, fornecer buffs e protegê-lo, e mais."
				""
				"Ler o &bDicionário de Espíritos&r é &laltamente recomendado&r, pois fornece um guia muito mais completo do que eu jamais fornecerei, especialmente em relação aos muitos &bGizes&r."
				""
				"Pronto para ser um ocultista?"
			]
		}
		quest.359A7C4C3C5E734F.quest_desc: {
			new: ["Безголовий Щуролюд краде голови мобів, вбитих поруч із ним. Потім він надає вам &6бонус до шкоди&r проти цього типу мобів."]
			old: ["O Homem-Rato sem Cabeça rouba as cabeças dos mobs mortos perto dele. Ele, então, fornece um &6bônus de dano&r contra aquele tipo de mob."]
		}
		task.0020C1E77C424CB0.title: {
			new: "Погляд на Духовний вогонь"
			old: "Olhe para o Spiritfire"
		}
		task.11CC52C63FF1FDE8.title: {
			new: "Закликати Фамільяра Бобра"
			old: "Evocar um Familiar Castor"
		}
		task.141B9E891675C4BB.title: {
			new: "Закликати Фамільяра Химеру"
			old: "Evocar um Familiar Quimera"
		}
		quest.7D36F35D54BD7812.quest_desc: {
			new: [
				"Ви можете час від часу знаходити &bНасіння Демонічного сну&r, ламаючи низьку траву."
				""
				"Коли воно виросте, його можна &6зібрати&r для отримання &bПлоду Демонічного сну&r, який має багато застосувань в окультних справах."
			]
			old: [
				"Voc00ea pode ocasionalmente encontrar &bsementes do Sonho do Dem00f4nio&r quebrando grama baixa."
				""
				"Quando cultivada, ela pode ser &6colhida&r para obter a &bfruta do Sonho do Dem00f4nio&r, que tem muitos usos em assuntos ocultos."
			]
		}
		quest.3A5A59C7AEA670C7.quest_desc: {
			new: ["&bКоло Авіара&r — це перший пентакль, який ви підготуєте. Він призначений для &6закликання Фоліотів&r. &6Зверніться&r до &bСловника Духів&r, щоб дізнатися, як його зібрати."]
			old: ["O &bCírculo de Aviar&r é o primeiro pentáculo que você irá preparar. Ele serve para &6invocar Foliot&r. &6Consulte&r o &bDicionário de Espíritos&r para saber como montá-lo."]
		}
