		quest.6BD625E5CA469914.quest_desc: {
			new: [
				"  Останній крок перед повним розгоном, найм'якше, але корисне оновлення, єдине і неповторне &bВисокотехнологічне покращення&r!"
				""
				"  Кожне з них, додане до вашої машини, &6збільшує її максимальне споживання енергії на 512 eu/t&r. Лише одне з цих див підштовхне вашу машину до місяця!"
				""
				"  Використовуйте їх з розумом, вони досить дорогі у виготовленні."
			]
			old: [
				"  O 00faltimo passo antes do overclock total, a melhoria mais contida, mas ben00e9fica, a 00fanica e exclusiva &bMelhoria Altamente Avan00e7ada&r!"
				""
				"  Cada uma delas adicionada 00e0 sua m00e1quina &6aumenta seu consumo m00e1ximo de energia poss00edvel em 512 eu/t&r. Apenas um desses carinhas vai impulsionar sua m00e1quina para a lua!"
				""
				"  Use-os com sabedoria, eles s00e3o bem caros de fazer."
			]
		}
		quest.71776A6A96EB037C.title: {
			new: "Вогнетривка глина"
			old: "Argila Refrat00e1ria"
		}
		quest.43DB398322EF99BD.quest_subtitle: {
			new: "Змішування &eдвох&r матеріалів разом для &6сплавів&r."
			old: "Misturando &edois&r materiais para &6ligas&r."
		}
		quest.7C0FA555C5FE00D1.title: {
			new: "Роботизовані маніпулятори"
			old: "Bra00e7os Rob00f3ticos"
		}
		quest.069382B7A2FC7D35.quest_desc: {
			new: [
				"Буде &6кальцинуватися&r і &cвтрачати&r ефективність з часом до мінімуму &e33%&r, коли не використовується &bДистильована вода&r."
				""
				"Використання &bСокири&r на &bБойлері&r скине його кальцинацію."
			]
			old: [
				"Irá &6calcificar&r e &cfechar&r a eficiência ao longo do tempo para um mínimo de &e33%&r de eficiência quando não estiver usando &bÁgua Destilada&r. "
				""
				"Usar um &bMachado&r na &bCaldeira&r irá resetar sua calcificação."
			]
		}
		quest.1C25114D2AF71C35.quest_desc: {
			new: [
				"  Використовуючи &bПромисловий ТНТ&r, &bІмплозійний компресор&r здатний стискати порошки та злитки найміцніших матеріалів. Це включає &bВольфрам&r, &bВибухостійкий сплав&r, &bБерилій&r і, нарешті, &bАлмази&r! Деякі з цих матеріалів будуть дуже важливими для вашої подорожі в ядерний поділ."
				""
				"  Тепер ви, мабуть, помітили, що під час своєї подорожі ви могли виготовляти &bПластини вибухостійкого сплаву&r та &bСамородки вольфраму&r у своєму звичайному компресорі, хоча це досить неефективний процес. Що ж, тепер, використовуючи &bІмплозійний компресор&r, ви зможете робити це швидше і ще ефективніше!"
			]
			old: [
				"  Usando &bTNT Industrial&r, o &bCompressor de Implosão&r é capaz de comprimir os pós e barras dos materiais mais resistentes. Isso inclui &bTungstênio&r, &bLiga à Prova de Explosão&r, &bBerílio&r e, finalmente, &bDiamantes&r! Alguns desses materiais serão muito importantes para sua jornada na fissão nuclear."
				""
				"  Agora, você provavelmente notou que em sua jornada, você foi capaz de fazer &bChapas de Liga à Prova de Explosão&b e &rPepitas de Tungstênio&r em seu compressor comum, apesar de ser um processo bastante ineficiente. Bem, agora, usando o &bCompressor de Implosão&r, você será capaz de fazer isso mais rápido e de forma ainda mais eficiente!"
			]
		}
		quest.71776A6A96EB037C.quest_desc: {
			new: [
				"  &bВогнетривка глина&r — це &6суміш&r звичайної річкової глини та &bЦегляного порошку&r як гартувального агента, потім &6перепалена&r для затвердіння, щоб витримувати екстремальні температури."
				""
				"  Щоб зробити &bЦегляний порошок&r, ви можете використовувати свій старий добрий &bКовальський молот&r, щоб &6подрібнити&r звичайну &bЦеглу&r. Ви також можете використовувати інші машини, такі як &bПодрібнювач&r, щоб зробити цей процес ефективнішим."
			]
			old: [
				"  A &bArgila Refrat00e1ria&r 00e9 uma &6mistura&r de &bArgila&r comum de rio e &bP00f3 de Tijolo&r como agente de t00eampera, depois &6recozida&r para endurec00ea-la e faz00ea-la suportar temperaturas extremas."
				""
				"  Para fazer o &bP00f3 de Tijolo&r, voc00ea pode usar seu bom e velho &bMartelo de Forja&r e us00e1-lo para &6esmagar&r &bTijolos&r comuns. Voc00ea tamb00e9m pode usar outras m00e1quinas como o &bMacerador&r para tornar este processo mais eficiente."
			]
		}
		quest.7436F6599E2D79C1.quest_desc: {
			new: [
				"- Можна &6фарбувати&r та &6підрізати&r!"
				""
				"- Перемикайте &6Творчий політ&r натисканням &eN&r."
			]
			old: [
				"- Pode ser &6Tingido&r e &6Adornado&r!"
				""
				"- Alterne o &6Voo Criativo&r pressionando &eN&r."
			]
		}
		quest.176524D0E4475298.quest_desc: {
			new: [
				"  З вашою щойно видобутою &bСирою нафтою&r ви можете виготовляти широкий спектр предметів, проте &6вам потрібно буде її переробити, щоб використовувати&r. Наразі вона досить марна в промисловому сенсі."
				""
				"  Ось тут і вступає в дію &bДистилятор&r! &6Ви можете переробляти або &oдистилювати&r &6рідини на їхні легші частини&r. З цим &bДистилятором&r ви можете переробляти лише одну рідину за раз."
				""
				"  Просто продовжуйте працювати, незабаром ви зможете видобувати багато рідин одночасно."
			]
			old: [
				"  Com seu &bÓleo Cru&r recém-perfurado, você pode fazer uma grande variedade de itens, no entanto, &6você precisará refiná-lo para usá-lo&r. Atualmente, é bastante inútil em um sentido industrial."
				""
				"  É aí que a &bDestilaria&r entra em jogo! &6Você pode refinar ou &odestilar&r &6fluidos em suas partes mais leves&r. Com esta &bDestilaria&r, você só pode refinar um fluido de cada vez."
				""
				"  Continue trabalhando, em breve você será capaz de extrair muitos fluidos de uma vez."
			]
		}
		quest.02272D430F08B1DC.quest_desc: {
			new: [
				"  Тепер ви можете зробити великий резервуар! Це мультиблоковий резервуар, який може зберігати 64 000 мб &oна&r блок у межах загального об'єму, який займає резервуар, включаючи повітряні та тверді блоки."
				""
				"  Коли ви розмістите Великий резервуар, відкрийте його графічний інтерфейс і перевірте верхній лівий кут. Він дозволить вам вибрати потрібний розмір."
				""
				"  Після вибору візьміть свій надійний гайковий ключ, і голограма покаже, куди ставити блоки."
				""
				"  Використовуйте також Люк для великого резервуара. Він працює так само, як і інші люки, за винятком того, що це лише точка доступу до резервуара. Він буде вводити та виводити рідину з будь-яких люків, які ви на нього встановите."
			]
			old: [
				"  Agora você pode fazer um tanque grande! Este é um multiblock de tanque que pode armazenar 64.000mb &opor&r bloco dentro do volume total que o tanque ocupa, blocos de ar e sólidos."
				""
				"  Quando você colocar um Tanque Grande, abra sua GUI e veja o canto superior esquerdo. Ele permitirá que você escolha o tamanho que deseja. "
				""
				"  Depois de escolher, segure sua fiel chave inglesa e um holograma mostrará onde colocar os blocos."
				""
				"  Use também uma Escotilha de Tanque Grande. Funciona como outras escotilhas, exceto por ser apenas um ponto de acesso ao tanque. Ele irá inserir e extrair de qualquer escotilha que você colocar nele."
			]
		}
		quest.1D57C823A1F0203C.title: {
			new: "Паровий гірничий бур"
			old: "Broca a Vapor de Mineração"
		}
		quest.1081BFCAB3F07FFF.quest_desc: {
			new: [
				"  Потрібне парове оновлення? Я знаю, що мені потрібно! &bВеликий паровий бойлер&r — це вдосконалена версія менших бронзових і сталевих бойлерів. &6Він використовує паливо у 8 разів швидше&r, ніж піч, але виробляє &6256 мб/т пари&r при максимальній температурі. Переконайтеся, що не забули забезпечити його &bВодою&r!"
				""
				"  Основним блоком, який вам знадобиться, є &bБронзована цегла&r, але вам також знадобляться інші блоки, показані у вашому EMI. &bВеликий паровий бойлер&r складається з шару &bТермостійких корпусів машин&r з шарами &6Бронзованої цегли&r та &6Корпусів машин для труб&r."
				""
				"  Контролер знаходиться на другому шарі, поверх &bТермостійких корпусів машин&r. &6Не забувайте, що ви можете використовувати свій &bГайковий ключ&r, &6щоб побачити форму мультиблока та розміщення необхідних для нього блоків&r. Необхідні люки повинні бути розміщені на нижньому шарі. Вам знадобиться спосіб подачі води та твердого палива, а також спосіб виведення &bПари&r."
			]
			old: [
				"  Precisa de uma melhoria a vapor? Eu sei que preciso! A &bCaldeira a Vapor Grande&r é uma versão melhorada das caldeiras menores de bronze e aço. &6Ela usa combustível 8 vezes mais rápido&r que a Fornalha, mas produz &6256 mb/t de vapor&r quando na temperatura máxima. Certifique-se de não esquecer de fornecer &bÁgua&r!"
				""
				"  O bloco principal que você precisará é de &bTijolos Banhados a Bronze&r, mas você também precisará de outros blocos mostrados no seu EMI. A &bCaldeira a Vapor Grande&r é composta por uma camada de &bCarcaças de Máquina à Prova de Calor&r com camadas de &6Tijolos Banhados a Bronze&r e &6Carcaças de Máquina de Cano&r."
				""
				"  O Controlador está na segunda camada, em cima das &bCarcaças de Máquina à Prova de Calor&r. &6Não se esqueça que você pode usar sua &bChave Inglesa&r &6para mostrar a forma do multiblock e a colocação dos blocos necessários para ele&r. As escotilhas necessárias devem ser colocadas na camada inferior. Você precisará de uma maneira de inserir água e um combustível sólido, bem como uma maneira de extrair &bVapor&r."
			]
		}
		quest.39CF27CAC4EE33DB.quest_desc: {
			new: [
				"- Натисніть &6Праву кнопку миші&r на &9Стоячу воду&r або &9Проточну воду&r, щоб наповнити."
				""
				"- Помістіть &8Паливо&r всередину &bБензопили&r за допомогою &6Правої кнопки миші&r."
				""
				"- Перемикайте &eШовковий дотик&r за допомогою &6Лівого Shift&r + &6Права кнопка миші&r."
			]
			old: [
				"- Pressione &6Clique Direito&r em &9Água Parada&r ou &9Água Corrente&r para encher."
				""
				"- Coloque &8Combustível&r dentro da &bMotosserra&r usando &6Clique Direito&r."
				""
				"- Alterne &eToque de Seda&r com &6Shift Esquerdo&r + &6Clique Direito&r."
			]
		}
		quest.3761B64135EA94C0.quest_desc: {
			new: [
				"  Ви нарешті зможете побудувати &bЯдерний реактор&r, який використовує різні типи &bРідин&r та &bПаливних стрижнів&r для виробництва різноманітного газоподібного палива, &bПари&r у великих кількостях та радіоактивних матеріалів."
				""
				"  &bЯдерний реактор&r не для слабкодухих. Вам потрібно буде стежити за показниками теплової та нейтронної взаємодії під час будівництва одного з чотирьох реакторів різних розмірів."
				"""  Якщо ви відмовитеся від розвитку своїх знань і стандартів у реакторі, поверніться до мене, і я поясню все про те, як він працює."
				""
				"  Наразі бажаю успіхів!"
			]
			old: [
				"  Ви нарешті зможете побудувати &bЯдерний реактор&r, який використовує різні типи &bРідин&r та &bПаливних стрижнів&r для виробництва різноманітного газоподібного палива, &bПари&r у величезних кількостях та радіоактивних матеріалів."
				""
				"  &bЯдерний реактор&r не для слабкодухих. Вам потрібно буде стежити за показниками теплової та нейтронної взаємодії під час будівництва одного з чотирьох реакторів різних розмірів."
				""
				"  Якщо ви відмовитеся від розвитку своїх знань і стандартів щодо реактора, поверніться до мене, і я поясню все про те, як він працює."
				""
				"  Наразі бажаю вам успіхів!"
			]
		}
		quest.64287B360B07BEBB.quest_desc: {
			new: ["- &6Підключіть/об'єднайте&r до &cмакс.&r &a64&r машин на ваш вибір."]
			old: ["- &6Підключіть/об'єднайте&r до &cмаксимуму&r &a64&r машин на ваш вибір."]
		}
		quest.0B2FF8169FD3812D.quest_subtitle: {
			new: "Чекаєте, поки щось вилупиться?"
			old: "Чекаєте, поки щось вилупиться?"
		}
		quest.250D1E2BFE6E0D50.quest_desc: {
			new: [
				"  Покращуйте ці &bВеликі парові котли&r якнайшвидше!"
				""
				"  Ця вдосконалена версія може &6збільшити виробництво &bПари&r у чотири рази &6до 1024 мб/т при повній температурі&r."
				""
				"  Вона трохи вища, тому не забудьте використати &bГайковий ключ&r, щоб побачити форму мультиблока та розміщення блоків."
			]
			old: [
				"  Покращуйте ті &bВеликі парові котли&r вже зараз!"
				""
				"  Ця вдосконалена версія може &6збільшити виробництво &bПари&r у чотири рази &6до 1024 мб/т при максимальній температурі&r."
				""
				"  Вона трохи вища, тому не забудьте використати &bГайковий ключ&r, щоб побачити форму мультиблока та розміщення блоків."
			]
		}
		quest.698235E8EC974A7F.quest_desc: {
			new: [
				"Ця машина краще справляється з виготовленням &bВигнутих пластин&r та &bКілець&r, ніж &6Компресор."
				""
				"Вона &6швидша&r та &6краща&r. Виконує створення вдвічі швидше!"
			]
			old: [
				"Ця машина краще справляється з виготовленням &bВигнутих пластин&r та &bКілець&r, ніж &6Компресор."
				""
				"Вона &6швидша&r та &6краща&r. Виконує створення вдвічі швидше!"
			]
		}
		quest.7C0FA555C5FE00D1.quest_desc: {
			new: [
				"  &bРоботизовані маніпулятори&r — це спосіб автоматичного переміщення речей всередині машини."
				""
				"  Це можуть бути дуже складні компоненти, тому вони виготовляються зі &bСталі&r, щоб залишатися міцними та запобігати внутрішнім пошкодженням."
				""
				"  &6Ви повинні автоматизувати це&r."
			]
			old: [
				"  &bРоботизовані маніпулятори&r — це спосіб автоматичного переміщення речей всередині машини."
				""
				"  Це можуть бути дуже складні компоненти, тому вони виготовляються зі &bСталі&r, щоб залишатися міцними та запобігати внутрішнім пошкодженням."
				""
				"  &6Ви повинні автоматизувати їх&r."
			]
		}
		quest.2B4BFD88DF1A934D.quest_desc: {
			new: ["  Має третину ваги сталі, але є пластичним і дуже ковким. Виготовляється шляхом нагрівання та видобутку з &bБокситів&r. Ви можете зробити це у своєму новоствореному &bAFE&r. &6Обов'язково автоматизуйте виробництво &bАлюмінію&r, оскільки ви зрештою використаєте його ДУЖЕ багато&r."]
			old: ["  Має третину ваги сталі, але є пластичним і дуже ковким. Виготовляється шляхом нагрівання та видобутку з &bБокситів&r. Ви можете зробити це у своєму новоствореному &bEBF&r. &6Обов'язково автоматизуйте виробництво &bАлюмінію&r, оскільки ви зрештою використаєте його ДУЖЕ багато&r."]
		}
		quest.2BC64E1EB1BCE14D.quest_desc: {
			new: [
				"  &bСвердло з нержавіючої сталі&r — це нове свердло, яке &6можна використовувати як у &bКар'єрі&r, так і на &bНафтовій буровій платформі&r."
				""
				"  Для кар'єру ви отримаєте нові рідкісні ресурси, які будуть надзвичайно корисними в майбутньому."
				""
				"  На буровій платформі ви зможете викачувати &bГорючий сланець&r, який можна дистилювати в &bГелій&r, &bСірчану сиру нафту&r та &bСірчану нафту&r."
			]
			old: [
				"  &bСвердло з нержавіючої сталі&r — це нове свердло, яке &6можна використовувати як у &bКар'єрі&r, так і на &bНафтовій буровій платформі&r."
				""
				"  Для кар'єру ви отримаєте нові рідкісні ресурси, які будуть надзвичайно корисними в майбутньому."
				""
				"  На буровій платформі ви зможете викачувати &bСланцеву нафту&r, який можна дистилювати в &bГелій&r, &bСірчану сиру нафту&r та &bСірчану нафту&r."
			]
		}
		quest.7593E582FA928061.quest_desc: {
			new: [
				"  Це &bМідне свердло&r. Воно дасть вам &6камінь та землю&r, які переважно використовуються як будівельні матеріали."
				""
				"  Перевірте виходи в EMI і переконайтеся, що знаєте, що &6свердло має шанс зламатися&r, тому не робіть лише одне."
			]
			old: [
				"  Це &bМідне свердло&r. Воно дасть вам &6камінь та землю&r, які переважно використовуються як будівельні матеріали."
				""
				"  Перевірте виходи в EMI і переконайтеся, що знаєте, що &6свердло має шанс зламатися&r, тому не робіть лише одне."
			]
		}
		quest.7FD5FCEFE3697A7C.quest_subtitle: {
			new: "Що сказав маленький &eкукурудзяний&r початок мамі &eкукурудзі&r?"
			old: "Що сказав маленький &eкукурудзяний&r початок мамі &eкукурудзі&r?"
		}
		quest.45F0194CF3DCA5DD.quest_desc: {
			new: [
				"  &bЛігніт&r — це справді багате &bджерело палива&r, яке можна &6знайти&r у світі. Це практично &bВугілля&r, але коричневе."
				""
				"  Воно має нижчий вміст вуглецю, хоча &6горить&r так само, як і &bВугілля&r; створюється таким же чином."
				""
				"  Це означає, що ви можете зберегти своє справжнє &bВугілля&r для інших &6проєктів&r або &6рецептів&r, а натомість використовувати &bЛігніт&r для &6живлення&r свого &bПарового гірничого свердла&r."
			]
			old: [
				"  &bЛігніт&r — це справді багате &bджерело палива&r, яке можна &6знайти&r у світі. Це практично &bВугілля&r, але коричневе."
				""
				"  Воно має нижчий вміст вуглецю, хоча &6горить&r так само, як і &bВугілля&r; створюється таким же чином."
				""
				"  Це означає, що ви можете зберегти своє справжнє &bВугілля&r для інших &6проєктів&r або &6рецептів&r, а натомість використовувати &bЛігніт&r для &6живлення&r свого &bПарового гірничого свердла&r."
			]
		}
		quest.20A093E5684D2E30.title: {
			new: "&bЕра середини гри!"
			old: "&bЕра середини гри!"
		}
		quest.29D05998ADC8ACF5.quest_desc: {
			new: ["  Суперсучасний процесор, щоб довести можливості розгону вашої машини до межі, а незабаром — щось трохи більше... &cЯдерне&r."]
			old: ["  Суперсучасний процесор, щоб довести можливості розгону вашої машини до межі, а незабаром — щось трохи більше... &cЯдерне&r."]
		}
		quest.3DF6354F7AC8D4A4.quest_desc: {
			new: ["  Тепер, коли ви можете розпочати свою подорож у хімію, відгалужуючись від &bСирої нафти&r, ви можете створювати покращення для своїх машин! Усі електричні машини, які ви використовували досі, мають максимальний розгін 32 EU/т. Тепер ви можете збільшити цей максимум залежно від рівня покращення, яке ви використовуєте. Перевірте свій EMI, щоб побачити, скільки EU додає кожне покращення."]
			old: ["  Тепер, коли ви можете розпочати свою подорож у хімію, відгалужуючись від &bСирої нафти&r, ви можете створювати покращення для своїх машин! Усі електричні машини, які ви використовували досі, мали максимальний розгін 32 EU/т. Тепер ви можете збільшити цей максимум залежно від рівня покращення, яке ви використовуєте. Перевірте свій EMI, щоб побачити, скільки EU додає кожне покращення."]
		}
		quest.7FD5FCEFE3697A7C.quest_desc: {
			new: [
				"Лише за &oмізерні&r &e8 EU/т&r, &bПаровий фермер&r може виконувати такі завдання:"
				"- &6Оранка&r: Коли активовано, блоки землі перетворюватимуться на зорану землю. Це не працюватиме, якщо не подати воду."
				"- &6Зволоження&r: При подачі води зорана земля буде зволожуватися."
				"- &6Збір врожаю&r: Якщо є достатньо місця для виходу, він збиратиме повністю вирощені культури та дерева."
				"- &6Посадка&r: При подачі насіння або саджанців, він висаджуватиме їх на придатний ґрунт. Використання різних режимів посадки дозволить висаджувати їх у різних порядках."
			]
			old: [
				"Лише за &oмізерні&r &e8 EU/т&r, &bПаровий фермер&r може виконувати такі завдання:"
				"- &6Оранка&r: Коли активовано, блоки землі перетворюватимуться на зорану землю. Це не працюватиме, якщо не подати воду."
				"- &6Зволоження&r: При подачі води зорана земля буде зволожуватися."
				"- &6Збір врожаю&r: Якщо є достатньо місця для виходу, він збиратиме повністю вирощені культури та дерева."
				"- &6Посадка&r: При подачі насіння або саджанців, він висаджуватиме їх на придатний ґрунт. Використання різних режимів посадки дозволить висаджувати їх у різних порядках."
			]
		}
		quest.5676B5FD97FB10C3.quest_desc: {
			new: [
				"  Це &bБронзова піч&r, і хоча вона така ж повільна, як і звичайна &bПіч&r, різниця в тому, що вона &6використовує у &o20&r&6 разів менше палива&r!"
				""
				"  Дякуйте &bПарі&r за таку ефективність!"
			]
			old: [
				"  Це &bБронзова піч&r, і хоча вона така ж повільна, як і звичайна &bПіч&r, різниця в тому, що вона &6використовує у &o20&r&6 разів менше палива&r!"
				""
				"  Дякуйте &bПарі&r за таку ефективність!"
			]
		}
		quest.4980C231ECDB0BF2.quest_desc: {
			new: ["  &bСталеве свердло&r дає вам решту &6найпоширеніших руд&r, які знадобляться для подальшого прогресу у вашій подорожі до повної автоматизації, а також у вашій подорожі світом. Перевірте свій EMI для всіх можливих виходів."]
			old: ["  &bСталеве свердло&r дає вам решту &6найпоширеніших руд&r, які знадобляться для подальшого прогресу у вашій подорожі до повної автоматизації, а також у вашій подорожі світом. Перевірте свій EMI для всіх можливих виходів."]
		}
		quest.1910E0D1BB24E94D.quest_desc: {
			new: [
				"Для виробництва &eенергії&r &bСонячній панелі&r потрібна &bФотоелектрична комірка&r відповідного рівня у її &6інвентарі&r."
				""
				"Якщо подати &bДистильовану воду&r до &bСонячної панелі&r, &bФотоелектрична комірка&r у її слоті прослужить у &a2x&r рази довше!"
				""
				"Швидкість &eгенерації енергії&r визначається тим, наскільки високо &6сонце&r знаходиться в &bнебі&r і чи &bнебо&r &aвидиме&r."
			]
			old: [
				"Для виробництва &eенергії&r &bСонячній панелі&r потрібна &bФотоелектрична комірка&r відповідного рівня у її &6інвентарі&r."
				""
				"Якщо подати &bДистильовану воду&r до &bСонячної панелі&r, &bФотоелектрична комірка&r у її слоті прослужить у &a2x&r рази довше!"
				""
				"Швидкість &eгенерації енергії&r визначається тим, наскільки високо &6сонце&r знаходиться в &bнебі&r і чи &bнебо&r &aвидиме&r."
			]
		}
		quest.42D6CC67AB29D7DA.quest_desc: {
			new: [
				"  Ви нарешті досягли &bЦифрових схем&r!"
				""
				"  Ось де починається справжня сила. Збільште можливості розгону ваших машин ще більше, ніж раніше, нові руди з кар'єрів."
				""
				"  &6Ви повинні автоматизувати це&r."
			]
			old: [
				"  Ви нарешті досягли &bЦифрових схем&r!"
				""
				"  Ось де починається справжня сила. Збільште можливості розгону ваших машин ще більше, ніж раніше, нові руди з кар'єрів."
				""
				"  &6Ви повинні автоматизувати це&r."
			]
		}
		quest.091C2772ED417247.quest_desc: {
			new: [
				"  Тепер, коли ви виробляєте енергію на &6рівні середньої напруги&r, вам потрібно переконатися, що ваші машини можуть приймати цю нову енергію."
				"""  Зазвичай &6кабелі навіть не підключаються до машин, якщо вони не одного рівня&r. Але, встановивши &bКорпус машини (просунутий)&r (або вищого рівня) у слот у верхньому правому куті машини, ви оновите машину до рівня енергії, що відповідає цьому корпусу."
				""
				"  За замовчуванням електричні машини вже мають рівень &bКорпусу машини (базовий)&r, і немає потреби встановлювати &bБазові корпуси машин&r у слот. Я покажу вам, які корпуси відповідають якому рівню енергії."
				""
				"  &6Обов'язково перевіряйте, які машини &cнасправді&r&6 потребують покращень&r, щоб не витрачати ресурси на машини, яким не потрібен додатковий приріст потужності."
			]
			old: [
				"  Тепер, коли ви виробляєте енергію на &6рівні середньої напруги&r, вам потрібно переконатися, що ваші машини можуть приймати цю нову енергію."
				""
				"  Зазвичай &6кабелі навіть не підключатимуться до машин, якщо вони не одного рівня&r. Але, встановивши &bКорпус машини (просунутий)&r (або вищого рівня) у слот у верхньому правому куті машини, ви оновите машину до рівня енергії, з яким вона асоціюється."
				""
				"  За замовчуванням електричні машини вже мають рівень &bКорпусу машини (базовий)&r, і немає потреби встановлювати &bБазові корпуси машин&r у слот. Я покажу вам, які корпуси відповідають якому рівню енергії."
				""
				"  &6Обов'язково перевіряйте, які машини &cнасправді&r&6 потребують покращень&r, щоб не витрачати ресурси на машини, яким не потрібен додатковий приріст потужності."
			]
		}
		quest.779C3C6B89AD2526.quest_desc: {
			new: [
				"  Електричні машини працюють точно так само, як і парові, за винятком того, що &6вони потребують електрики для роботи замість пари&r і можуть поступово розганяти (оверклокати) рецепти до 32 EU/t (поки що)."
				""
				"  Ви можете використовувати свій EMI, щоб переглянути рецепти для електричних версій машин, з якими ви вже знайомі. Рецепти складніші і вимагатимуть більш специфічних деталей, орієнтованих на машини."
				""
				"  Вашою першою основною деталлю будуть &bАналогові схеми&r. Це буде основна схема для машин низької напруги (LV), а також база для схем і машин вищого рівня. &6Ви повинні автоматизувати це якомога швидше&r."
				""
				"  Я наполегливо раджу вам почати автоматизувати деталі якомога швидше. Я повідомлю вам, які деталі слід автоматизувати, коли ми з ними зіткнемося. Це зробить електричні машини практично безкоштовними, оскільки вам не доведеться вручну створювати жоден компонент!"
			]
			old: [
				"  Електричні машини працюють точно так само, як і парові, за винятком того, що &6вони потребують електрики для роботи замість пари&r і можуть поступово розганяти (оверклокати) рецепти до 32 EU/t (поки що)."
				""
				"  Ви можете використовувати свій EMI, щоб переглянути рецепти для електричних версій машин, з якими ви вже знайомі. Рецепти складніші і вимагатимуть більш специфічних деталей для машин."
				""
				"  Вашою першою основною деталлю буде &bАналогова схема&r. Це буде основна схема для машин низької напруги (LV), а також база для схем і машин вищого рівня. &6Ви повинні автоматизувати це якомога швидше&r."
				""
				"  Я наполегливо раджу вам почати автоматизувати деталі якомога швидше. Я повідомлю вам, які деталі слід автоматизувати, коли ми з ними зіткнемося. Це зробить електричні машини практично безкоштовними, оскільки вам не доведеться вручну створювати жоден компонент!"
			]
		}
		quest.2B4BFD88DF1A934D.quest_subtitle: {
			new: "Все буде добре, чи не так?"
			old: "Все буде гаразд?"
		}
		quest.163BCEEEE08F3898.quest_desc: {
			new: [
				"  &bПоляризатор&r, ну, поляризує речі! Це означає, що його ||електрони|| вирівнюються, і таким чином метал, який ви в нього кладете, стає магнітним."
				""
				"  &bПоляризовані стрижні&r не мають багато застосувань, але &6використовувати їх для автоматизації двигунів — ідеально&r!"
				"{image:modern_industrialization:block/machines/polarizer/overlay_front_active width:32 height:32 align:center}"
			]
			old: [
				"  &bПоляризатор&r, ну, поляризує речі! Це означає, що його ||електрони|| вирівнюються, і таким чином метал, який ви в нього вставляєте, стає магнітним."
				""
				"  &bПоляризовані стрижні&r не мають багато застосувань, але &6використовувати їх для автоматизації двигунів — ідеально&r!"
				"{image:modern_industrialization:block/machines/polarizer/overlay_front_active width:32 height:32 align:center}"
			]
		}
		quest.07FE9074247583EE.quest_desc: {
			new: [
				"  Тепер ви, можливо, помітили, що я сказав \"зазвичай\", коли говорив про взаємодію з контролером. Це означає, що предмети та &6рідини не можуть бути введені або виведені з контролера&r, але інформація може; у сенсі статистики. Дивлячись на контролер, ви побачите кілька речей: Валідність структури, Статус, Прогрес, Базовий рецепт та Поточний рецепт."
				""
				"  Валідність структури повідомить вам, чи &6мультиблок побудований правильно чи ні&r. Він не скаже, чи ви пропустили щось, чи у вас забагато люків у мультиблоці, тому ви повинні вирішити це самі. Майте на увазі, що мультиблочні структури &cможуть&r ділитися блоками одна з одною, якщо ці блоки, що перекриваються, НЕ містять люк."
				""
				"  Статус повідомить вам поточний стан мультиблока. Чи він простоює, чи активний."
				""
				"  Прогрес покаже виконання, повільно накопичуючи відсотки до 100%. Залежно від швидкості процесу, відсотки зростатимуть швидше."
				""
				"  Базовий рецепт показує &6базове споживання енергії/пари для рецепта&r. Залежно від того, що ви робите, він використовує мінімальну кількість енергії/пари, але може використовувати більше для прискорення процесу. Це не відбувається в парових машинах, тому я не буду заглиблюватися в це зараз."
				""
				"  Поточний рецепт — це &6поточна кількість енергії/пари, що фактично споживається&r."
			]
			old: [
				"  Тепер ви, можливо, помітили, що я сказав \"зазвичай\", коли говорив про взаємодію з контролером. Це означає, що предмети та &6рідини не можуть бути введені або виведені з контролера&r, але інформація може; у сенсі статистики. Дивлячись на контролер, ви побачите кілька речей: Валідність структури, Статус, Прогрес, Базовий рецепт та Поточний рецепт."
				""
				"  Валідність структури повідомить вам, чи &6мультиблок побудований правильно чи ні&r. Він не скаже, чи ви пропустили щось, чи у вас забагато люків у мультиблоці, тому ви повинні вирішити це самі. Майте на увазі, що мультиблочні структури &cможуть&r ділитися блоками одна з одною, якщо ці блоки, що перекриваються, НЕ містять люк."
				""
				"  Статус повідомить вам поточний стан мультиблока. Чи він простоює, чи активний."
				""
				"  Прогрес покаже виконання, повільно накопичуючи відсотки до 100%. Залежно від швидкості процесу, відсотки зростатимуть швидше."
				""
				"  Базовий рецепт показує &6базове споживання енергії/пари для рецепта&r. Залежно від того, що ви робите, він використовує мінімальну кількість енергії/пари, але може використовувати більше для прискорення процесу. Це не відбувається в парових машинах, тому я не буду заглиблюватися в це зараз."
				""
				"  Поточний рецепт — це &6поточна кількість енергії/пари, що фактично споживається&r."
			]
		}
		quest.2D4170B5AD28DCBF.quest_desc: {
			new: [
				"  Найкращий &bДизельний генератор&r з одного блоку, який ви можете зробити. &6Він вироблятиме до 1024 EU/t&r з будь-якої з багатьох рідин, перелічених у вашому EMI."
				""
				"  Тепер, це не найкращий генератор, який приймає рідке паливо. Існує &bВеликий дизельний генератор&r, який вимагатиме &bВисокопросунуті корпуси машин&r; хоча це того варте, коли ви почуєте, що &6він генеруватиме до 16 384 EU/t&r!"
			]
			old: [
				"  Найкращий &bДизельний генератор&r з одного блоку, який ви можете зробити. &6Він вироблятиме до 1024 EU/t&r з будь-якої з багатьох рідин, перелічених у вашому EMI."
				""
				"  Тепер, це не найкращий генератор, який приймає рідке паливо. Існує &bВеликий дизельний генератор&r, який вимагатиме &bВисокопросунуті корпуси машин&r; хоча це того варте, коли ви почуєте, що &6він генеруватиме до 16 384 EU/t&r!"
			]
		}
		quest.215606B3A894512E.title: {
			new: "Поради щодо кар'єру"
			old: "Поради щодо кар'єру"
		}
		quest.24A4F1AA0BFFE867.quest_desc: {
			new: [
				"  Це електрична версія &bПарової доменної печі&r. &bЕлектрична доменна піч (ЕДП)&r використовує індукційне нагрівання для створення екстремальних температур, відкриваючи безліч нових рецептів. Крім того, її &6оверклок обмежений 128 EU/t за замовчуванням&r, як і в інших електричних мультиблочних машин."
				""
				"  &bЕлектрична доменна піч&r або &bЕДП&r виготовляється виключно з &bЖаростійких корпусів машин&r та &bКупронікелевих котушок&r. &6Використовуйте свій &bГайковий ключ&r &6щоб побачити форму мультиблока та розміщення блоків&r. Контролер розміщується на нижньому шарі, а люки можна розміщувати на верхньому або нижньому шарах."
				""
				" &6Не забудьте додати люк(и) входу енергії&r, інакше ЕДП не матиме енергії для роботи! Почніть з &bЛюка входу енергії (LV)&r, і ви зможете оновити його до люків вищого рівня, коли матимете відповідні рівні енергії. Пам'ятайте, &bЛюк входу енергії (LV)&r підключатиметься лише до &bкабелів LV&r."
				""
				"  Вам також знадобляться люки входу предметів або рідин та люки виходу предметів або рідин залежно від використання &bЕДП&r. Перевірте свій EMI для нових рецептів і вибирайте люки відповідно до ваших потреб."
			]
			old: [
				"  Це електрична версія &bПарової доменної печі&r. &bЕлектрична доменна піч (ЕДП)&r використовує індукційне нагрівання для створення екстремальних температур, відкриваючи безліч нових рецептів. Крім того, її &6оверклок обмежений 128 EU/t за замовчуванням&r, як і в інших електричних мультиблочних машин."
				""
				"  &bЕлектрична доменна піч&r або &bЕДП&r виготовляється виключно з &bЖаростійких корпусів машин&r та &bКупронікелевих котушок&r. &6Використовуйте свій &bГайковий ключ&r &6щоб побачити форму мультиблока та розміщення блоків&r. Контролер розміщується на нижньому шарі, а люки можна розміщувати на верхньому або нижньому шарах."
				""
				" &6Не забудьте додати люк(и) входу енергії&r, інакше ЕДП не матиме енергії для роботи! Почніть з &bЛюка входу енергії (LV)&r, і ви зможете оновити його до люків вищого рівня, коли матимете відповідні рівні енергії. Пам'ятайте, &bЛюк входу енергії (LV)&r підключатиметься лише до &bкабелів LV&r."
				""
				"  Вам також знадобляться люки входу предметів або рідин та люки виходу предметів або рідин залежно від використання &bЕДП&r. Перевірте свій EMI для нових рецептів і вибирайте люки відповідно до ваших потреб."
			]
		}
		quest.6CA941AE132445D9.quest_desc: {
			new: [
				"  &bКорпуси машин&r містять основні електронні компоненти, що дозволяють машинам працювати. Існують різні рівні корпусів машин, кожен з яких дозволяє вам оновлювати свої машини. &bКорпус машини (базовий)&r є основою кожної машини, яка використовує енергію LV."
				"""  Якщо ви хочете, щоб ваша машина приймала енергію МТ, ви повинні оновити її за допомогою &bПокращеного корпусу машини&r. Ви можете зробити це, &6клацнувши правою кнопкою миші по машині з оновленим корпусом&r у руці або помістивши його у верхній правий слот графічного інтерфейсу машини, який виглядає як маленьке зображення ізометричного куба. Ви можете зробити те саме з корпусами вищого рівня, оскільки вони дозволять використовувати джерела енергії вищого рівня."
			]
			old: [
				"  &bКорпуси машин&r містять основну електроніку, що дозволяє машинам працювати. Існують різні рівні корпусів машин, кожен з яких дозволяє вам покращувати свої машини. &bБазовий корпус машини&r є основою кожної машини, яка використовує енергію НТ (LV)."
				""
				"  Якщо ви хочете, щоб ваша машина приймала енергію МТ (MV), ви повинні оновити її за допомогою &bПокращеного корпусу машини&r. Ви можете зробити це, &6клацнувши правою кнопкою миші по машині з оновленим корпусом&r у руці або помістивши його у верхній правий слот графічного інтерфейсу машини, який виглядає як маленьке зображення ізометричного куба. Ви можете зробити те саме з корпусами вищого рівня, оскільки вони дозволять використовувати джерела енергії вищого рівня."
			]
		}
		quest.43DB398322EF99BD.quest_desc: {
			new: [
				"&bЛиварна сталевих сплавів&r дозволяє створювати &9сплави&r з двох різних злитків &oбез&r потреби &6змішувати&r порошки у &bЗмішувачі&r спочатку. Перевірте свій &dEMI&r, щоб побачити, які сплави можна виготовити таким чином."
				""
				"Ви також можете використовувати будь-яку &6комбінацію&r рівних кількостей ресурсів для створення сплаву, наприклад, &aдев'ять&r крихітних порошків + &aдев'ять&r самородків."
				""
				"Чого ви &oне можете&r зробити, так це &aдев'ять&r крихітних порошків + &aодин&r злиток, оскільки кількості різні."
			]
			old: [
				"&bЛиварна сталевих сплавів&r дозволяє створювати &9сплави&r з двох різних злитків &oбез&r потреби &6змішувати&r порошки у &bЗмішувачі&r спочатку. Перевірте свій &dEMI&r, щоб побачити, які сплави можна виготовити таким чином."
				""
				"Ви також можете використовувати будь-яку &6комбінацію&r рівних кількостей ресурсів для створення сплаву, наприклад, &aдев'ять&r крихітних порошків + &aдев'ять&r самородків."
				""
				"Чого ви &oне можете&r зробити, так це &aдев'ять&r крихітних порошків + &aодин&r злиток, оскільки кількості різні."
			]
		}
		quest.779C3C6B89AD2526.title: {
			new: "&eЕлектрична ера!"
			old: "&eЕлектрична ера!"
