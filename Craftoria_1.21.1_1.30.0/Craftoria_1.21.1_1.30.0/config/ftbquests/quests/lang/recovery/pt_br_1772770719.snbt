		quest.4E8963E1C18ADBAB.quest_desc: {
			new: [
				"&bІнкубатор&r — це невеликий мультиблок, що використовується для рекомбінації Принципів матерії в об'єкти."
				""
				"Він складається з одного типу &bпосудини&r, розміщеної з боків — &bСіль&r, &bСірка&r та &bРтуть&r — самого &bІнкубатора&r та джерела &6тепла&r, у цьому випадку &bПіромантичної жаровні&r знизу."
			]
			old: [
				"&bІнкубатор&r — це невеликий мультиблок, що використовується для рекомбінації Принципів матерії в об'єкти."
				""
				"Він складається з одного типу &bпосудини&r, розміщеної з боків — &bСіль&r, &bСірка&r та &bРтуть&r — самого &bІнкубатора&r та джерела &6тепла&r, у цьому випадку &bПіромантичної жаровні&r знизу."
			]
		}
		quest.5D584858B61E534B.quest_desc: {
			new: ["Цей &bКаталізатор&r повільно перетворює &bРтуть&r на &dРтутний потік&r, джерело &6Енергії&r для алхімічних пристроїв."]
			old: ["Цей &bКаталізатор&r повільно перетворює &bРтуть&r на &dРтутний потік&r, джерело &6Енергії&r для алхімічних пристроїв."]
