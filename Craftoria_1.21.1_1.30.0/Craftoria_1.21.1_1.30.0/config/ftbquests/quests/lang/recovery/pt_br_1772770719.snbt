		quest.7AF270EF635B11CF.quest_desc: {
			new: [
				"  Створено шляхом &6стиснення&r трьох найміцніших матеріалів, які ви використовували у своїй подорожі досі."
				""
				"- &bВольфрам&r, метал з &6надзвичайно високою температурою плавлення та щільністю&r, яку неможливо перевершити."
				"""- &bТитан&r, матеріал, &6стійкий до корозії&r, &6міцний, але легкий&6."
				""
				"- &bНержавіюча сталь&r, надзвичайно &6стійка до іржі&r."
				""
				"  Це найміцніша пластина, яку ви коли-небудь виковували."
			]
			old: [
				"  Створено шляхом &6стиснення&r трьох найміцніших матеріалів, які ви використовували у своїй подорожі до цього часу."
				""
				"- &bВольфрам&r, метал з &6надзвичайно високою температурою плавлення та щільністю&r, яку неможливо перевершити."
				""
				"- &bТитан&r, матеріал, &6стійкий до корозії&r, &6міцний, але легкий&6."
				""
				"- &bНержавіюча сталь&r, надзвичайно &6стійка до іржі&r."
				""
				"  Це найміцніша пластина, яку ви коли-небудь виковували."
			]
