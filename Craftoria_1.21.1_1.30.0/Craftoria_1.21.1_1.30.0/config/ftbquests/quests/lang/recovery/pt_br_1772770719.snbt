		}
		quest.1A6929801D08F2C5.quest_desc: {
			new: ["Можливо, є й інші способи &6генерувати більше енергії&r за допомогою модів, але важко перевершити задоволення від котла, що приводить у дію багато &bПарових двигунів&r... стільки, скільки ви зможете налаштувати, &6забезпечивши&r їх достатньою кількістю &cтепла&r та &9води&r."]
			old: ["Можливо, є й інші способи &6генерувати більше енергії&r за допомогою модів, але важко перевершити задоволення від котла, що приводить у дію багато &bПарових двигунів&r... стільки, скільки ви зможете налаштувати, &6забезпечивши&r їх достатньою кількістю &cтепла&r та &9води&r."]
