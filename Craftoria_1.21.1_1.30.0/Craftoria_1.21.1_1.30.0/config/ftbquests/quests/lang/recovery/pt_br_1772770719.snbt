		quest.206C9BCE1D67C3B8.quest_desc: {
			new: ["Очищення &bКрейди&r вручну може бути виснажливим завданням. На щастя, ця проблема вирішена: використовуйте &bПензель&r!"]
			old: ["Очищення &bКрейди&r вручну може бути виснажливим завданням. На щастя, ця проблема вирішена: використовуйте &bПензель&r!"]
		}
		task.336881A8652FA9A0.title: {
			new: "Закликати Фоліота-дробильника (прогресу немає, вибачте!)"
			old: "Закликати Фоліота-дробильника (прогресу немає, вибачте!)"
		}
		quest.1A8D5373290BC1A6.quest_desc: {
			new: [
				"За допомогою духів можна створити зв'язок з іншим виміром, де ви можете &6зберігати&r всі ті &bпредмети&r, які накопичили — ваша колекція справді дивовижна."
				""
				"Для цього вам знадобиться &bАктуатор зберігання&r. Думайте про нього як про дуже велику скриню."
			]
			old: [
				"За допомогою духів можна створити зв'язок з іншим виміром, де ви можете &6зберігати&r всі ті &bпредмети&r, які накопичили — ваша колекція справді дивовижна."
				""
				"Для цього вам знадобиться &bАктуатор зберігання&r. Думайте про нього як про дуже велику скриню."
			]
		}
		quest.510EAAAA3E08FCD5.quest_desc: {
			new: ["Цей дух-шахтар не має рівних, він здатний добувати &bбільшість руд&r. Іноді він також приносить &6особливий&r предмет..."]
			old: ["Цей дух-шахтар не має рівних, він здатний добувати &bбільшість руд&r. Іноді він також приносить &6особливий&r предмет..."]
		}
		quest.5C56A0938613CBC0.quest_subtitle: {
			new: "Як це вимовляється?"
			old: "Як це вимовляється?"
		}
		task.74C6D98426025A18.title: {
