			old: "Закликати фамільяра Охоронця"
		}new: "Ви думаєте, що видобувний вимір схожий на звичайний світ?"
			old: "Ви думаєте, що видобувний вимір схожий на звичайний світ?"
		}
		quest.2D5A0399B7FFA5DB.quest_subtitle: {
			new: "Прихистіть лавкрафтівський жах вже сьогодні"
			old: "Прихистіть космічний жах вже сьогодні"
		}
		quest.1F828E56F64FFD15.quest_desc: {
			new: [
				"&5Духовний вогонь&r — це особливий тип полум'я, який може &6перетворювати&r одні предмети на інші."
				""
				"Ви можете створити його, &6кинувши&r &bПлід демонічного сну&r на землю та &6підпаливши його&r."
				""
				"Ви можете &6кинути&r в нього &bАндезит&r, щоб отримати &bПотойбічний камінь&r, або &bСаджанці дуба&r, щоб отримати &bПотойбічні саджанці&r."
			]
			old: [
				"&5Духовний вогонь&r — це особливий тип полум'я, який може &6перетворювати&r одні предмети на інші."
				""
				"Ви можете створити його, &6кинувши&r &bПлід демонічного сну&r на землю та &6підпаливши його&r."
				""
				"Ви можете &6кинути&r в нього &bАндезит&r, щоб отримати &bПотойбічний камінь&r, або &bСаджанці дуба&r, щоб отримати &bПотойбічні саджанці&r."
			]
		}
		quest.4A0E862883FE42BB.quest_desc: {
			new: ["Цей самоцвіт здатний &6зберігати&r більшість &bмобів&r всередині для легкого транспортування."]
			old: ["Цей самоцвіт здатний &6зберігати&r більшість &bмобів&r всередині для легкого транспортування."]
		}
		quest.29EB6FA48EDBE556.quest_desc: {
			new: ["&7Світло-сіра крейда&r слугує вдосконаленою базовою крейдою, кращою за білу, оскільки вона краще стабілізує пентаклі, створені з її допомогою."]
			old: ["&7Світло-сіра крейда&r слугує вдосконаленою базовою крейдою, кращою за білу, оскільки вона краще стабілізує пентаклі, створені з її допомогою."]
