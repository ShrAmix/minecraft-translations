				"Це дозволяє створювати цілі озера з будь-якої &7рідини&r, яку ви забажаєте."
			]
			old: [
				"&bРідинний наповнювач&r дозволяє вам &6подавати&r в нього &7рідину&r, і він заповнюватиме відкриті простори під собою &7цією рідиною&r."
				""
				"Це дозволяє створювати цілі озера з будь-якої &7рідини&r, яку ви забажаєте."
			]
		}
		quest.3CABE90D2D99AAD0.title: {
			new: "Формула створення"
			old: "Формула створення"
		}
		quest.7BEA5B1D1B410E82.quest.desc: {
			new: ["&3Вдосконалений сонячний генератор&r — це покращена версія маленького &3сонячного генератора&r, що надає набагато більше &aенергії&r. Ви можете &6розмістити їх&r у верхніх кутах &3Термічної випарної вежі&r із зеленим &aвиходом енергії&r, спрямованим до &3Блока термічного випаровування&r, щоб &6збільшити&r &cтепло&r вежі протягом дня."]
			old: ["&3Вдосконалений сонячний генератор&r — це покращена версія маленького &3сонячного генератора&r, що надає набагато більше &aенергії&r. Ви можете &6розмістити їх&r у верхніх кутах &3Термічної випарної вежі&r із зеленим &aвиходом енергії&r, спрямованим до &3Блока термічного випаровування&r, щоб &6збільшити&r &cтепло&r вежі протягом дня."]
		}
		quest.67284079A941EF4B.quest_desc: {
			new: [
				"&bДайвінг-балон&r отримує &7кисень&r і дозволяє вам &6дихати під водою&r протягом тривалого часу."
				""
				"Використовуйте його, щоб досліджувати глибини &9океану&r або &6побудувати&r собі підводну базу."
			]
			old: [
				"&bДайвінг-балон&r отримує &7кисень&r і дозволяє вам &6дихати під водою&r протягом тривалого часу."
				""
				"Використовуйте його, щоб досліджувати глибини &9океану&r або &6побудувати&r собі підводну базу."
			]
		}
		quest.378E30F8E12695A2.title: {
			new: "Зарядна база"
			old: "Зарядна база"
		}
		quest.4CA2A53F4C298E2B.quest_desc: {
			new: [
				"&bПортативна панель QIO&r дозволить вам отримати доступ до вашої &dСистеми зберігання QIO&r з будь-якого місця у світі."
				""
				"Дуже зручно."
			]
			old: [
				"&bПортативна панель QIO&r дозволить вам отримати доступ до вашої &dСистеми зберігання QIO&r з будь-якого місця у світі."
				""
				"Дуже зручно."
			]
		}
		quest.378E30F8E12695A2.quest_desc: {
			new: ["&bЗарядна база&r — це платформа, яку можна &6розмістити на підлозі&r і &6заряджати&r будь-що, що стоїть на ній; включаючи будь-які &eенергоспоживаючі пристрої/батареї&r в інвентарі гравця, який стоїть на ній."]old: ["&bPlataforma de Carga&r é uma plataforma que pode ser &6colocada no chão&r e &6carregar&r qualquer coisa que esteja sobre ela; incluindo quaisquer &ebaterias/itens que usem energia&r no inventário de um jogador que esteja sobre ela."]
		}
		quest.614E49D8AA7F85FC.quest_desc: {
			new: ["Кожен &bПровайдер індукції еліти&r, доданий до вашої матриці, додає &e9.55 MFE за тік&r швидкості передачі енергії, всередину та назовні вашої матриці."]
			old: ["Кожен &bПровайдер індукції еліти&r, доданий до вашої матриці, додає &e9.55 MFE за тік&r швидкості передачі енергії, всередину та назовні вашої матриці."]
		}
		quest.05A0AC380BB141A0.quest_desc: {
			new: ["&bОбмежувальний транспортер&r — це тип &bЛогістичного транспортера&r, який фактично працює як труба для \"&6надлишків&r\". Як тільки &3предмети&r не мають куди йти, вони &6подорожуватимуть&r через &bОбмежувальний транспортер&r."]
			old: ["&bОбмежувальний транспортер&r — це тип &bЛогістичного транспортера&r, який фактично працює як труба для \"&6надлишків&r\". Як тільки &3предмети&r не мають куди йти, вони &6подорожуватимуть&r через &bОбмежувальний транспортер&r."]
		}
		quest.3BAA7EC7653A7905.quest_desc: {
			new: [
				"&bКамера хімічної ін'єкції&r дозволяє вам &6обробляти&r різні &9руди&r та &cсирі руди&r, використовуючи &7Хлороводень&r, перетворюючи їх на численні &eфрагменти&r як перший крок до обробки руди з ефективністю &a400%&r."
				""
				"Ви також можете використовувати &7кисень&r для примусового &4окислення&r деяких мідних матеріалів, водяну пару для твердіння бетону, зворотного випалу глини та регідратації мертвого корала."
			]
			old: [
				"&bКамера ін'єкції&r дозволяє вам &6обробляти&r різні &9руди&r та &cсирі руди&r, використовуючи &7Хлороводень&r, перетворюючи їх на численні &eфрагменти&r як перший крок до обробки руди з ефективністю &a400%&r."
				""
				"Ви також можете використовувати &7кисень&r для примусового &4окислення&r деяких мідних матеріалів, водяну пару для твердіння бетону, зворотного випалу глини та регідратації мертвих коралів."
			]
		}
	}
	"chapters/Immersive Aircraft.snbt": {
		quest.16F37A3E31EBDA50.quest_desc: {
			new: [
				"Швидкий одномісний літак, вимагає більше зусиль для керування, але це дуже весело, друже!"
				""
				"Має трохи місця для зберігання, слот для зброї, чотири слоти для покращень, слот для прапора, і навіть може використовувати ракети для прискорення!"
