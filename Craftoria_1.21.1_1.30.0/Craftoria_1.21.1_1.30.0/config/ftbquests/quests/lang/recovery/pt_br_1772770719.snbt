		quest.475DC864A0BC0F1F.quest_desc: {
			new: [
				"  Як було сказано раніше, ви можете оновити свої бронзові машини до сталевих."
				""
				"  Створіть &bСталеве покращення&r і встановіть його на будь-яку бронзову машину &6за допомогою ковальського столу або пакувальника&r."
			]
			old: [
				"  Як було сказано раніше, ви можете оновити свої бронзові машини до сталевих."
				""
				"  Створіть &bСталеве покращення&r і встановіть його на будь-яку бронзову машину &6за допомогою ковальського столу або пакувальника&r."
			]
		}
		quest.0729CB454B970201.quest_desc: {
			new: [
				"  Це &bБронзовий бур&r. Він дасть вам основні руди, які знадобляться для подальшого розширення."
				""
				"  Перевірте вихідні дані в &6EMI&r і пам'ятайте, що бур має шанс зламатися, тому не робіть лише один."
			]
			old: [
				"  Це &bБронзовий бур&r. Він дасть вам основні руди, які знадобляться для подальшого розширення."
				""
				"  Перевірте вихідні дані в &6EMI&r і пам'ятайте, що бур має шанс зламатися, тому не робіть лише один."
			]
		}
		quest.5401B18217772D6C.quest_desc: {
			new: [
				"  Ви можете використовувати &bТеплообмінник&r, щоб, ну, обмінюватися теплом. Ви можете відновити &bВоду високого тиску&r для використання в іншому циклі."
				""
				"  Пам'ятайте, що &6підвищення тиску &bВоди&r &6до &bВоди високого тиску&r &6коштує багато енергії&r, але турбіна не обов'язково поверне її назад."
			]
			old: [
				"  Ви можете використовувати &bТеплообмінник&r, щоб, ну, обмінюватися теплом. Ви можете відновити &bВоду високого тиску&r для використання в іншому циклі."
				""
				"  Пам'ятайте, що &6підвищення тиску &bВоди&r &6до &bВоди високого тиску&r &6коштує багато енергії&r, але турбіна не обов'язково поверне її назад."
			]
		}
		quest.7AF270EF635B11CF.title: {
			new: "Вибухостійка лита пластина"
			old: "Вибухостійка лита пластина"
		}
		quest.7D0CF81F7E703B71.quest_desc: {
			new: [
				"{image:modern_industrialization:block/machines/water_pump/overlay_front_active width:32 height:32 align:center}"
				""
				"  Цікавитесь автоматичним перекачуванням &bВоди&r? Добре, що ви можете робити майже все, що забажаєте! &bВодяний насос&r автоматично збиратиме &bВоду&r і &6передаватиме її до сусідніх блоків&r. Переконайтеся, що розмістили джерела води навколо насоса горизонтально, подайте на нього &bПару&r, і він почне виробляти &bВоду&r за 1 EU/t."
				""
				"  &bБронзовий водяний насос&r вироблятиме &6125 мб &bВоди&r для кожного сусіднього джерела води кожні 5 секунд&r, що забезпечує максимальний вихід 1000 мб кожні 5 секунд."
			]
			old: [
				"{image:modern_industrialization:block/machines/water_pump/overlay_front_active width:32 height:32 align:center}"
				""
				"  Цікавитесь автоматичним перекачуванням &bВоди&r? Добре, що ви можете робити майже все, що забажаєте! &bВодяний насос&r автоматично збиратиме &bВоду&r і &6передаватиме її до сусідніх блоків&r. Переконайтеся, що розмістили джерела води навколо насоса горизонтально, подайте на нього &bПару&r, і він почне виробляти &bВоду&r за 1 EU/t."
				""
				"  &bБронзовий водяний насос&r вироблятиме &6125 мб &bВоди&r для кожного сусіднього джерела води кожні 5 секунд&r, що забезпечує максимальний вихід 1000 мб кожні 5 секунд."
			]
		}
		quest.6F57A2A5AA6E3F49.quest_subtitle: {
			new: "Солодка, солодка нафта"
			old: "Солодка, солодка нафта"
		}
		quest.22420EF3089DD7F6.quest_desc: {
			new: ["  Ваш перший смак справжньої &4а&r&6в&r&е&r&2т&r&а&r&м&r&а&r&т&r&и&r&з&r&а&r&ц&r&і&r&ї&r! Це також перша машина, яку ви захочете мати у великій кількості. &bМонтажник&r дозволяє &6автоматизувати&r майже всі рецепти, пов'язані з машинами. Перевірте свій &bEMI&r, щоб побачити, які рецепти ви можете автоматизувати за допомогою &bМонтажника&r. Ви можете налаштувати до &63 рецептів в одному монтажнику&r, використовуючи &6блокування слотів&r. Просто пам'ятайте, що він виконає стільки першого рецепта, скільки зможе, перш ніж перейти до наступного, &6тому ніколи не ставте кілька рецептів з високим попитом в один монтажник&r."]
			old: ["  Ваш перший смак справжньої &4а&r&6в&r&е&r&2т&r&а&r&м&r&а&r&т&r&и&r&з&r&а&r&ц&r&і&r&ї&r! Це також перша машина, яку ви захочете мати у великій кількості. &bМонтажник&r дозволяє &6автоматизувати&r майже всі рецепти, пов'язані з машинами. Перевірте свій &bEMI&r, щоб побачити, які рецепти ви можете автоматизувати за допомогою &bМонтажника&r. Ви можете налаштувати до &63 рецептів в одному монтажнику&r, використовуючи &6блокування слотів&r. Просто пам'ятайте, що він виконає стільки першого рецепта, скільки зможе, перш ніж перейти до наступного, &6тому ніколи не ставте кілька рецептів з високим попитом в один монтажник&r."]
		}
		quest.668453E081A6C57B.quest_desc: {
			new: [
				"  Викуваний у серці наднових, &bТитан&r має найвище співвідношення міцності до ваги. Він такий же міцний, як сталь, але на 45% легший, що робить його надзвичайно потужним для своєї ваги."
				""
				"  Він не магнітний, не корозійний і не проводить електрику, тому використання його для деталей машин може бути надзвичайно корисним."
				""
				"  Чи його рожевий колір звідкись береться?"
			]
			old: [
				"  Викуваний у серці наднових, &bТитан&r має найвище співвідношення міцності до ваги. Він такий же міцний, як сталь, але на 45% легший, що робить його надзвичайно потужним для своєї ваги."
				""
				"  Він не магнітний, не корозійний і не проводить електрику, тому використання його для деталей машин може бути надзвичайно корисним."
				""
				"  Чи його рожевий колір звідкись береться?"
			]
		}
		quest.6F57A2A5AA6E3F49.quest_desc: {
			new: [
				"  Нафта — це чорна горюча рідина, яка утворюється в ґрунті протягом &oдуже&r тривалого часу. &6Використовуючи &bБурову платформу&r&6, ви можете пробурити ґрунт і видобути цю нафту&r."
				""
				"  Нафта — це не єдине, що можна викачати з-під землі. Використання різних типів бурів визначає, яку рідину видобувати. Використовуйте свій EMI, щоб побачити, які бури видобувають яку рідину."
				""
				"  P.S. Не забувайте, це один із тих дуже складних мультиблоків. &6Використовуйте свій &bГайковий ключ&r &6, щоб побачити, як його побудувати&r!"
			]
			old: [
				"  Нафта — це чорна горюча рідина, яка утворюється в ґрунті протягом &oдуже&r тривалого часу. &6Використовуючи &bБурову платформу&r&6, ви можете пробурити ґрунт і видобути цю нафту&r."
				""
				"  Нафта — це не єдине, що можна викачати з-під землі. Використання різних типів бурів визначає, яку рідину видобувати. Використовуйте свій EMI, щоб побачити, які бури видобувають яку рідину."
				""
				"  P.S. Не забувайте, це один із тих дуже складних мультиблоків. &6Використовуйте свій &bГайковий ключ&r &6, щоб побачити, як його побудувати&r!"
			]
		}
		quest.29E6ED5067027F08.quest_desc: {
			new: [
				"- Може виконувати &6рецепти&r будь-якої &bелектричної&r машини для створення, наданої їй партіями."
				""
				"- Розмір партії визначається кількістю наданих їй &bмашин&r."
				""
				"- Вставляйте &bелектричні&r машини для створення, щоб працювати &6паралельно&r."
			]
			old: ["- Може виконувати &6рецепти&r будь-якої &bелектричної&r крафтової машини з одним блоком, що надається їй партіями."
				""
				"- Розмір партії визначається кількістю &bмашин&r, наданих їй."
				""
				"- Вставте &eелектричні&r крафтові машини для роботи в &6паралельному&r режимі."
			]
		}
		quest.39FCE3168C26B863.title: {
			new: "Кокс"
			old: "Коксове вугілля"
		}
		quest.64287B360B07BEBB.quest_subtitle: {
			new: "З'єднай їх!"
			old: "Закуй їх у ланцюги!"
		}
		quest.454FF6E2926163F7.quest_desc: {
			new: [
				"  Чесно кажучи, я не можу вас звинувачувати. Хоча, якщо ви прийшли сюди після того, як створили свій супер-неймовірний реактор з цікавості, я вас хвалю. Але для тих, кому потрібна допомога, чому б нам не почати? Увага!"
				""
				"  &bЯдерний реактор&r може виробляти в сотні разів більше EU/t, ніж дизель. Він буває різних розмірів, від &bмалого&r до &bекстремального&r."
				""
				"  Те, як це працює за лаштунками, може бути трохи приголомшливим, проте вам не потрібно розуміти деталі, щоб спроєктувати потужний реактор."
				""
				"  &6Зауважте, що в цьому світі &bЯдерний реактор&r &6&oне може&r &6вибухнути, випромінювати радіацію або іншим чином пошкодити навколишню територію&r. Єдине, що він може пошкодити — це предмети, які ви в нього кладете, якщо температура стане занадто високою, про що я розповім пізніше. Не соромтеся експериментувати та насолоджуйтеся своїм новим життям як ядерний фізик!"
				""
				"  Основним компонентом є &bЯдерна оболонка&r, яка виготовляється з &bЯдерного сплаву&r; суміші &bкадмію&r, &bберилію&r та &bвибухозахищеного сплаву&r."
				""
				"  Верхня частина структури приймає &bЛюки для предметів&r, &bЯдерну рідину&r або просто прості оболонки. &6Це входи та виходи реактора&r."
				""
				"  Кожен люк має один вхід (предмет або рідина) і два виходи. Вхідні слоти утворюють сітку, що відображається на панелі керування реактором (доступна при натисканні правою кнопкою миші на контролер)."
				""
				"  &6Кожен люк має температуру&r і накопичує тепло, яке можна розсіяти різними способами. Тепло природним чином переміщується до сусіднього люка або назовні, якщо люк знаходиться на краю, хоча це призведе до втрати тепла. Швидкість цього процесу дорівнює коефіцієнту теплопередачі вмісту люка, який можна знайти у вашому EMI, помноженому на різницю температур. Тепло також можна витягти в рідинний люк, &bвиробляючи пару&r. &6Температура вище максимальної температури предмета знищить його&r."
				""
				"  Центральними елементами ядерного реактора є &bнейтрони&r. Вони виробляються &bядерним паливом&r. Існує два типи нейтронів: &bшвидкі&r та &bтеплові&r: швидкі несуть енергію, тоді як теплові — ні. Нейтрони рухаються по прямій лінії, поки не зустрінуть елемент або не покинуть реактор, хоча для швидких нейтронів їхня енергія при цьому втрачається. Потік нейтронів відображається на панелі керування реактором."
				""
				"  Коли нейтрон зустрічає непорожній люк, можуть статися дві речі: нейтрон &bпоглинається&r або &bрозсіюється&r. &6Розсіяний нейтрон випадковим чином змінить напрямок&r. Якщо розсіяний нейтрон швидкий, він має шанс сповільнитися, стаючи тепловим. Це передає енергію нейтрона люку у вигляді тепла. &6Поглинутий нейтрон зупиняє свій курс і також передає свою енергію, якщо це був швидкий нейтрон&r."
				""
				"  Кількість нейтронів, поглинутих в одному люку, можна побачити на панелі керування. Ймовірність кожного процесу показана у вашому EMI. Це сильно залежатиме від вмісту люка та типу нейтрона, швидкого чи теплового. &6Ядерне паливо поглинає теплові нейтрони набагато краще&r."
				""
				"  Коли нейтрон, швидкий чи тепловий, поглинається ядерним паливом, генеруються нові нейтрони. Це завжди швидкі нейтрони, і вони мають випадковий напрямок. &6Їх генерація супроводжується прямим виділенням енергії у вигляді додаткового тепла в люку&r."
				""
				"  Вище певного порогу кількість згенерованих нейтронів зменшуватиметься з температурою, поки не досягне нуля. &6Цей процес витрачає частину енергії, але гарантує стабільність реактора&r. Кількість згенерованих нейтронів, ефективність, пряма енергія та температурний поріг відображаються у вашому EMI."
				""
				"  Кожен ядерний компонент має максимальну кількість поглинань. &6Коли вона досягається, предмет знищується або перетворюється на відпрацьований варіант&r. Це особливо корисно для ядерного палива, оскільки частина &6&bU238&r &6перетворюється на &bПлутоній&r &6у відпрацьованому варіанті&r, що означає, що частину його можна перетворити назад у паливо."
				""
				"  Те саме відбувається з рідинами, де трохи рідини перетворюється після кожного поглинання нейтрона. Це можна використовувати для масового виробництва корисних ізотопів, таких як &bдейтерій&r та &bтритій&r. В обох випадках результат показано у вашому EMI."
			]
			old: [
				"  Чесно кажучи, я не можу вас звинувачувати. Хоча, якщо ви прийшли сюди після того, як створили свій супер-неймовірний реактор з цікавості, я вас вітаю. Але для тих, кому потрібна допомога, чому б нам не почати? Увага!"
				""
				"  &bЯдерний реактор&r може виробляти в сотні разів більше EU/t, ніж дизель. Він буває різних розмірів, від &bмалого&r до &bекстремального&r."
				""
				"  Те, як він працює за лаштунками, може бути трохи приголомшливим, проте вам не потрібно розуміти деталі, щоб спроєктувати потужний реактор."
				""
				"  &6Зауважте, що в цьому світі &bЯдерний реактор&r &6&oне може&r &6вибухнути, випромінювати радіацію або пошкодити навколишню територію&r. Єдине, що він може пошкодити — це предмети, які ви в нього кладете, якщо температура стане занадто високою, про що я розповім пізніше. Не соромтеся експериментувати та насолоджуйтеся своїм новим життям як ядерний фізик!"
				""
				"  Основним компонентом є &bЯдерна оболонка&r, яка виготовляється з &bЯдерного сплаву&r; суміші &bкадмію&r, &bберилію&r та &bвибухозахищеного сплаву&r."
				""
				"  Верхня частина структури приймає &bЛюки для предметів&r, &bЯдерну рідину&r або просто прості оболонки. &6Це входи та виходи реактора&r."
				""
				"  Кожен люк має один вхід (предмет або рідина) і два виходи. Вхідні слоти утворюють сітку, що відображається на панелі керування реактором (доступна при натисканні правою кнопкою миші на контролер)."
				""
				"  &6Кожен люк має температуру&r і накопичує тепло, яке можна розсіяти різними способами. Тепло природним чином переміщується до сусіднього люка або назовні, якщо люк знаходиться на краю, хоча це призведе до втрати тепла. Швидкість цього процесу дорівнює коефіцієнту теплопередачі вмісту люка, який можна знайти у вашому EMI, помноженому на різницю температур. Тепло також можна витягти в рідинний люк, &bвиробляючи пару&r. &6Температура вище максимальної температури предмета знищить його&r."
				""
				"  Центральними елементами ядерного реактора є &bнейтрони&r. Вони виробляються &bядерним паливом&r. Існує два типи нейтронів: &bшвидкі&r та &bтеплові&r: швидкі несуть енергію, тоді як теплові — ні. Нейтрони рухаються по прямій лінії, поки не зустрінуть елемент або не покинуть реактор, хоча для швидких нейтронів їхня енергія при цьому втрачається. Потік нейтронів відображається на панелі керування реактором."
				""
				"  Коли нейтрон зустрічає непорожній люк, можуть статися дві речі: нейтрон &bпоглинається&r або &bрозсіюється&r. &6Розсіяний нейтрон випадковим чином змінить напрямок&r. Якщо розсіяний нейтрон швидкий, він має шанс сповільнитися, стаючи тепловим. Це передає енергію нейтрона люку у вигляді тепла. &6Поглинутий нейтрон зупиняє свій курс і також передає свою енергію, якщо це був швидкий нейтрон&r."
				""
				"  Кількість нейтронів, поглинутих в одному люку, можна побачити на панелі керування. Ймовірність кожного процесу показана у вашому EMI. Це сильно залежатиме від вмісту люка та типу нейтрона, швидкого чи теплового. &6Ядерне паливо поглинає теплові нейтрони набагато краще&r."
				""
				"  Коли нейтрон, швидкий чи тепловий, поглинається ядерним паливом, генеруються нові нейтрони. Це завжди швидкі нейтрони, і вони мають випадковий напрямок. &6Їх генерація супроводжується прямим виділенням енергії у вигляді додаткового тепла в люку&r."
				""
				"  Вище певного порогу кількість згенерованих нейтронів зменшуватиметься з температурою, поки не досягне нуля. &6Цей процес витрачає частину енергії, але гарантує стабільність реактора&r. Кількість згенерованих нейтронів, ефективність, пряма енергія та температурний поріг відображаються у вашому EMI."
				""
				"  Кожен ядерний компонент має максимальну кількість поглинань. &6Коли вона досягається, предмет знищується або перетворюється на відпрацьований варіант&r. Це особливо корисно для ядерного палива, оскільки частина &6&bU238&r &6перетворюється на &bПлутоній&r &6у відпрацьованому варіанті&r, що означає, що частину його можна перетворити назад у паливо."
				""
				"  Те саме відбувається з рідинами, де трохи рідини перетворюється після кожного поглинання нейтрона. Це можна використовувати для масового виробництва корисних ізотопів, таких як &bдейтерій&r та &bтритій&r. В обох випадках результат показано у вашому EMI."
			]
		}
		quest.37F3ABF113A1D399.quest_desc: {
			new: [
				"  &bЛюк входу енергії НВ&r — це як гігантська електрична розетка. Як я вже казав, вам потрібен &bЛюк входу енергії&r для живлення електричних багатоблокових машин."
				""
				"  Пам'ятайте, що ви можете покращити багатоблокову машину, замінивши &bЛюк входу енергії&r на вищий рівень, збільшуючи максимальну швидкість енергії для рецептів та загальні можливості оверклокінгу."
			]
			old: [
				"  &bЛюк входу енергії НВ&r — це як гігантська електрична розетка. Як я вже казав, вам потрібен &bЛюк входу енергії&r для живлення електричних багатоблокових машин."
				""
				"  Пам'ятайте, що ви можете покращити багатоблокову машину, замінивши &bЛюк входу енергії&r на вищий рівень, збільшуючи максимальну швидкість енергії для рецептів та загальні можливості оверклокінгу."
			]
		}
