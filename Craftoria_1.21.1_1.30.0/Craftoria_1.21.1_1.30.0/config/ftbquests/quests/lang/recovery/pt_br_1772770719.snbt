		}
		quest.3D5B74D9663AAB5A.quest_desc: {
			new: [
				"&bТепловий генератор&r — це просте джерело енергії, яке залежить від &cджерел тепла&r навколо нього. "
				""
				"&bГенератор&r може отримувати &cтепло&r з &a7&r точок, &a6&r з яких — це його різні грані. Ще одна — це сам генератор, який може бути &4занурений у лаву&r. Він не &6генерує&r багато енергії, але для початку вашої подорожі цього достатньо!"
				""
				"Енергію генеруватимуть не лише &bблоки&r та &7рідини&r, що випромінюють &cтепло&r, а й тепло від &bТермодинамічних провідників&r."
			]
			old: [
				"&bТепловий генератор&r — це просте джерело енергії, яке залежить від &cджерел тепла&r навколо нього."
				""
				"&bГенератор&r може отримувати &cтепло&r з &a7&r точок, &a6&r з яких — це його різні грані. Ще одна — це сам генератор, який може бути &4занурений у лаву&r. Він не &6генерує&r багато енергії, але для початку вашої подорожі цього достатньо!"
				""
				"Енергію генеруватимуть не лише &bблоки&r та &7рідини&r, що випромінюють &cтепло&r, а й тепло від &bТермодинамічних провідників&r."
			]
		}
		quest.550B874D9F2D0D5A.quest_desc: {
			new: [
				"&bЦифровий майнер&r — це автоматичний майнер, що базується на &eфільтрах&r. "
				""
				"У його графічному інтерфейсі ви можете вказати &eфільтри&r для конкретних &9блоків&r (не тільки руд) і навіть фільтрувати на основі тегів. "
				""
				"Його максимальний радіус становить &a32&r блоки. "
				""
				"Щоб дізнатися тег блоку, пам'ятайте про &bСловник&r."
			]
			old: [
				"&bЦифровий майнер&r — це автоматичний майнер, що базується на &eфільтрах&r. "
				""
				"У його графічному інтерфейсі ви можете вказати &eфільтри&r для конкретних &9блоків&r (не тільки руд) і навіть фільтрувати на основі тегів. "
				""
				"Його максимальний радіус становить &a32&r блоки. "
				""
				"Щоб дізнатися тег блоку, пам'ятайте про &bСловник&r."
			]
		}
