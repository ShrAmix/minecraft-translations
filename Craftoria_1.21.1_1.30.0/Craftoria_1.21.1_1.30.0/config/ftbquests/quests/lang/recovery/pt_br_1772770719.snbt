		quest.2B1717F5D6E20B79.quest_desc: {
			new: [
				"  За допомогою &bЕлектролізатора&r, достатньої кількості часу та енергії, а також вашої новоствореної &bСингулярності&r, ви можете видобувати величезні обсяги енергії через &bКвантове випромінювання Гокінга&r у формі &bУніверсально придатної матерії&r, також відомої просто як &dUU-матерія&r."
				""
				"  Це сама &oтканина&r &9всесвіту&r."
			]
			old: [
				"  За допомогою &bЕлектролізатора&r, достатньої кількості часу та енергії, а також вашої новоствореної &bСингулярності&r, ви можете видобувати величезні обсяги енергії через &bКвантове випромінювання Гокінга&r у формі &bУніверсально придатної матерії&r, також відомої просто як &dUU-матерія&r."
				""
				"  Це сама &oтканина&r &9всесвіту&r."
			]
		}
		quest.4D5787F48ECCB000.quest_desc: {
			new: [
				"&bСталева пивоварня&r може &6автоматично&r варити &aчотири&r зілля одночасно зі значно вищою швидкістю, ніж звичайна стійка для зілля."
				""
				"Пам'ятайте, що замість &6Вогняного порошку&r їй потрібна &eВогняна есенція&r."
			]
			old: [
				"&bСталева пивоварня&r може &6автоматично&r варити &aчотири&r зілля одночасно зі значно вищою швидкістю, ніж звичайна стійка для зілля."
