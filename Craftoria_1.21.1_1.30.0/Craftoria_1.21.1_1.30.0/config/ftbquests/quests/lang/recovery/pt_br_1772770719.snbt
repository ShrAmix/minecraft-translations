		quest.720874ECBFD3FD19.quest_desc: {
			new: [
				"  &bВуглик Блейза&r + РП → &4Вуглик Блейза Ø&r"
				""
				"  &bВугілля Порожнечі&r + &cВуглик Блейзаƒ&r → &4Вугілля Порожнечі Ø&r"
				""
				"  &bВуглик Затемнення&r + &cВугілля Порожнечіƒ&r → &4Вуглик Затемнення Ø&r"
				""
				"  &4&oX&r &4Ø&r + &bслиз&r* ➠ &c&oX&r &cƒ&r"
				""
				"    (* слиз має бути ≥ рівня)"
				""
				"   РП = рідкий полімер"
				"    Ø = &oнерафіноване&r паливо  "
				"    ƒ = паливо"
				" "
			]
			old: [
				"  &bВуглик Блейза&r + РП → &4Вуглик Блейза Ø&r"
				""
				"  &bВугілля Порожнечі&r + &cВуглик Блейзаƒ&r → &4Вугілля Порожнечі Ø&r"
				""
				"  &bВуглик Затемнення&r + &cВугілля Порожнечіƒ&r → &4Вуглик Затемнення Ø&r"
				""
				"  &4&oX&r &4Ø&r + &bслиз&r* ➠ &c&oX&r &cƒ&r"
				""
