	"chapters/Powah.snbt": {
		quest.5663A6C559490A29.quest_desc: {
			new: ["&6Клацніть правою кнопкою миші&f з &bперлиною повітря&f на &bзомбі&f або &bхаску&f, і вона буде готова."]
			old: ["&6Клацніть правою кнопкою миші&f з &bперлиною повітря&f на &bзомбі&f або &bхаску&f, і вона буде готова."]
		}
		quest.5E9F30ADD242C764.quest_desc: {
			new: [
				"&4Купуйте 2 за ціною 1, якщо зателефонуєте зараз!!!"
				"&bНітро-кристали &f— це матеріали, необхідні для найвищого рівня механізмів, а саме &bНітро&f. Виготовляються з &bЗірок Нетеру, Редстоуну&f та дрібки &bвогняних кристалів."
			]
			old: [
				"&4Купуйте 2 за ціною 1, якщо зателефонуєте зараз!!!"
				"&bНітро-кристали &f— це матеріали, необхідні для найвищого рівня механізмів, а саме &bНітро&f. Виготовляються з &bЗірок Нетеру, Редстоуну&f та дрібки &bвогняних кристалів."
			]
		}
		quest.0897CCAC72E82C5B.quest_desc: {
			new: [
				"&oPowah! — це про генерацію, зберігання та передачу енергії"
				"&8*Але не для Modern Industrialization"
			]
			old: [
				"&oPowah! — це про генерацію, зберігання та передачу енергії"
				"&8*Але не для Modern Industrialization"
			]
		}
		quest.098C3858B4FFCE78.quest_desc: {
			new: ["При використанні &bтермічного генератора&f, якщо ви поставите під нього &bвогняний блок&f, він працюватиме з &b280% ефективністю."]
			old: ["При використанні &bтермічного генератора&f, якщо ви поставите під нього &bвогняний блок&f, він працюватиме з &b280% ефективністю."]
		}
		quest.745ECCC690C1AD23.quest_desc: {
			new: ["&bВогняні кристали &fвиготовляються з матеріалу, який ви ніколи б не вгадали. Так, саме так, &bстрижні іфритів."]
			old: ["&bВогняні кристали &fвиготовляються з матеріалу, який ви ніколи б не вгадали. Так, саме так, &bстрижні іфритів."]
		}
		quest.292875386D7B9981.quest_subtitle: {
			new: "Можливо, варто одягнути рукавички"
			old: "Можливо, варто одягнути рукавички"
		}
		quest.6DED76B2F4AFD02F.quest_desc: {
			new: ["&bСухий лід &fнадзвичайно рідко зустрічається під землею, але ви можете зробити його, якщо у вас є достатньо &bенергії та льоду."]
			old: ["&bСухий лід &fнадзвичайно рідко зустрічається під землею, але ви можете зробити його, якщо у вас є достатньо &bенергії та льоду."]
		}
		quest.11FC8E533E897B8F.quest_desc: {
			new: ["Маючи лише &b500.000 FE&f, ви можете викликати &bблискавки&f, зарядивши &bsніжку в енергізаторі!!!"]
			old: ["Маючи лише &b500.000 FE&f, ви можете викликати &bблискавки&f, зарядивши &bsніжку в енергізаторі!!!"]
		}
		quest.292875386D7B9981.quest_desc: {
			new: ["&bУранініт &f— це руда, яку можна отримати &6видобутком&f. Ви також можете отримати її з &bКар'єру MI&f. &bУранініт&f є ключовою частиною Powah і використовується в багатьох рецептах та для живлення &bреактора."]
			old: ["&bУранініт &f— це руда, яку можна отримати &6видобутком&f. Ви також можете отримати її з &bКар'єру MI&f. &bУранініт&f є ключовою частиною Powah і використовується в багатьох рецептах та для живлення &bреактора."]
		}
		quest.5E9F30ADD242C764.quest_subtitle: {
			new: "Тепер лише за $19,99!"
			old: "Тепер лише за $19,99!"
		}
		quest.5663A6C559490A29.quest_subtitle: {
			new: "Не думаю, що ви повернете цього зомбі"
			old: "Не думаю, що ви повернете цього зомбі"
		}
		quest.407D04C17AA78E09.quest_subtitle: {
			new: "Вони можуть вам знадобитися"
			old: "Вони можуть вам знадобитися"
		}
		quest.48212961977655E7.quest_subtitle: {
			new: "Ви не можете чистити нею зуби"
			old: "Ви не можете чистити нею зуби"
		}
		quest.0897CCAC72E82C5B.quest_subtitle: {
			new: "Потрібно БІЛЬШЕ POWAH!, так?"
			old: "Потрібно БІЛЬШЕ POWAH!, так?"
		}
		quest.2476BE69FBC0681D.quest_subtitle: {
			new: "Можливо, для цієї структури знадобиться захисний костюм"
			old: "Можливо, для цієї структури знадобиться захисний костюм"
		}
		quest.2476BE69FBC0681D.quest_desc: {
			new: [
				"&bРеактори&f — це дуже хороше джерело &bенергії&f. Вони можуть генерувати від тисяч до сотень тисяч &bFE&f. Вони потребують &bредстоуну&f для зменшення споживання палива, &bвугілля&f для підвищення ефективності, &bльоду та води&f для охолодження реактора і, звісно, &bуранініту&f для живлення цього &bреактора&f."
				""
				"Для створення потрібно &b36 блоків реактора&f, і вони будуються самі. Так, ви не помилилися, вони збудуються автоматично, якщо у вас є всі &b36 блоків&f у вашому &6інвентарі&f, і ви &6поставите&f один з них — мультиблок сформується навколо нього як &b3x3x4&f."
			]
			old: [
				"&bРеактори&f — це дуже хороше джерело &bенергії&f. Вони можуть генерувати від тисяч до сотень тисяч &bFE&f. Вони потребують &bредстоуну&f для зменшення споживання палива, &bвугілля&f для підвищення ефективності, &bльоду та води&f для охолодження реактора і, звісно, &bуранініту&f для живлення цього &bреактора&f."
				""
				"Для створення потрібно &b36 блоків реактора&f, і вони будуються самі. Так, ви не помилилися, вони збудуються автоматично, якщо у вас є всі &b36 блоків&f у вашому &6інвентарі&f, і ви &6поставите&f один з них — мультиблок сформується навколо нього як &b3x3x4&f."
			]
		}
		quest.48212961977655E7.quest_desc: {
			new: [
				"Ну, думаю, ви могли б, але не думаю, що це було б смачно."
				""
				"&bДіелектрична паста &fвикористовується для &bКонденсаторів&f та &bМатриць&f. Вам знадобляться ці компоненти для створення машин та отримання &bPOWAH!!!"
			]
			old: [
				"Ну, думаю, ви могли б, але не думаю, що це було б смачно."
				""
				"&bДіелектрична паста &fвикористовується для &bКонденсаторів&f та &bМатриць&f. Вам знадобляться ці компоненти для створення машин та отримання &bPOWAH!!!"
			]
		}
		quest.5E9F30ADD242C764.title: {
			new: "&4Нітро-кристал"
			old: "&4Нітро-кристал"
		}
		task.7537E40C4FAB6D5C.title: {
			new: "Ласкаво просимо до Powah"
			old: "Ласкаво просимо до Powah"
		}
		quest.0035439F73199781.quest_desc: {
			new: ["Я думав, що &bсталь &f— це &bЗалізо та Вуглець&f, а це просто енергізоване, навіть не коване."]
			old: ["Я думав, що &bсталь &f— це &bЗалізо та Вуглець&f, а це просто енергізоване, навіть не коване."]
		}
		quest.7EF829BFBBB4009B.quest_desc: {
			new: ["Розміщуючи Енергетичні стрижні навколо Енергетичного орба, а потім живлячи стрижні, ви можете заряджати різні матеріали всередині орба. Це може варіюватися від унікальних предметів до комбінації предметів."
				""
				"Якщо ви хочете робити це швидше, ви можете заряджати масово! &bЗаряджання&r можна прискорити, якщо у вас достатньо &bенергії&r. Якщо у вас є &bблоки&r замість &bстрижнів&r, ви можете зробити &bзаряджений блок у 9 разів швидше&r."
			]
			old: [
				"Ao colocar hastes Energizadoras ao redor de um Orbe Energizador e depois energizar as hastes, você pode energizar diferentes materiais dentro do orbe. Isso pode variar de itens únicos a uma combinação de itens."
				""
				"Se você quiser fazer isso de forma mais rápida, pode energizar em massa! A &bEnergização&r pode ser acelerada se você tiver &benergia&r suficiente. Se você tiver os &bblocos&r em vez das &bbarras&r, pode fazer o &bbloco energizado 9x mais rápido&r."
			]
		}
	}
