		quest.660EFAF144F70749.quest_desc: {
			new: [
				"  Час для великого оновлення! Раніше ви могли виробляти лише 32 EU/т на турбіну, використовуючи &bПарову турбіну НН&r, але тепер ви зможете &6виробляти максимум 128 EU/т&r за допомогою нової &bПарової турбіни СН&r! Окрім чотирикратного збільшення виробництва енергії, вона працює точно так само, як і &bПарова турбіна НН&r."
				""
				"  Варто пам'ятати, що &6ви не зможете використовувати ті самі кабелі, що й раніше&r. Тепер вам знадобляться кабелі з &bКупронікелю&r або &bЕлектруму&r, щоб передавати цей новий рівень енергії СН."
			]
			old: [
				"  Час для великого оновлення! Раніше ви могли виробляти лише 32 EU/т на турбіну, використовуючи &bПарову турбіну НН&r, але тепер ви зможете &6виробляти максимум 128 EU/т&r за допомогою нової &bПарової турбіни СН&r! Окрім чотирикратного збільшення виробництва енергії, вона працює точно так само, як і &bПарова турбіна НН&r."
				""
				"  Варто пам'ятати, що &6ви не зможете використовувати ті самі кабелі, що й раніше&r. Тепер вам знадобляться кабелі з &bКупронікелю&r або &bЕлектруму&r, щоб передавати цей новий рівень енергії СН."
			]
		}
		quest.6CA941AE132445D9.quest_subtitle: {
			new: "Електронне серце"
			old: "Електронне серце"
		}
		quest.1987DF7742136DC4.quest_desc: {
			new: [
				"  Пам'ятаєте, я казав, що &bДистилятор&r може виробляти лише один тип рідини за цикл? Що ж, це ваше оновлення!"
				""
				"  &6Ви можете вибрати кількість шарів, до 9&r, і вона вироблятиме рідину &oдля кожного шару&r!"
				""
				"  Щоб вибрати розмір, який ви хочете налаштувати для &bДистиляційної вежі&r, використовуйте селектор у верхньому лівому куті екрана. Вдалої дистиляції!"
			]
			old: [
				"  Пам'ятаєте, я казав, що &bДистилятор&r може виробляти лише один тип рідини за цикл? Що ж, це ваше оновлення!"
				""
				"  &6Ви можете вибрати кількість шарів, до 9&r, і вона вироблятиме рідину &oдля кожного шару&r!"
				""
				"  Щоб вибрати розмір, який ви хочете налаштувати для &bДистиляційної вежі&r, використовуйте селектор у верхньому лівому куті екрана. Вдалої дистиляції!"
			]
		}
		quest.1D57C823A1F0203C.quest_desc: {
			new: [
				"  У мене є &bідеальний інструмент&r для вас, знадобиться лише трохи &6часу на створення&r. Це &bПаровий гірничий бур&r! Вони можуть &6видобувати&r у сітці &6набагато більшого розміру&r, ніж звичайні &bКирки&r; а саме &63x3&r. Ви не тільки зможете &6видобувати ефективніше&r, але й з легкістю прокладати гарні &bтунелі&r."
				""
				"  Хочете знати щось круте? Цей &bбур&r &6&oмає шовковий дотик&r до блоків! Я знаю, правда? Це неймовірно! Таким чином, ви отримаєте &6&oнабагато&r більше віддачі від своїх інвестицій, коли поєднаєте його з &bКовальським молотом&r, оскільки ви можете &6подрібнювати&r &bЦілісні руди&r замість того, щоб починати з &bСирої руди&r."
				""
				"  Маленький... як би це назвати, &6мінус&r? Вам потрібно &6заправляти його&r. З якоїсь причини сам &bбур&r &6ніколи&r насправді &6не ламається&r, але вам потрібно буде заправляти його &bВодою&r та якимось &bПаливом&r; наприклад, &bВугіллям&r або &bЛігнітом&r. Просто &6клацніть правою кнопкою миші&r по &bпредметах палива&r у вашому &bінвентарі&r, щоб &6заправити його&r!"
				""
				"  &aПоради&r: &6Носіть із собою&r &bВідро води&r. Це не тільки дозволить вам &6скасувати шкоду від падіння&r, якщо ви достатньо вправні, але й послужить джерелом &bВоди&r для роботи вашого &bбура&r. З якоїсь причини, залежно від випадку, &bДжерела води&r у цьому світі нескінченні; використовуйте це на свою користь."
				""
				"  &aБільше порад&r: &6Присядьте, щоб видобувати&r &bокремі блоки&r, якщо потрібно! Вони все одно будуть у формі &6Шовкового дотику&r, але це не робитиме &63x3&r, якщо вам потрібно видобувати &bблоки&r більш делікатно."
			]
			old: [
				"  У мене є &bідеальний інструмент&r для вас, знадобиться лише трохи &6часу на створення&r. Це &bПаровий гірничий бур&r! Вони можуть &6видобувати&r у сітці &6набагато більшого розміру&r, ніж звичайні &bКирки&r; а саме &63x3&r. Ви не тільки зможете &6видобувати ефективніше&r, але й з легкістю прокладати гарні &bтунелі&r."
				"""  Хочете знати дещо цікаве? Цей &bбур&r &6&oтакож використовує шовковий дотик&r на блоках! Я знаю, правда? Це неймовірно! Таким чином, ви отримаєте &6&oнабагато&r більше віддачі від своїх інвестицій, коли поєднаєте його з &bКовальським молотом&r, оскільки ви можете &6подрібнювати&r &bЦілісні руди&r замість того, щоб починати з &bСирих руд&r."
				""
				"  Маленький... ви б назвали це &6недоліком&r? Вам потрібно &6заправляти його&r. З якоїсь причини сам &bбур&r &6ніколи&r насправді не &6ламається&r, але вам потрібно буде заправляти його &bВодою&r та якимось &bПаливом, що горить&r; наприклад, &bВугіллям&r або &bЛігнітом&r. Просто &6Клацніть правою кнопкою миші&r на &bпаливні предмети&r у вашому &bбурі&r всередині вашого &bінвентарю&r, щоб &6заповнити його&r!"
				""
				"  &aПоради&r: &6Носіть із собою&r &bВідро води&r. Це не тільки дозволить вам &6скасувати шкоду від падіння&r, якщо ви достатньо вправні, але й послужить джерелом &bВоди&r для роботи вашого &bбура&r. З якоїсь причини, залежно від випадку, &bДжерела води&r у цьому світі нескінченні; використовуйте це на свою користь."
				""
				"  &aБільше порад&r: &6Присядьте, щоб видобувати&r &bокремі блоки&r, якщо потрібно! Вони все одно будуть у формі &6Шовкового дотику&r, але не робитимуть &63x3&r, якщо вам потрібно видобувати &bблоки&r більш делікатно."
			]
		}
		quest.7342F6461382E839.title: {
			new: "&dКвантовий арсенал"
			old: "&dArsenal Qu00e2ntico"
		}
