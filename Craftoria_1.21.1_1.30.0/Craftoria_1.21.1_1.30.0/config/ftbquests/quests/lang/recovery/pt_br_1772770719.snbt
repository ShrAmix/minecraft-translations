		quest.656CBEFEE317E2E7.quest_desc: {
			new: [
				"За замовчуванням обсяг сховища Актуатора не найбільший."
				""
				"Ви можете вирішити цю проблему, використовуючи &bСтабілізатори&r. Вони &6стабілізують&r зв'язок Актуатора з виміром сховища, дозволяючи йому &6зберігати все більше&r і більше."
			]
			old: [
				"Por padrão, o espaço de armazenamento do Atuador não é o maior."
				""
				"Você pode resolver esse problema usando &bEstabilizadores&r. Estes irão &6estabilizar&r ainda mais a conexão do Atuador com a dimensão de armazenamento, permitindo que ele &6armazene mais&r e mais."
			]
		}
		quest.168AB4DADB1CA2D9.quest_desc: {
			new: [
				"Вся &bКрейда&r виготовляється &6нечистою&r і може бути &6очищена&r у &5Духовному вогні&r, щоб стати придатною для використання."
				""
				"Біла крейда — це найпростіша базова крейда, яка не має власних унікальних властивостей."
			]
			old: [
				"Todo &bGiz&r é criado &6impuro&r, e pode ser &6purificado&r no &5Fogo Espiritual&r para se tornar utilizável."
				""
				"O Giz Branco é o giz de fundação mais simples e não tem propriedades únicas por si só."
			]
