		quest.63F26CC561D0B80D.quest_subtitle: {
			new: "Знайдено всередині його &6Вежі Ліча&r, великого комплексу з кількома розгалуженими вежами, що зустрічаються в лісі."
			old: "Знайдено всередині його &6Вежі Ліча&r, великого комплексу з кількома розгалуженими вежами, що зустрічаються в лісі."
		}
		quest.6531DF5573672E9E.quest_desc: {
			new: [
				"Тут немає лабіринту чи підземелля для навігації, оскільки &1Гідра&r не потребує жодного захисту від непроханих гостей."
				""
				"Успіхів!"
				""
				"Якщо ви виживете, отримайте &6Палаючу кров Гідри&r, і етап &aБолота&r у пригоді буде завершено."
			]
			old: [
				"Тут немає лабіринту чи підземелля для навігації, оскільки &1Гідра&r не потребує жодного захисту від непроханих гостей."
				""
				"Успіхів!"
				""
				"Якщо ви виживете, отримайте &6Палаючу кров Гідри&r, і етап &aБолота&r у пригоді буде завершено."
			]
		}
		quest.1D2EF18DBF02F6EB.quest_desc: {
			new: [
				"&6Темна вежа&r знаходиться на невеликій галявині в центрі &2Темного лісу&r."
				""
				"Центральна зона має червонувате осіннє листя та зів'ялу траву."
				""
				"&6Темна вежа&r є місцем багатьох жахливих експериментів."
			]
			old: [
				"&6Темна вежа&r знаходиться на невеликій галявині в центрі &2Темного лісу&r."
				""
				"Центральна зона має червонувате осіннє листя та зів'ялу траву."
				""
				"&6Темна вежа&r є місцем багатьох жахливих експериментів."
			]
		}
	}
	"chapters/Applied Energistics.snbt": {
		quest.77978ED3AC1DFA26.quest_desc: {
			new: ["&aExtendedAE &f— це мод, який можна використовувати для &aприскорення та розширення &aae2&f, щоб він працював швидше і був більшим."]
			old: ["&aExtendedAE &f— це мод, який можна використовувати для &aприскорення та розширення &aae2&f, щоб він працював швидше і був більшим."]
		}
		quest.1523A200F5E4361B.quest_desc: {
			new: ["&bРозширений вписувач&f дозволить виконувати &aчотири процеси&f одночасно."]
			old: ["&bРозширений вписувач&f дозволить виконувати &aчотири процеси&f одночасно."]
		}
		quest.5ECC7F4F5D2591D9.title: {
			new: "Розширені покращення"
			old: "Розширені покращення"
		}
		quest.1C7918099D5A55E2.quest_desc: {
			new: ["&bПаралельний прес&f використовується всередині &bВписувача&f для створення &bПаралельного процесора&f."]
			old: ["&bПаралельний прес&f використовується всередині &bВписувача&f для створення &bПаралельного процесора&f."]
		}
		quest.3973F425BD96668A.title: {
			new: "Термінал кодування шаблонів"
			old: "Термінал кодування шаблонів"
		}
		quest.72481CA0AC8AFD6A.quest_desc: {
			new: [
				"Хоча зовні він схожий на &bВкритий кабелем ME Fluix&r, він надає функцію діагностики, відображаючи &6використання каналів&r у &bкабелях&r. &6Канали&r виглядають як кольорові підсвічені лінії, що проходять уздовж чорної смуги на &bкабелях&r, даючи вам розуміння того, як ваші &6канали&r використовуються у вашій &6мережі&r."
				""
				"Перші чотири &6канали&r відображаються лініями, що відповідають кольору &bкабелю&r, наступні чотири — білими лініями."
			]
			old: [
				"Хоча зовні він схожий на &bВкритий кабелем ME Fluix&r, він надає функцію діагностики, відображаючи &6використання каналів&r у &bкабелях&r. &6Канали&r виглядають як кольорові підсвічені лінії, що проходять уздовж чорної смуги на &bкабелях&r, даючи вам розуміння того, як ваші &6канали&r використовуються у вашій &6мережі&r."
				""
				"Перші чотири &6канали&r відображаються лініями, що відповідають кольору &bкабелю&r, наступні чотири — білими лініями."
			]
		}
		quest.72481CA0AC8AFD6A.title: {
			new: "Розумний кабель Fluix"
			old: "Розумний кабель Fluix"
		}
		quest.237468FAB20906A8.quest_subtitle: {
			new: "2x Зберігання"
			old: "2x Зберігання"
		}
		quest.23CC2667A1269C9C.quest_desc: {
			new: ["До цього часу ви використовували лише &bНакопичувачі&f, які містили &6двовимірні дані&f у вигляді нулів та одиниць. Тепер ми будемо зберігати &6тривимірні дані&f у вигляді сировини. Це набагато складніший тип &bнакопичувача&f, тому він буде дорогим, і спочатку ви не зможете багато зберігати."]
			old: ["До цього часу ви використовували лише &bНакопичувачі&f, які містили &6двовимірні дані&f у вигляді нулів та одиниць. Тепер ми будемо зберігати &6тривимірні дані&f у вигляді сировини. Це набагато складніший тип &bнакопичувача&f, тому він буде дорогим, і спочатку ви не зможете багато зберігати."]
		}
		quest.7D57C6962950AA98.title: {
			new: "Процесори створення"
			old: "Процесори створення"
		}
		quest.06D66E791A9939DD.quest_desc: {
			new: ["Побудуйте &bЗарядник&r і живіть його за допомогою &bВібраційної камери&r або генераторів з інших модів."]
			old: ["Побудуйте &bЗарядник&r і живіть його за допомогою &bВібраційної камери&r або генераторів з інших модів."]
		}
		quest.20F99CBAD8D587DA.quest_desc: {
			new: ["Щоб отримати &bCertus&f, ви повинні спочатку відправитися до &bМетеорита&f і взяти принаймні 5 &bКварцу Certus&f, а також &6створити&f 1 &bДрузу Certus&f. З &bблоком Друзи&f ви можете &6помістити його&f на землю і чекати, поки він виросте. Коли &bКристали&f виростають, &bБлок Друзи&f має шанс &6деградувати&f до стану звичайного &bБлоку Certus&f і більше не рости."]
			old: ["Щоб отримати &bCertus&f, ви повинні спочатку відправитися до &bМетеорита&f і взяти принаймні 5 &bКварцу Certus&f, а також &6створити&f 1 &bДрузу Certus&f. З &bблоком Друзи&f ви можете &6помістити його&f на землю і чекати, поки він виросте. Коли &bКристали&f виростають, &bБлок Друзи&f має шанс &6деградувати&f до стану звичайного &bБлоку Certus&f і більше не рости."]
		}
		quest.2190034B6F3E2768.quest_desc: {
			new: ["Це основні компоненти &bПристроїв введення та виведення&f."]
			old: ["Це основні компоненти &bПристроїв введення та виведення&f."]
		}
		quest.2E883FCCA2FB281B.quest_desc: {
			new: ["Налаштувавши два &bКвантові кільця&f, ви можете підключити свою &bME-систему&f до будь-якого місця у світі. Підключіть перше до своєї &bME-системи&f, а друге — туди, де ви хочете мати зв'язок. Вам знадобляться 2 &bСплетені сингулярності&f, помістіть одну з них у кожне &bКвантове кільце&f, після чого вони будуть пов'язані."]
			old: ["Налаштувавши два &bКвантові кільця&f, ви можете підключити свою &bME-систему&f до будь-якого місця у світі. Підключіть перше до своєї &bME-системи&f, а друге — туди, де ви хочете мати зв'язок. Вам знадобляться 2 &bСплетені сингулярності&f, помістіть одну з них у кожне &bКвантове кільце&f, після чого вони будуть пов'язані."]
		}
		quest.2F993B0F106DB883.title: {
			new: "Вписувач"
			old: "Вписувач"
		}
		quest.19C33613F2811BAA.quest_desc: {
			new: ["&bБазовий термінал&f дозволяє вам отримати доступ до вашого &bсховища&f, але його можна покращити."]
			old: ["&bБазовий термінал&f дозволяє вам отримати доступ до вашого &bсховища&f, але його можна покращити."]
		}
		quest.0B98E8AC5CFB0FC2.quest_desc: {
			new: ["Отримується, коли ви дозволяєте своїм &bЕнтропійним агрегатам&f вирости до &aмаксимальної стадії&f."]
			old: ["Отримується, коли ви дозволяєте своїм &bЕнтропійним агрегатам&f вирости до &aмаксимальної стадії&f."]
		}
		quest.3B82F8F19AF630D5.quest_desc: {
			new: ["&bТочка перемикання&f працює так само, як &bСкляний кабель&f, але використовується для &6тимчасового вимкнення&f секції системи після неї, коли немає живлення. &6Подача енергії&f дозволить даним та енергії знову проходити."]
			old: ["&bТочка перемикання&f працює так само, як &bСкляний кабель&f, але використовується для &6тимчасового вимкнення&f секції системи після неї, коли немає живлення. &6Подача енергії&f дозволить даним та енергії знову проходити."]
		}
		quest.7C201074DDBAE831.quest_desc: {
			new: ["Думаю, весь той біом міг би зникнути у вашому &bME-сховищі..."]
			old: ["Думаю, весь той біом міг би зникнути у вашому &bME-сховищі..."]
		}
		quest.3E165961635B0C4B.quest_desc: {
			new: ["&6Метеорит&r завжди містить &bТаємничий куб&r. Як тільки ви знайдете &bТаємничий куб&f, ви повинні розбити його, щоб отримати всі &bПреси вписувача&f."]
			old: ["&6Метеорит&r завжди містить &bТаємничий куб&r. Як тільки ви знайдете &bТаємничий куб&f, ви повинні розбити його, щоб отримати всі &bПреси вписувача&f."]
		}
		quest.62FCB2F06126B622.quest_desc: {
			new: ["&bБездротовий термінал&f — це &bзвичайний термінал&f, який можна використовувати для доступу до &bME-системи&f без дротів. Використовуйте &bТочку доступу&f для підключення вашого &bТерміналу&f та використовуйте &bКарти підсилення&f, щоб збільшити загальну відстань цієї &bТочки доступу&f, на якій ви хочете використовувати свою систему. Використання кількох &bТочок доступу&f в одній мережі в різних місцях може допомогти вам покрити більшу територію."]
			old: ["&bБездротовий термінал&f — це &bзвичайний термінал&f, який можна використовувати для доступу до &bME-системи&f без дротів. Використовуйте &bТочку доступу&f для підключення вашого &bТерміналу&f та використовуйте &bКарти підсилення&f, щоб збільшити загальну відстань цієї &bТочки доступу&f, на якій ви хочете використовувати свою систему. Використання кількох &bТочок доступу&f в одній мережі в різних місцях може допомогти вам покрити більшу територію."]
		}
		quest.6DFA92E319E7DA77.title: {
			new: "Постачальник шаблонів"
			old: "Постачальник шаблонів"
		}
		quest.59128813386BFDB1.quest_desc: {
			new: [
				"&bТунелі точка-точка (P2P)&f можуть бути надзвичайно складними, але водночас дуже корисними. Ці &bтунелі&f можна використовувати для &6передачі до 32 каналів з однієї точки в іншу&f. Тепер ви можете запитати: \"Але чому я не можу просто використовувати &bЩільний кабель&f?\""
				"""І я тут, щоб сказати: ви можете! Але це &6жахливо неефективно&f. Ці 32 канали стискаються в один канал. Це означає, що теоретично ви можете підключити &61024 канали&f через &6один щільний кабель, замість лише 32&f."
				""
				"Вам доведеться використовувати &bКарту пам'яті&f, щоб &6пов'язати&f &bтунелі&f між собою через частоти. &6Shift+Правий клік&f на &bтунелі \"входу\" &bвстановить &bкарту пам'яті &fна цю частоту. &6Правий клік&f на &bтунелі \"виходу\" &fвстановить &bтунель &fна частоту &b\"входу\"&f. Майте на увазі, що ви можете мати кілька &bтунелів \"виходу\"&f, доки загальна кількість каналів, що використовуються між ними, не перевищує кількість каналів, введених у &bтунель \"входу\"&f."
				""
				"Існують також різні типи &bТочкових тунелів (P2P)&f. Окрім тих, що передають &bME-канали&f, є ті, що &6передають &bсиру енергію&f, &bрідини&f, &bпредмети&f, &bсвітло&f і навіть &bредстоун&f! Вони працюють так само, окрім &bпередачі каналів&f."
				""
				"Потрібен певний час на практику, тому спочатку поекспериментуйте з ними. Як тільки ви зрозумієте принцип, ваша &bME-система&f виглядатиме більш ніж професійно!"
			]
			old: [
				"&bТочкові тунелі (P2P)&f можуть бути надзвичайно складними, але водночас надзвичайно корисними. Ці &bтунелі&f можна використовувати для &6передачі до 32 каналів з однієї точки в іншу&f. Тепер ви можете запитати: \"Але чому я не можу просто використати &bЩільний кабель&f?\""
				""
				"І я тут, щоб сказати: ви можете! Але це &6надзвичайно неефективно&f. Ці 32 канали стискаються в один канал. Це означає, що теоретично ви можете підключити &61024 канали&f через &6один щільний кабель, замість лише 32&f."
				""
				"Вам доведеться використовувати &bКарту пам'яті&f, щоб &6з'єднати&f &bтунелі&f через частоти. &6Shift+Правий клік&f на тунелі &b\"входу\" &bвстановить &bкарту пам'яті &fна цю частоту. &6Правий клік&f на тунелі &b\"виходу\" &fвстановить &bтунель &fна частоту &b\"входу\"&f. Пам'ятайте, ви можете мати кілька тунелів &b\"виходу\"&f, доки загальна кількість каналів, що використовуються між ними, не перевищує кількість каналів, введених у тунель &b\"входу\"&f."
				""
				"Існують також різні типи &bТочкових тунелів&f. Окрім тих, що передають &bME-канали&f, є ті, що &6передають &bсиру енергію&f, &bрідини&f, &bпредмети&f, &bсвітло&f і навіть &bредстоун&f! Вони працюють так само, окрім &bпередачі каналів&f."
				""
				"Потрібно трохи практики, щоб навчитися ними користуватися, тому спочатку поекспериментуйте. Коли ви зрозумієте принцип, ваша &bME-система&f виглядатиме більш ніж професійно!"
			]
		}
		quest.4EC894E7808440AC.quest_subtitle: {
			new: "Четверна кількість шаблонів, 16-кратна швидкість"
			old: "Четверна кількість шаблонів, 16-кратна швидкість"
		}
