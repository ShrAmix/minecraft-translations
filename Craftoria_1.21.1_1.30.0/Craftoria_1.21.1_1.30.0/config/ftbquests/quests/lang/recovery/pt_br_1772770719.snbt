		quest.55391FF509DA53A5.quest_subtitle: {
			new: "Найпростіший шлях до алхімії"
			old: "Найпростіший шлях до алхімії"
		}
		quest.55391FF509DA53A5.quest_desc: {
			new: [
				"Алхімічне мистецтво &3Теургії&r може надати засоби для збільшення виходу руди, трансмутації одного матеріалу в інший та створення нескінченної кількості ресурсів."
				""
				"Ця &bкнига&r, Hermetica, буде вашим путівником разом із тим, чого я вас навчу."
			]
			old: [
				"Алхімічне мистецтво &3Теургії&r може надати засоби для збільшення виходу руди, трансмутації одного матеріалу в інший та створення нескінченної кількості ресурсів."
				""
				"Ця &bкнига&r, Hermetica, буде вашим путівником разом із тим, чого я вас навчу."
			]
		}
		quest.1EBE2B9A6CCE5A69.quest_desc: {
			new: [
				"&3Жезли віщування&r дозволяють алхіміку &6знаходити&r цінні блоки на відстані."
				""
				"&6Використання з присіданням&r жезла на блоці &6налаштує&r його на цей блок. Коли ви &6зарядите&r жезл, він надішле частинку до найближчого цільового блоку, який знайде — &cце споживає міцність&r. &6Використовуйте його&r знову, щоб \"позначити\" це місце. Коштовний камінь стає фіолетовішим, чим ближче ви до блоку."
				""
				"Скляний жезл, будучи найдешевшим, може знаходити лише &8Рясні&r та &aЗвичайні&r блоки."
			]
			old: [
				"&3Жезли віщування&r дозволяють алхіміку &6знаходити&r цінні блоки на відстані."
				""
				"&6Використання з присіданням&r жезла на блоці &6налаштує&r його на цей блок. Коли ви &6зарядите&r жезл, він надішле частинку до найближчого цільового блоку, який знайде — &cце споживає міцність&r. &6Використовуйте його&r знову, щоб \"позначити\" це місце. Коштовний камінь стає фіолетовішим, чим ближче ви до блоку."
				""
				"Скляний жезл, будучи найдешевшим, може знаходити лише &8Рясні&r та &aЗвичайні&r блоки."
			]
		}
		quest.4E6BB4279E8E793A.quest_desc: {
			new: ["&8Рясні&r ресурси зазвичай знаходяться всюди і у великих кількостях."]
			old: ["&8Рясні&r ресурси зазвичай знаходяться всюди і у великих кількостях."]
