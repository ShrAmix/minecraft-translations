		quest.41D1344A31FEA6DF.quest_desc: {
			new: [
				"  &bКанталові котушки&r — це новий тип обмотки для вашої &bAFE&r, що &6дозволяє споживати більше енергії&r та генерувати ще більше тепла. Будьте обережні, ви ж не хочете обпектися. Ай!"
				""
				"&bКанталові котушки&r не змусять вашу &bAFE&r автоматично нагріватися до &6найвищих температур&r. Комп'ютер керування має такі можливості, вам просто потрібно налаштувати значення, щоб дозволити йому повною мірою скористатися оновленням."
				""
				"  У цьому випадку все спрощено для вас. Зайдіть у &bGUI контролера&r, і у &6верхньому лівому куті&r ви побачите набір стрілок. Натисніть ту, що вказує праворуч, і вона змінить налаштування з рівня &bКупронікелю&r на рівень &bКанталу&r."
				""
				"  Легко, правда?"
			]
			old: [
				"  &bКанталові котушки&r — це новий тип обмотки для вашої &bEBF&r, що &6дозволяє споживати більше енергії&r та генерувати ще більше тепла. Будьте обережні, ви ж не хочете обпектися. Ай!"
				""
				"&bКанталові котушки&r не змусять вашу &bEBF&r автоматично нагріватися до &6найвищих температур&r. Комп'ютер керування має такі можливості, вам просто потрібно налаштувати значення, щоб дозволити йому повною мірою скористатися оновленням."
				""
				"  У цьому випадку все спрощено для вас. Зайдіть у &bінтерфейс контролера&r, і у &6верхньому лівому куті&r ви побачите набір стрілок. Натисніть ту, що вказує праворуч, і вона змінить налаштування з рівня &bКупронікелю&r на рівень &bКанталу&r."
				""
				"  Легко, правда?"
			]
		}
		quest.135FBE79D4415F15.quest_desc: {
			new: [
				"  Перш ніж ви запитаєте, відповідь — ні. Ці &bядерні бомби&r &oне&r вибухають. Це ядерні бомби без детонатора. "
				""
				"  Вони використовуються виключно для &bІмплозійного компресора&r."
			]
			old: [
				"  Перш ніж ви запитаєте, відповідь — ні. Ці &bядерні бомби&r &oне&r вибухають. Це ядерні бомби без детонатора. "
				""
				"  Вони використовуються виключно для &bІмплозійного компресора&r."
			]
		}
		quest.21939E58707A7756.quest_desc: {
			new: ["&bВеликий подрібнювач&r може &6подрібнювати&r рецепти партіями до 8 штук зі знижкою &a25%&r на вартість &eEU&r. Майте на увазі, він &cне&r змішуватиме рецепти, вони &oмають&r бути одного типу. Якщо ні, кожен тип рецепта буде &6розділений&r на свою партію максимум по 8 штук."]
			old: ["&bВеликий подрібнювач&r може &6подрібнювати&r рецепти партіями до 8 штук зі знижкою &a25%&r на вартість &eEU&r. Майте на увазі, він &cне&r змішуватиме рецепти, вони &oмають&r бути одного типу. Якщо ні, кожен тип рецепта буде &6розділений&r на свою партію максимум по 8 штук."]
		}
		quest.21584ECDBB6907DE.quest_desc: {
			new: [
				" &aСпокійно, спокійно!&r &bТік&r — це &6найменша одиниця&r часу, яку можна &6зареєструвати&r."
				""
				"  Це приблизно &6одна двадцята&r частина &bсекунди&r. Світ працює на цих \"&bтіках&r\", і ви можете &6використовувати їх&r на &bсвою&r користь!"
			]
			old: [
				" &aСпокійно, спокійно!&r &bТік&r — це &6найменша одиниця&r часу, яку можна &6зареєструвати&r."
				""
				"  Це приблизно &6одна двадцята&r частина &bсекунди&r. Світ працює на цих \"&bтіках&r\", і ви можете &6використовувати їх&r на &bсвою&r користь!"
			]
		}
		quest.3F0097CCBA02804C.quest_desc: {
			new: ["&bВелика парова піч&r може &6плавити&r рецепти партіями до 8 штук зі знижкою &a25%&r на вартість &eEU&r. Майте на увазі, вона &cне&r змішуватиме рецепти, вони &oмають&r бути одного типу. Якщо ні, кожен тип рецепта буде &6розділений&r на свою партію максимум по 8 штук."]
			old: ["&bВелика парова піч&r може &6плавити&r рецепти партіями до 8 штук зі знижкою &a25%&r на вартість &eEU&r. Майте на увазі, вона &cне&r змішуватиме рецепти, вони &oмають&r бути одного типу. Якщо ні, кожен тип рецепта буде &6розділений&r на свою партію максимум по 8 штук."]
