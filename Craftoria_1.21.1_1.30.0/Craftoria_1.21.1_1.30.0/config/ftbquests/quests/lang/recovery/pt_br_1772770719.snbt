		quest.7D155344A5A6CEF7.quest_desc: {
			new: [
				"&bТермічний Компресор&r використовує &eрізницю температур&r на протилежних сторонах блоку для стиснення &7повітря&r. "
				""
				"Щоб керувати ним, помістіть блок з &cвисокою температурою&r з одного боку і блок з &bнизькою температурою&r з протилежного боку. "
				"""Примітка: сторони &3Північ-Південь&r &eтермічно&r з'єднані між собою, так само як і сторони &3Схід-Захід&r, але між сторонами &3Північ-Південь&r та &3Схід-Захід&r &eтермічного з'єднання&r немає."
				""
				"&eТермічно з'єднані&r сторони намагатимуться вирівняти свої &bтемператури&r, тому важливо підтримувати &cзначний&r перепад температур для &aефективної&r роботи."
			]
			old: [
				"&bТермічний компресор&r використовує &eрізницю температур&r на протилежних сторонах блоку для стиснення &7повітря&r."
				""
				"Для роботи розмістіть блок з &cвисокою температурою&r з одного боку, а блок з &bнизькою температурою&r — з протилежного."
				""
				"Примітка: сторони &3Північ-Південь&r &eтермічно&r з'єднані між собою, так само як і сторони &3Схід-Захід&r, але між сторонами &3Північ-Південь&r та &3Схід-Захід&r &eтермічного з'єднання&r немає."
				""
				"&eТермічно з'єднані&r сторони намагатимуться вирівняти свої &bтемператури&r, тому важливо підтримувати &cзначний&r перепад температур для &aефективної&r роботи."
			]
		}
		quest.0D44F37BE787CA30.quest_desc: {
			new: ["Цю &3речовину&r можна &6обробити&r на &bУстановці термопневматичної обробки&r для отримання &eЗВГ&r, що є &aчудовим&r &7рідким паливом&r, порівнянним за якістю з &7Рафінованим паливом&r з &3Thermal Expansion&r. "]
			old: ["Цю &3речовину&r можна &6обробити&r на &bУстановці термопневматичної обробки&r для отримання &eЗВГ&r, що є &aчудовим&r &7рідким паливом&r, порівнянним за якістю з &7Рафінованим паливом&r з &3Thermal Expansion&r. "]
		}
		quest.67B17617F57B247F.quest_desc: {
			new: [
				"&bЛіфт&r використовує &7тиск&r для переміщення вас вгору та вниз між поверхами за допомогою &bКонтролера&r. При встановленні &bЛіфта&r ви можете піднятися на &eзагалом&r шість блоків; якщо ви ставитимете &bОснови ліфта&r одну на одну вище &cмаксимальної висоти&r, це &aзбільшить&r висоту на шість блоків за кожну додану основу."
				""
				"Ви також можете &aзбільшити&r ширину та глибину &bЛіфта&r, додавши таку ж кількість &bОснов ліфта&r, як і при початковому встановленні."
				""
				"&bКонтролер&r розміщується на &eрівні очей&r, на один блок вище підлоги, ліворуч або праворуч, але впритул до &bЛіфта&r, торкаючись &bШахти ліфта&r. Його потрібно ставити на кожному блоці, щоб &bЛіфт&r міг підніматися, оскільки він ковзає по &bрейках&r."
				""
				"Якщо ви хочете, щоб &bЛіфт&r піднімався на &330 блоків&r з &tтрьома поверхами&r, вам знадобиться:"
				""
				"&96&r &bОснов ліфта&r x ширина та глибина."
				""
				"&930&r &bШахт ліфта&r x ширина та глибина."
				""
				"&91&r &bКонтролер&r для кожного поверху, тобто три."
				""
				"&7Тиск&r, необхідний для &bЛіфта&r, досягає максимуму в &c5.0&r і не збільшується залежно від кількості &bОснов ліфта&r."
			]
			old: [
				"&bЛіфт&r використовує &7тиск&r для переміщення вас вгору та вниз між поверхами за допомогою &bКонтролера&r. При встановленні &bЛіфта&r ви можете піднятися на &eзагалом&r шість блоків. Якщо ви ставитимете &bОснови ліфта&r одну на одну вище &cмаксимальної висоти&r, це &aзбільшить&r висоту на шість блоків за кожну додану основу."
				""
				"Ви також можете &aзбільшити&r ширину та глибину &bЛіфта&r, додавши таку ж кількість &bОснов ліфта&r, як і при початковому встановленні."
				""
				"&bКонтролер&r розміщується на &eрівні очей&r, на один блок вище підлоги, ліворуч або праворуч, але впритул до &bЛіфта&r, торкаючись &bШахти ліфта&r. Його потрібно ставити на кожному блоці, щоб &bЛіфт&r міг підніматися, оскільки він рухається по &bрейках&r."
				""
				"Якщо ви хочете, щоб &bЛіфт&r піднімався на &330 блоків&r з &aтрьома поверхами&r, вам знадобиться:"
				""
				"&96&r &bОснов ліфта&r x ширина та глибина."
				""
				"&930&r &bШахт ліфта&r x ширина та глибина."
				""
				"&91&r &bКонтролер&r для кожного поверху, тобто три."
				""
				"&7Тиск&r, необхідний для &bЛіфта&r, досягає максимуму в &c5.0&r і не збільшується залежно від кількості &bОснов ліфта&r."
			]
		}
		quest.33CEED6232901CE5.quest_desc: {
			new: ["&6Використовується&r з &bВакуумним люком&r, ця машина &6засмоктуватиме&r будь-яких &7мобів&r поруч із собою і поміщатиме їх у &bЯдро генератора&r. Щоб це працювало, ви повинні спочатку &6створити&r &bЯдро генератора&r і &6вставити&r його у &bВакуумний люк&r."]
