		quest.4047F3E2AD081915.quest_desc: {
			new: ["&bМережевий інструмент&f — це покращений &bГайковий ключ&f, який показує &6діагностичну інформацію мережі&f, а також зберігає картки покращень. &6Клацання правою кнопкою миші&f по будь-якій частині &bМережі&f покаже діагностику так само, як це робить &bME-контролер&f. Він також тимчасово робить &bФасади&f прозорими, щоб ви могли знайти приховані кабелі."]
			old: ["&bМережевий інструмент&f — це покращений &bГайковий ключ&f, який показує &6діагностичну інформацію мережі&f, а також зберігає картки покращень. &6Клацання правою кнопкою миші&f по будь-якій частині &bМережі&f покаже діагностику так само, як це робить &bME-контролер&f. Він також тимчасово робить &bФасади&f прозорими, щоб ви могли знайти приховані кабелі."]
		}
		quest.3A20D522302FE7B9.quest_desc: {
			new: [
				"&bЛогічний процесор&f використовується на самому початку для отримання ваших перших одиниць та покращень."
				""
				"&bІнженерні процесори&f використовуються для створення &bКонтролера&f та інших компонентів для запуску вашої першої &bME-системи&f."
				""
				"&bОбчислювальні процесори&f використовуються в &bКомпонентах зберігання&f та деяких інших речах."
			]
			old: [
				"&bЛогічний процесор&f використовується на самому початку для отримання ваших перших одиниць та покращень."
				""
				"&bІнженерні процесори&f використовуються для створення &bКонтролера&f та інших компонентів для запуску вашої першої &bME-системи&f."
