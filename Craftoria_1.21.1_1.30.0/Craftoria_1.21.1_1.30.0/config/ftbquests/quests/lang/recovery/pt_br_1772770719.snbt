		quest.4E1B3935FC8A1170.quest_desc: {
			new: ["Ще 4x! У вас все чудово виходить!"]
			old: ["Ще 4x! У вас все чудово виходить!"]
		}
		quest.0B94435972292812.quest_desc: {
			new: [
				"&bПросторовий порт введення/виведення&f є ядром &bсистеми просторової оцифровки&f. Він розміщується у вершині, де сходяться всі 3 &bкраї пілона&f. Це місце, куди ви вставляєте &bПросторову комірку&f, що дозволяє їй &6захопити споруду або вивільнити її&f. Це також блок для подачі живлення при завантаженні системи."
				""
				"Ви також можете взаємодіяти з &bПросторовим портом введення/виведення&f за допомогою лійок або інших методів передачі, щоб автоматизувати процес, якщо бажаєте. &6Редстоун-сигнал&f — це все, що потрібно &bПросторовому порту введення/виведення&f для активації. Будьте обережні!"
			]
			old: ["&bПорт вводу/виводу простору &f— це ядро системи &bПросторової цифровізації&f. Він розміщується у вершині, де сходяться всі 3 &bзони стовпів&f. Саме сюди ви вставляєте &bПросторову одиницю&f, що дозволяє їй &6захопити конструкцію або звільнити її&f. Це також блок, який потрібно живити енергією під час завантаження системи."
				""
				"Ви також можете взаємодіяти з &bПортом вводу/виводу простору&f за допомогою лійок або інших методів передачі, щоб автоматизувати процес, якщо бажаєте. &6Сигнал редстоуну&f — це все, що потрібно &bПорту вводу/виводу простору&f для активації. Будьте обережні!"
			]
		}
		quest.70EA0BAAB50E32BF.quest_desc: {
			new: ["&bНарізувач схем&f — це те саме, що й &bВписувач&f, але він створює &a9 предметів&f за раз і є &aшвидшим&f. Він все ще має слоти для покращень."]
