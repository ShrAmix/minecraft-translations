		quest.692049F6F50CC017.title: {
			new: "&2Привид лицаря"
			old: "&2Cavaleiro Fantasma"
		}
		quest.692049F6F50CC017.quest_desc: {
			new: [
				"Під &2Темним лісом&r (а іноді й у навколишніх районах) лежать занепалі &6Фортеці лицарів Сутінків&r."
				""
				"Нижні рівні фортець повністю запечатані, і перед входом вам доведеться пройти невелику &bцеремонію посвячення&r."
				""
				"Вам доведеться знайти певну кімнату в руїнах верхньої частини фортеці."
				""
				"Кімната містить &bП'єдестал для трофеїв&r і неглибоку яму, заблоковану &6Щитами фортеці&r."
				""
				"Розміщення трофея одного з попередніх босів на п'єдесталі зніме щит і відкриє доступ до нижніх рівнів."
				""
				"Опинившись всередині основної частини фортеці, вам зрештою доведеться знайти &aПривидів лицарів&r, щоб продовжити шлях."
				""
				"Відправлення привидів на вічний спокій змусить дивні пристрої &8Тіньової вежі&r підкоритися вам."
			]
			old: [
				"Sob a &2Floresta Sombria&r (e às vezes as áreas circundantes) jazem as &6Fortalezas caídas dos Cavaleiros do Crepúsculo&r. "
				""
				"Os níveis inferiores das fortalezas estão completamente selados, e antes de entrar, você terá que completar uma pequena &bcerimônia de iniciação&r. "
				""
				"Você terá que encontrar uma sala específica nas ruínas superiores da fortaleza. "
				""
				"A sala contém um &bPedestal de Troféu&r e um fosso raso bloqueado por &6Escudos da Fortaleza&r."
				""
				"Colocar um troféu de um dos chefes anteriores no pedestal removerá o escudo e permitirá o acesso aos níveis inferiores."
				""
				"Uma vez dentro da parte principal da fortaleza, você eventualmente terá que encontrar os &aFantasmas Cavaleiros&r para prosseguir. "
				""
				"Enviar os fantasmas para seu descanso final fará com que os estranhos dispositivos da &8Torre Sombria&r obedeçam a você."
			]
		}
		quest.7DA49A7F33A82D1C.quest_subtitle: {
			new: "Можна знайти у внутрішньому дворі, прикрашеному в стилі змії."
			old: "Pode ser encontrado em um p00e1tio adornado com um motivo de cobra."
		}
		quest.413557ECF489FD2C.quest_subtitle: {
			new: "З'являється в рідкісних структурах на островах Енду."
			old: "Aparece em estruturas raras nas ilhas do End."
		}
		quest.5570CFF754032FDB.quest_desc: {
			new: [
				"Різноманітні крижані істоти населяють вежу, тоді як &9Снігова королева&r чекає в кімнаті, вкритій інеєм, біля вершини."
				""
				"Вона захищена &bкрижаним&r щитом і атакуватиме градом крижаних атак або кидатиметься на шукача пригод."
				""
				"Перемога над &9Сніговою королевою&r у бою завершить етап &bСнігового лісу&r пригоди."
			]
			old: [
				"Uma variedade de criaturas gélidas habita a torre, enquanto a &9Rainha da Neve&r aguarda em uma sala coberta de gelo perto do topo. "
				""
				"Ela é protegida por um escudo de &bgelo&r e atacará com uma barragem de ataques gélidos ou investirá contra o aventureiro. "
				""
				"Derrotar a &9Rainha da Neve&r em combate completará a fase da &bFloresta Nevada&r da aventura."
			]
		}
		quest.4C357D8CF72B8F25.quest_subtitle: {
			new: "З'являється в рідкісних структурах у Незері."
