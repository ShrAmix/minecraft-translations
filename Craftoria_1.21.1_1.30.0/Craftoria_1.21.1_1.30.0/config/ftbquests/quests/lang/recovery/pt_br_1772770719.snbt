		quest.4AAFD7E0D868844A.quest_desc: {
			new: ["Він &6викидає...&r це, те, корів, кріперів, овець або навіть гравців."]
			old: ["Він &6викидає...&r це, те, корів, кріперів, овець або навіть гравців."]
		}
		quest.590D73FDE6335297.quest_desc: {
			new: ["&6Вимірюйте&r, скільки &dенергії&r у вигляді одиниць навантаження ваші механізми &6генерують&r та &6споживають&r, або наскільки швидко вони працюють."]
			old: ["&6Вимірюйте&r, скільки &dенергії&r у вигляді одиниць навантаження ваші механізми &6генерують&r та &6споживають&r, або наскільки швидко вони працюють."]
		}
		quest.3F6730383CCC8BB0.quest_desc: {
			new: ["Не помиляйтеся... він може виглядати як звичайний &bказан&r, але він достатньо гнучкий, щоб працювати з &bКонвеєрами&r, &bТрубами для рідини&r, &bМеханічними змішувачами&r та &bПресами&r — &6забезпечуючи&r автоматизацію багатьох рецептів."]
			old: ["Не помиляйтеся... він може виглядати як звичайний &bказан&r, але він достатньо гнучкий, щоб працювати з &bКонвеєрами&r, &bТрубами для рідини&r, &bМеханічними змішувачами&r та &bПресами&r — &6забезпечуючи&r автоматизацію багатьох рецептів."]
		}quest.55AEBE2068711237.quest_desc: {
			new: [
				"Ах, скромне &bВодяне колесо&r."
				""
				"Це найпростіший перший крок для &6генерації&r безкоштовної енергії для Create, що також втілює обертальний рух — важливу особливість Create."
			]
			old: [
				"Ах, скромне &bВодяне колесо&r."
				""
				"Це найпростіший перший крок для &6генерації&r безкоштовної енергії для Create, що також втілює обертальний рух — важливу особливість Create."
			]
		}
		quest.1F71E19AD3CFCABC.quest_desc: {
			new: [
				"&oУвертюра 1812 року&r Чайковського… музика, під яку можна і будувати."
				""
				"&6Вистрілюйте&r свої плани будівель прямо у світ, блок за блоком."
			]
			old: [
				"&oУвертюра 1812 року&r Чайковського… музика, під яку можна і будувати."
				""
				"&6Вистрілюйте&r свої плани будівель прямо у світ, блок за блоком."
			]
		}
		quest.6227304103E32C74.quest_desc: {
			new: [
				"Зручний та корисний &bРезервуар для рідини&r працює самостійно або може бути &6об'єднаний&r у колони шириною 1, 2 на 2, 3 на 3, висотою до 30 блоків!"
				""
				"&6Помістіть його&r над джерелом тепла, &6накачайте&r достатньо &9води&r, і він стане котлом, який може живити &bПарові двигуни&r — більший котел, &6забезпечений&r більшою кількістю &9води&r та нагріванням, може &6приводити в дію&r більше &bПарових двигунів&r."
			]
			old: [
				"Зручний та корисний &bРезервуар для рідини&r працює самостійно або може бути &6об'єднаний&r у колони шириною 1, 2 на 2, 3 на 3, висотою до 30 блоків!"
				""
				"&6Помістіть його&r над джерелом тепла, &6накачайте&r достатньо &9води&r, і він стане котлом, який може живити &bПарові двигуни&r — більший котел, &6забезпечений&r більшою кількістю &9води&r та нагріванням, може &6приводити в дію&r більше &bПарових двигунів&r."
			]
		}
	}
