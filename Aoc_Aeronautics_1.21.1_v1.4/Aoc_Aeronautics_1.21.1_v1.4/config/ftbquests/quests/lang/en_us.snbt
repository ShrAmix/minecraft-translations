	chapter.7FF2874A6AAD533C.title: " &eІндустрія зачарувань"
	chapter_group.0ED9F00893D42C69.title: "&6Фермерство та їжа"
	chapter_group.24D8C97C99F7384D.title: "&e Аеронавтика"
	chapter_group.2F8B068425AF05D4.title: "&6Додатково"
	chapter_group.3B8AF43E1258A852.title: "&6Рай інженера"
